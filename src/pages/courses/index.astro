---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import FeaturedCourseCard from '../../components/FeaturedCourseCard.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const courses = (await getCollection('courses')).filter((c) => !c.data.draft);
const live = courses.filter((c) => c.data.status === 'live');
const comingSoon = courses.filter((c) => c.data.status === 'coming-soon');
// AI Mastery 2026 is the flagship per the mockup
const flagship = live.find((c) => c.slug === 'ai-mastery-2026')
  || live.find((c) => c.slug === 'claude-cowork-for-professionals')
  || live[0];
const otherLive = live.filter((c) => c !== flagship);
---

<AppLayout
  title="Courses"
  pane="courses"
  description="An apprenticeship for the AI-native operator. The Cowork Course is the flagship; eight more in flight or coming."
>
  <SectionHero
    cover={landingHero('courses')}
    eyebrow="Learn · the catalogue"
    title="Courses"
    titleHtml="Cour<em>ses</em>"
    lede="For operators already <em>in the work</em> — not beginners."
  />

  <section class="section-body">
    <h2 class="h2">For operators already <em>in the work</em> — not beginners.</h2>
    <p class="body-lead">One flagship live and recording right now. Seven more in the pipeline.</p>

    {flagship && <FeaturedCourseCard item={flagship} />}

    {otherLive.length > 0 && (
      <section class="course-section">
        <h2 class="h2">Other <em>live</em> courses</h2>
        <div class="course-grid">
          {otherLive.map((c) => (
            <a class="course-card" href={`/courses/${c.slug}/`}>
              <div class="cc-badge">LIVE</div>
              <div class="cc-title">{c.data.title}</div>
              <div class="cc-lede">{c.data.lede}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {comingSoon.length > 0 && (
      <section class="course-section">
        <h2 class="h2"><em>Coming soon</em></h2>
        <div class="course-grid">
          {comingSoon.map((c) => (
            <a class="course-card course-card-soon" href={`/courses/${c.slug}/`}>
              <div class="cc-badge">SOON</div>
              <div class="cc-title">{c.data.title}</div>
              <div class="cc-lede">{c.data.lede}</div>
            </a>
          ))}
        </div>
      </section>
    )}
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .course-section { margin-bottom: 4em; }
    .course-section .h2 { font-family: var(--font-display); font-size: 32px; font-weight: 500; color: var(--text-1); margin: 0 0 1.2em; }
    .course-section .h2 :global(em) { color: var(--accent); font-style: italic; }
    .course-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
    .course-card { display: flex; flex-direction: column; padding: 24px 26px; background: rgba(20, 20, 24, 0.45); border: 1px solid var(--border-2); border-radius: 12px; text-decoration: none; color: inherit; transition: border-color 0.2s var(--ease), transform 0.2s var(--ease); }
    .course-card:hover { border-color: rgba(168, 85, 247, 0.3); transform: translateY(-2px); }
    .course-card-soon { filter: grayscale(0.7); opacity: 0.85; }
    .course-card-soon:hover { filter: none; opacity: 1; }
    .cc-badge { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; color: var(--accent); margin-bottom: 12px; }
    .course-card-soon .cc-badge { color: var(--text-3); }
    .cc-title { font-family: var(--font-display); font-size: 22px; color: var(--text-1); margin: 0 0 8px; }
    .cc-lede { font-family: var(--font-body); font-size: 14px; color: var(--text-2); line-height: 1.55; margin: 0; }
  </style>
</AppLayout>
