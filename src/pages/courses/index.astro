---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero, itemHero } from '../../lib/hero-image';

export const prerender = true;

const courses = (await getCollection('courses')).filter((c) => !c.data.draft);
// No flagship call-out — every course sits in the grid. Live first (LIVE
// pill), then the coming-soon ones; the live status is shown on the card.
const live = courses.filter((c) => c.data.status === 'live');
const comingSoon = courses.filter((c) => c.data.status === 'coming-soon');
---

<AppLayout
  title="Courses"
  pane="courses"
  description="An apprenticeship for the AI-native operator. The Cowork Course is the flagship; eight more in flight or coming."
>
  <SectionHero
    cover={landingHero('courses')}
    eyebrow="Learn · the catalogue"
    title="Courses"
    titleHtml="<em>Courses</em>"
  />

  <section class="section-body">
    <h2 class="h2">For operators already <em>in the work</em> — not beginners.</h2>
    <p class="body-lead">One live and recording right now. Seven more in the pipeline.</p>

    <div class="room-grid">
      {live.map((c) => (
        <a class="room-card" href={`/courses/${c.slug}/`}>
          <div class="room-card-img" style={`background-image: url('${itemHero('courses', c.data.title.replace(/<[^>]+>/g, ''), c.slug)}');`}></div>
          <div class="room-card-veil"></div>
          <div class="room-card-group-pill is-signal">LIVE</div>
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">Course · live</div>
            <div class="room-card-title" set:html={c.data.titleHtml || c.data.title}></div>
            <div class="room-card-line">{c.data.lede}</div>
          </div>
        </a>
      ))}
      {comingSoon.map((c) => (
        <a class="room-card" href={`/courses/${c.slug}/`}>
          <div class="room-card-img" style={`background-image: url('${itemHero('courses', c.data.title.replace(/<[^>]+>/g, ''), c.slug)}');`}></div>
          <div class="room-card-veil"></div>
          <div class="room-card-group-pill is-muted">SOON</div>
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">Course · coming soon</div>
            <div class="room-card-title" set:html={c.data.titleHtml || c.data.title}></div>
            <div class="room-card-line">{c.data.lede}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>
</AppLayout>
