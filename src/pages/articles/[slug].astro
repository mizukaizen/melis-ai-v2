---
import { getCollection, type CollectionEntry } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

export async function getStaticPaths() {
  // Only `status: 'live'` entries get a detail route. Coming-soon entries
  // render on the index as non-clickable cards with a badge.
  const items = (await getCollection('articles')).filter((a) => a.data.status === 'live');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'articles'> };
const { item } = Astro.props as Props;
const { Content } = await item.render();
const data = item.data;
// Article-specific paper-craft if data.cover (extracted from ARTICLES_LIST) exists
const cover = (data.cover && data.cover.startsWith('/'))
  ? data.cover
  : (data.cover ? `/${data.cover}` : landingHero('articles'));
---

<AppLayout title={data.title} pane="articles" inRoom description={data.lede}>
  <SectionHero
    cover={cover}
    eyebrow={data.eyebrow}
    title={data.title}
    titleHtml={data.titleHtml}
    byline={data.byline}
    lede={data.lede}
  />

  <section class="section-body">
    <article class="article-content">
      <Content />
    </article>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .article-content { max-width: 720px; margin: 0 auto; }
    .article-content :global(p) {
      font-family: var(--font-body);
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-1);
      margin: 0 0 1.4em;
      max-width: 680px;
    }
    .article-content :global(h2) {
      font-family: var(--font-display);
      font-size: 30px;
      font-weight: 500;
      line-height: 1.2;
      color: var(--text-1);
      margin: 2.4em 0 0.7em;
    }
    .article-content :global(h2 em) { color: var(--accent); font-style: italic; }
    .article-content :global(ul) {
      list-style: none;
      padding: 0;
      margin: 0 0 1.6em;
      max-width: 680px;
    }
    .article-content :global(li) {
      padding: 14px 0;
      border-bottom: 1px solid var(--border-1);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.65;
      color: var(--text-2);
    }
    .article-content :global(li:last-child) { border-bottom: none; }
    .article-content :global(strong) { color: var(--text-1); }
    .article-content :global(em) { color: var(--accent); font-style: italic; }
    .article-content :global(blockquote) {
      border-left: 2px solid var(--accent);
      padding: 0.5em 0 0.5em 1.4em;
      margin: 2em 0;
      max-width: 640px;
    }
    .article-content :global(blockquote p) {
      font-family: var(--font-display);
      font-size: 22px;
      font-style: italic;
      color: var(--text-1);
      line-height: 1.45;
      margin: 0 0 0.6em;
    }
    .article-content :global(blockquote cite) {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-3);
      letter-spacing: 0.06em;
      font-style: normal;
    }
  </style>
</AppLayout>
