---
import { getCollection, type CollectionEntry } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

export async function getStaticPaths() {
  // Only `status: 'live'` entries get a detail route. Coming-soon entries
  // render on the index as non-clickable cards with a badge.
  const items = (await getCollection('articles')).filter((a) => a.data.status === 'live');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'articles'> };
const { item } = Astro.props as Props;
const { Content } = await item.render();
const data = item.data;
// Article-specific paper-craft if data.cover (extracted from ARTICLES_LIST) exists
const cover = (data.cover && data.cover.startsWith('/'))
  ? data.cover
  : (data.cover ? `/${data.cover}` : landingHero('articles'));
---

<AppLayout title={data.title} pane="articles" inRoom description={data.lede}>
  <SectionHero
    cover={cover}
    eyebrow={data.eyebrow}
    title={data.title}
    titleHtml={data.titleHtml}
    byline={data.byline}
  />

  <section class="section-body">
    {data.lede && <p class="body-lead">{data.lede}</p>}
    <article class="article-content">
      <Content />
    </article>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

</AppLayout>
