---
import { getCollection, type CollectionEntry } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('articles');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'articles'> };
const { item } = Astro.props as Props;
const { Content } = await item.render();
const data = item.data;
const cover = data.cover || '/card-articles-v1.png';
---

<AppLayout title={data.title} pane="articles" inRoom description={data.lede}>
  <section class="section-header">
    <div class="section-hero-bg" style={`background-image: url('${cover}');`}></div>
    <div class="section-hero-veil"></div>
    <div class="section-header-inner">
      <a class="back-link" href="/articles/" data-pane="articles">← back to Articles</a>
      <div class="section-title-block">
        {data.eyebrow && <div class="section-eyebrow">{data.eyebrow}</div>}
        <h1 class="section-title" set:html={data.titleHtml || data.title}></h1>
        {data.lede && <p class="section-lead">{data.lede}</p>}
        {data.byline && <p class="section-byline" style="margin-top:8px;font-family:var(--font-mono);font-size:11px;color:var(--text-3);letter-spacing:0.06em;">{data.byline}</p>}
      </div>
    </div>
  </section>

  <section class="section-body">
    <article class="article-content">
      <Content />
    </article>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .article-content :global(p) {
      font-family: var(--font-body);
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-1);
      margin: 0 0 1.4em;
      max-width: 68ch;
    }
    .article-content :global(h2) {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 500;
      line-height: 1.2;
      color: var(--text-1);
      margin: 2em 0 0.7em;
    }
    .article-content :global(h2 em) { color: var(--accent); font-style: italic; }
    .article-content :global(ul) {
      list-style: none;
      padding: 0;
      margin: 0 0 1.6em;
      max-width: 68ch;
    }
    .article-content :global(li) {
      padding: 12px 0;
      border-bottom: 1px solid var(--border-1);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.65;
      color: var(--text-2);
    }
    .article-content :global(li:last-child) { border-bottom: none; }
    .article-content :global(strong) { color: var(--text-1); }
    .article-content :global(em) { color: var(--accent); font-style: italic; }
    .article-content :global(blockquote) {
      border-left: 2px solid var(--accent);
      padding: 0.4em 0 0.4em 1.4em;
      margin: 2em 0;
      max-width: 60ch;
    }
    .article-content :global(blockquote p) {
      font-family: var(--font-display);
      font-size: 22px;
      font-style: italic;
      color: var(--text-1);
      line-height: 1.4;
      margin: 0 0 0.6em;
    }
    .article-content :global(blockquote cite) {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-3);
      letter-spacing: 0.06em;
      font-style: normal;
    }
  </style>
</AppLayout>
