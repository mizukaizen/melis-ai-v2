---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import FilterDropdown from '../../components/FilterDropdown.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

// Show ALL articles (live + coming-soon) on the index, sorted publishedAt desc.
// Coming-soon entries render as non-clickable cards with a badge — no detail
// route is built for them (see [slug].astro getStaticPaths filter).
const articles = (await getCollection('articles'))
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

const categories = ['All', ...new Set(articles.map((a) => a.data.category).filter((c): c is string => Boolean(c)))];

function formatDate(iso?: string) {
  // Mockup-canonical format: ISO YYYY-MM-DD. Sort-friendly + semantic.
  if (!iso) return '';
  return iso.slice(0, 10);
}

function fallbackCover(i: number) {
  return `/section-rooms/articles-${(i % 10) + 1}.png`;
}
---

<AppLayout
  title="Articles"
  pane="articles"
  description="Operator notes from inside the work — essays, field notes, tear-downs and tutorials from a decade of building with AI."
>
  <SectionHero
    cover={landingHero('articles')}
    eyebrow="Read · 06 · this season"
    title="Articles"
    titleHtml="<em>Articles</em>"
  />

  <section class="section-body">
    <div class="flat-list-header">
      <div>
        <h2 class="h2">Operator notes from <em>inside</em> the work.</h2>
      </div>
      <FilterDropdown id="articles-filter" options={categories} />
    </div>
    <p class="body-lead">Essays, field notes, tear-downs, and tutorials from a decade of building with AI. No theory, no listicles — only the writing I'd want to read myself.</p>

    <div class="flat-list-grid" id="articles-list">
      {articles.map((a, i) => {
        const cover = a.data.cover || fallbackCover(i);
        const tag = a.data.category || '';
        const date = formatDate(a.data.publishedAt);
        const tagLine = [tag, date].filter(Boolean).join(' · ');
        const isComingSoon = a.data.status === 'coming-soon';
        const Tag = isComingSoon ? 'div' : 'a';
        const cardProps = isComingSoon
          ? { class: 'flat-card flat-card-coming-soon', 'data-category': tag }
          : { class: 'flat-card', href: `/articles/${a.slug}/`, 'data-category': tag };
        return (
          <Tag {...cardProps}>
            <div class="flat-card-img" style={`background-image: url('${cover}');`}></div>
            <div class="flat-card-veil"></div>
            {isComingSoon && <div class="flat-card-badge">Coming soon</div>}
            <div class="flat-card-meta">
              {tagLine && <div class="flat-card-tag">{tagLine}</div>}
              <div class="flat-card-title">{a.data.title}</div>
              {a.data.lede && <div class="flat-card-line">{a.data.lede}</div>}
            </div>
          </Tag>
        );
      })}
    </div>

    {/* Mockup-canonical closing section (lifted verbatim from
        wireSectionDetails JS, lines 14723+ of the mockup HTML). */}
    <div class="landing-closing">
      <h2 class="h2">Field notes from a year of <em>building in the open</em>.</h2>
      <p class="body-lead">Essays, tear-downs and field notes. Every piece [draft] is something I am working on this quarter — not polished yet, but the substance is real.</p>
      <div class="group-block" style="margin-top: 28px;">
        <div class="group-eyebrow">Latest · 3 articles</div>
        <div class="v6-detail" style="margin-top:14px;">
          <div class="vd-rows">
            <a class="vd-row" href="/articles/the-operator-s-toolkit/">
              <div>
                <div class="vd-row-name">The Operator's Toolkit</div>
                <div class="vd-row-attr">22 Mar 2026 · essay · 8 min</div>
              </div>
              <div class="vd-row-take">Eleven tools, two principles, and the philosophy that decides which ones survive your spring-clean.</div>
              <div class="vd-row-cta">Read →</div>
            </a>
            <a class="vd-row" href="/articles/how-i-run-9-agents-from-helsinki/">
              <div>
                <div class="vd-row-name">How I Run 9 Agents from Helsinki</div>
                <div class="vd-row-attr">14 Mar 2026 · tear-down · 12 min</div>
              </div>
              <div class="vd-row-take">Full architecture write-up — Hetzner, OpenClaw, Telegram, and the L1/L2/L3 tier system.</div>
              <div class="vd-row-cta">Read →</div>
            </a>
            <a class="vd-row" href="/articles/on-the-two-way-door/">
              <div>
                <div class="vd-row-name">On the Two-Way Door</div>
                <div class="vd-row-attr">7 Mar 2026 · field note · 4 min</div>
              </div>
              <div class="vd-row-take">Bezos's frame for decision speed. Why most operators reverse it. And the situation where the model breaks.</div>
              <div class="vd-row-cta">Read →</div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <script>
    function wireFilter() {
      const sel = document.getElementById('articles-filter');
      const list = document.getElementById('articles-list');
      if (!sel || !list) return;
      sel.addEventListener('filter:change', (e) => {
        const val = (e as CustomEvent).detail as string;
        list.querySelectorAll<HTMLElement>('.flat-card').forEach((card) => {
          if (val === 'All' || card.dataset.category === val) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    }
    document.addEventListener('astro:page-load', wireFilter);
    wireFilter();
  </script>
</AppLayout>
