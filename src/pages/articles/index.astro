---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import FilterDropdown from '../../components/FilterDropdown.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const articles = (await getCollection('articles'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

const categories = ['All', ...new Set(articles.map((a) => a.data.category).filter((c): c is string => Boolean(c)))];

function formatDate(iso?: string) {
  // Mockup-canonical format: ISO YYYY-MM-DD. Sort-friendly + semantic.
  if (!iso) return '';
  return iso.slice(0, 10);
}

function fallbackCover(i: number) {
  return `/section-rooms/articles-${(i % 10) + 1}.png`;
}
---

<AppLayout
  title="Articles"
  pane="articles"
  description="Essays and field notes from inside the operation. Honest, slow, sometimes unfinished."
>
  <SectionHero
    cover={landingHero('articles')}
    eyebrow="Read · 06 · this season"
    title="Articles"
    titleHtml="<em>Articles</em>"
    lede="Essays and field notes from inside the operation. Honest, slow, sometimes unfinished."
  />

  <section class="section-body">
    <div class="flat-list-header">
      <div>
        <div class="section-eyebrow-small">{articles.length} articles · essays + field notes</div>
        <h2 class="h2">Operator notes from <em>inside</em> the work.</h2>
      </div>
      <FilterDropdown id="articles-filter" options={categories} />
    </div>
    <p class="body-lead">Essays, field notes, tear-downs, and tutorials from a decade of building with AI. No theory, no listicles — only the writing I'd want to read myself.</p>

    <div class="flat-list-grid" id="articles-list">
      {articles.map((a, i) => {
        const cover = a.data.cover || fallbackCover(i);
        const tag = a.data.category || '';
        const date = formatDate(a.data.publishedAt);
        const tagLine = [tag, date].filter(Boolean).join(' · ');
        return (
          <a class="flat-card" href={`/articles/${a.slug}/`} data-category={tag}>
            <div class="flat-card-img" style={`background-image: url('${cover}');`}></div>
            <div class="flat-card-veil"></div>
            <div class="flat-card-meta">
              {tagLine && <div class="flat-card-tag">{tagLine}</div>}
              <div class="flat-card-title">{a.data.title}</div>
              {a.data.lede && <div class="flat-card-line">{a.data.lede}</div>}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <script>
    function wireFilter() {
      const sel = document.getElementById('articles-filter');
      const list = document.getElementById('articles-list');
      if (!sel || !list) return;
      sel.addEventListener('filter:change', (e) => {
        const val = (e as CustomEvent).detail as string;
        list.querySelectorAll<HTMLAnchorElement>('a.flat-card').forEach((card) => {
          if (val === 'All' || card.dataset.category === val) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    }
    document.addEventListener('astro:page-load', wireFilter);
    wireFilter();
  </script>
</AppLayout>
