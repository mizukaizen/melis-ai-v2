---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import FilterDropdown from '../../components/FilterDropdown.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const articles = (await getCollection('articles'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

const categories = ['All', ...new Set(articles.map((a) => a.data.category).filter((c): c is string => Boolean(c)))];
---

<AppLayout
  title="Articles"
  pane="articles"
  description="Essays and field notes from inside the operation. Honest, slow, sometimes unfinished."
>
  <SectionHero
    cover={landingHero('articles')}
    eyebrow={`Read · ${articles.length} · this season`}
    title="Articles"
    titleHtml="<em>Articles</em>"
    lede="Essays and field notes from inside the operation. Honest, slow, sometimes unfinished."
  />

  <section class="section-body">
    <div class="articles-headstrip">
      <div>
        <div class="section-eyebrow-small">{articles.length} articles · essays + field notes</div>
        <h2 class="h2">Operator's notes from <em>inside</em> the work.</h2>
      </div>
      <FilterDropdown id="articles-filter" options={categories} />
    </div>
    <p class="body-lead">No tutorials. No "10 prompts that…" listicles. Just essays, observations, and field notes from someone using AI as a daily tool — sometimes thinking, sometimes ranting, always honest. Newsletter sends fresh ones every morning at dawn.</p>

    <div class="item-list" id="articles-list">
      {articles.map((a, i) => (
        <a class="item-row" href={`/articles/${a.slug}/`} data-category={a.data.category || ''}>
          <div class="num">No. {String(i + 1).padStart(2, '0')}</div>
          <div class="col-main">
            <h4>{a.data.title}</h4>
            {a.data.lede && <p>{a.data.lede}</p>}
          </div>
          <div class="col-meta">{a.data.category || '—'}{a.data.byline ? ` · ${a.data.byline}` : ''}</div>
        </a>
      ))}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .articles-headstrip {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 24px;
      margin-bottom: 24px;
    }
    @media (max-width: 720px) {
      .articles-headstrip { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <script>
    function wireFilter() {
      const sel = document.getElementById('articles-filter');
      const list = document.getElementById('articles-list');
      if (!sel || !list) return;
      sel.addEventListener('filter:change', (e) => {
        const val = (e as CustomEvent).detail as string;
        list.querySelectorAll<HTMLAnchorElement>('a.item-row').forEach((row) => {
          if (val === 'All' || row.dataset.category === val) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }
    document.addEventListener('astro:page-load', wireFilter);
    wireFilter();
  </script>
</AppLayout>
