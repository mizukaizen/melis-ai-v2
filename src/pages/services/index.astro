---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const services = (await getCollection('services')).filter((s) => !s.data.draft);
---

<AppLayout
  title="Services"
  pane="services"
  description="Work directly with Sean — strategy sprints, implementation, retainers."
>
  <SectionHero
    cover={landingHero('services')}
    eyebrow={`Work With Me · ${services.length} ways in`}
    title="Services"
    titleHtml="<em>Services</em>"
    lede="Three doors into the studio: a fortnight strategy sprint, a multi-week build, or an ongoing operator-level retainer. All start with a conversation."
  />

  <section class="section-body">
    <div class="services-grid">
      {services.map((s) => (
        <a class="service-card" href={`/services/${s.slug}/`}>
          <div class="sc-eyebrow">{s.data.eyebrow}</div>
          <h3 class="sc-title" set:html={s.data.titleHtml || s.data.title}></h3>
          <p class="sc-lede">{s.data.lede}</p>
        </a>
      ))}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 16px; max-width: 1100px; margin: 0 auto; }
    .service-card { display: flex; flex-direction: column; padding: 26px 28px; background: rgba(20, 20, 24, 0.45); border: 1px solid var(--border-2); border-radius: 12px; text-decoration: none; color: inherit; transition: border-color 0.2s var(--ease); }
    .service-card:hover { border-color: rgba(168, 85, 247, 0.3); }
    .sc-eyebrow { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; color: var(--text-3); margin-bottom: 10px; }
    .sc-title { font-family: var(--font-display); font-size: 26px; color: var(--text-1); margin: 0 0 10px; }
    .sc-title :global(em) { color: var(--accent); font-style: italic; }
    .sc-lede { font-family: var(--font-body); font-size: 14px; color: var(--text-2); line-height: 1.55; margin: 0; }
  </style>
</AppLayout>
