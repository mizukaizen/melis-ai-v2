---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const services = (await getCollection('services')).filter((s) => !s.data.draft);

const COVER_MAP: Record<string, string> = {
  'strategy-print-sprint': '/section-rooms/services-strategy.png',
  'business-ai-blueprint': '/section-rooms/services-advisory.png',
  'ai-builds-on-tap':      '/section-rooms/services-build.png',
  'fractional-operator':   '/section-rooms/services-fractional.png',
  'speaking':              '/section-rooms/services-speaking.png',
};
function coverFor(slug: string) {
  return COVER_MAP[slug] || '/section-rooms/services-landing.png';
}
---

<AppLayout
  title="Services"
  pane="services"
  description="Work directly with Sean — strategy sprints, implementation, retainers."
>
  <SectionHero
    cover={landingHero('services')}
    eyebrow="Work With Me · the offerings"
    title="Services"
    titleHtml="<em>Services</em>"
    lede="When you need the studio in the room — strategy sprints, agent builds, coaching, brand systems, speaking."
  />

  <section class="section-body">
    <div class="landing-intro">
      <h2 class="h2">When you need an <em>operator</em> in the room.</h2>
      <p class="body-lead">I work with three or four clients at a time. Bias toward depth, not volume. The work I take is what I'd want to teach later — which is the test that keeps it interesting on both sides.</p>
    </div>
    <div class="room-grid">
      {services.map((s) => (
        <a class="room-card" href={`/services/${s.slug}/`}>
          <div class="room-card-img" style={`background-image: url('${coverFor(s.slug)}');`}></div>
          <div class="room-card-veil"></div>
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">{s.data.eyebrow}</div>
            <div class="room-card-title" set:html={s.data.titleHtml || s.data.title}></div>
            <div class="room-card-line">{s.data.lede}</div>
          </div>
        </a>
      ))}
    </div>

    <hr class="rule" />

    {/* Mockup-canonical closing section: client list + CTA panel. */}
    <div class="landing-closing">
      <div class="section-eyebrow-small">Past clients · a sample</div>
      <h2 class="h2">Trusted by operators who <em>build for a living</em>.</h2>
      <p class="body-lead">Mercedes · Kiehl's · Brisbane Lions · Lyre's Spirits · Maybelline NY · Culture Amp · Snap Fitness · Jetts · JustDigitalPeople · JKL College — and a quiet list of solo founders, indie studios, and operators who'd rather not be named.</p>

      <div class="cta-panel">
        <div class="cta-panel-text">
          <h3>Want to <em>talk first</em>?</h3>
          <p>Twenty minutes, no slides. Just walk through what you're working on and what's stuck. I'll tell you whether I'm the right fit honestly.</p>
        </div>
        <a class="btn" href="mailto:sean@melis.ai">Email me →</a>
      </div>
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

</AppLayout>
