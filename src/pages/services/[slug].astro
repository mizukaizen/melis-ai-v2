---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import LeadForm from '../../components/LeadForm.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { itemHero, landingHero } from '../../lib/hero-image';
import { SERVICES_DETAIL } from '../../data/services';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('services');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'services'> };
const { item } = Astro.props as Props;
const data = item.data;
const detail = SERVICES_DETAIL[item.slug];
// Detail data wins over MDX frontmatter — it's the mockup-canonical copy.
const eyebrow = detail?.eyebrow || data.eyebrow;
const titleHtml = detail?.title || data.titleHtml || data.title;
const lede = detail?.lede || data.lede;
const strip = detail?.strip || data.strip || [];
const steps = detail?.whatYouGet || [];
const cta = detail?.cta;
const cover = (data.cover && data.cover.startsWith('/'))
  ? data.cover
  : itemHero('services', data.title.replace(/<[^>]+>/g, ''), item.slug) || landingHero('services');
const isComingSoon = (data as { status?: string }).status === 'coming-soon';
---

<AppLayout title={data.title} pane="services" inRoom description={lede}>
  <SectionHero
    cover={cover}
    eyebrow={eyebrow}
    title={data.title}
    titleHtml={titleHtml}
    lede={lede}
  />

  <section class="section-body">
    <div class="v6-detail">
      {strip.length > 0 && (
        <div class="vd-strip">
          {strip.map((s) => (
            <div class="vd-strip-item">
              <div class="lbl">{s.lbl}</div>
              <div class="val">{s.val}</div>
            </div>
          ))}
        </div>
      )}

      {isComingSoon && (
        <section class="vd-section service-soon">
          <span class="vd-pill is-violet">Coming soon</span>
          <div class="vd-prose">
            <p>This service is in development. Join the newsletter to be the first to know when it opens.</p>
          </div>
          <div class="ss-soon-form"><NewsletterForm /></div>
        </section>
      )}

      {!isComingSoon && steps.length > 0 && (
        <section class="vd-section">
          <h3 class="vd-h3">What you'll <em>walk away with</em>.</h3>
          <ol class="vd-steps">
            {steps.map((s) => (
              <li>
                <div class="vd-step-num">{s.num}</div>
                <div>
                  <div class="vd-step-title" set:html={s.title}></div>
                  <div class="vd-step-line">{s.line}</div>
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}

      {!isComingSoon && cta && (
        <div class="vd-cta">
          <div class="vd-cta-title">{cta.title}</div>
          <div class="vd-cta-line">{cta.line}</div>
        </div>
      )}

      {!isComingSoon && (
        <section class="vd-section service-lead-form">
          <h3 class="vd-h3">Get in <em>touch</em>.</h3>
          <div class="vd-prose">
            <p>Tell Sean what you're trying to ship. He responds personally within a working day.</p>
          </div>
          <LeadForm service={data.title} />
        </section>
      )}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    /* Service-specific glue — small additions to the v6-detail base */
    .service-soon { text-align: center; max-width: 540px; margin: 0 auto 2em; }
    .ss-soon-form { margin: 20px auto 0; max-width: 460px; }
    .service-lead-form { max-width: 540px; margin: 0 auto; }
  </style>
</AppLayout>
