---
import AppLayout from '../../layouts/AppLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import StripeBuyButton from '../../components/StripeBuyButton.astro';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('products');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'products'> };
const { item } = Astro.props as Props;
const { Content } = await item.render();
const data = item.data;
const cover = data.cover || '/card-products-v1.png';

function priceLabel(cents: number, currency: string) {
  const sym = currency === 'USD' ? '$' : currency === 'AUD' ? 'A$' : currency === 'EUR' ? '€' : '£';
  return `${sym}${(cents / 100).toFixed(0)}`;
}
---

<AppLayout title={data.title} pane="products" inRoom description={data.lede}>
  <section class="section-header">
    <div class="section-hero-bg" style={`background-image: url('${cover}');`}></div>
    <div class="section-hero-veil"></div>
    <div class="section-header-inner">
      <a class="back-link" href="/products/" data-pane="products">← back to Products</a>
      <div class="section-title-block">
        {data.eyebrow && <div class="section-eyebrow">{data.eyebrow}</div>}
        <h1 class="section-title" set:html={data.titleHtml || data.title}></h1>
        {data.lede && <p class="section-lead">{data.lede}</p>}
      </div>
    </div>
  </section>

  <section class="section-body">
    <div class="product-detail">
      <div class="product-pricing">
        <div class="price">{priceLabel(data.price, data.currency)}</div>
        {data.badge && <div class="badge">{data.badge}</div>}
      </div>

      <article class="product-body">
        <Content />
      </article>

      {data.breakdown && data.breakdown.length > 0 && (
        <section class="product-breakdown">
          <h3>What's in the bundle</h3>
          <ul>
            {data.breakdown.map((b) => (
              <li>
                <span class="bn">{b.name}</span>
                <span class="bc">{b.count}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <div class="product-cta">
        <StripeBuyButton productSlug={item.slug} label={`Buy — ${priceLabel(data.price, data.currency)}`} />
      </div>
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .product-detail { max-width: 760px; margin: 0 auto; }
    .product-pricing {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 28px;
    }
    .price {
      font-family: var(--font-display);
      font-size: 48px;
      color: var(--accent);
    }
    .badge {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.06em;
      padding: 4px 10px;
      background: var(--accent-subtle);
      color: var(--accent);
      border-radius: 4px;
    }
    .product-body :global(p) {
      font-family: var(--font-body);
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-1);
      margin: 0 0 1.4em;
    }
    .product-breakdown {
      margin-top: 3em;
      padding: 24px 28px;
      background: rgba(20, 20, 24, 0.45);
      border: 1px solid var(--border-2);
      border-radius: 12px;
    }
    .product-breakdown h3 {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-3);
      margin: 0 0 18px;
    }
    .product-breakdown ul { list-style: none; padding: 0; margin: 0; }
    .product-breakdown li {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid var(--border-1);
      font-family: var(--font-body);
      font-size: 15px;
    }
    .product-breakdown li:last-child { border-bottom: none; }
    .bn { color: var(--text-1); }
    .bc { color: var(--text-3); font-family: var(--font-mono); font-size: 12px; }
    .product-cta { margin-top: 3em; }
  </style>
</AppLayout>
