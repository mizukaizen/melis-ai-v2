---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import FeaturedProductCard from '../../components/FeaturedProductCard.astro';
import { getCollection } from 'astro:content';
import { PRODUCTS_HERO } from '../../data/products-hero';
import { PRODUCTS_CATEGORIES } from '../../data/products-categories';
import { landingHero, itemHero } from '../../lib/hero-image';

export const prerender = true;

// Curated mockup order: featured Complete Arsenal first, then by
// PRODUCTS_CATEGORIES declaration order (mockup-canonical priority).
const all = (await getCollection('products')).filter((p) => !p.data.draft);
const arsenal = all.find((p) => p.slug === 'complete-arsenal');
const others = all
  .filter((p) => p.slug !== 'complete-arsenal')
  .sort((a, b) => {
    const ai = PRODUCTS_CATEGORIES.findIndex((c) => c.title === (a.data.category || ''));
    const bi = PRODUCTS_CATEGORIES.findIndex((c) => c.title === (b.data.category || ''));
    return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
  });

function coverFor(p: { data: { title: string; cover?: string }; slug: string }) {
  if (p.data.cover && p.data.cover.startsWith('/')) return p.data.cover;
  return itemHero('products', p.data.title.replace(/<[^>]+>/g, ''), p.slug);
}
function priceLabel(cents: number) { return `$${(cents / 100).toFixed(0)}`; }
---

<AppLayout
  title="Products"
  pane="products"
  description="Starter kits, Claude skills, AI personas, spreadsheets, and more — the AI operator's toolbox."
>
  <SectionHero
    cover={landingHero('products')}
    eyebrow="Resources · the shop"
    title="Products & Tools"
    titleHtml="Products &amp; <em>Tools</em>"
    lede="Templates, prompt packs, frameworks, scripts, recipes. Things I made because I needed them, then packaged."
  />

  <section class="section-body">
    <div class="landing-intro">
      <h2 class="h2">Things I made because I needed them — <em>then</em> packaged so you can use them too.</h2>
      <p class="body-lead">Every product started as a tool I built for real client work, then refined enough times that it became reusable. Nothing here is theoretical.</p>
    </div>

    <FeaturedProductCard slug={PRODUCTS_HERO.id} hero={PRODUCTS_HERO} />

    {/* Uniform paper-craft image-card grid below the featured Arsenal —
        no per-category sections (mockup pattern, restored in scorecard pass). */}
    <div class="room-grid">
      {others.map((p) => (
        <a class="room-card" href={`/products/${p.slug}/`}>
          <div class="room-card-img" style={`background-image: url('${coverFor(p)}');`}></div>
          <div class="room-card-veil"></div>
          <div class="room-card-group-pill is-muted">{priceLabel(p.data.price)}</div>
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">{p.data.category}</div>
            <div class="room-card-title">{p.data.title}</div>
            <div class="room-card-line">{p.data.lede}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>
</AppLayout>
