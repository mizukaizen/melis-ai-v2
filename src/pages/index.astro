---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="melis.ai" pane="home">
  <section class="hero">
    <p class="eyebrow">melis.ai</p>
    <h1>Building at the <em>frontier</em> of AI.</h1>
    <p class="lead">
      Scaffold rendered. Home page port pending — see <code>src/pages/index.astro</code>.
    </p>
  </section>

  <style>
    .hero {
      max-width: var(--section-max-w);
      margin: 0 auto;
      padding-block: 6rem;
    }
    .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--text-3);
      margin-bottom: 1rem;
    }
    h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 500;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--text-1);
      margin-bottom: 1.5rem;
    }
    h1 em {
      font-style: italic;
      color: var(--accent);
    }
    .lead {
      font-size: 1.125rem;
      color: var(--text-2);
      max-width: 36rem;
    }
    code {
      font-family: var(--font-mono);
      font-size: 0.85em;
      background: var(--accent-subtle);
      padding: 0.1em 0.4em;
      border-radius: var(--r-sm);
      color: var(--accent);
    }
  </style>
</AppLayout>
