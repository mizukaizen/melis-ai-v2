---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const ventures = (await getCollection('ventures')).filter((v) => !v.data.draft);

const COVER_MAP: Record<string, string> = {
  'lighthouse':  '/section-rooms/ventures-lighthouse.png',
  'holy-signal': '/section-rooms/ventures-holy-signal.png',
  'phantom-ink': '/section-rooms/ventures-phantom-ink.png',
};
function coverFor(slug: string) {
  return COVER_MAP[slug] || '/section-rooms/ventures-landing.png';
}
---

<AppLayout
  title="Ventures"
  pane="projects"
  description="Live builds and sub-brands in flight from melis.ai."
>
  <SectionHero
    cover={landingHero('ventures')}
    eyebrow={`The Lab · ${ventures.length} · in flight`}
    title="Projects"
    titleHtml="<em>Projects</em>"
    lede="Six sub-brands and ten more ventures. Real things being made in public."
  />

  <section class="section-body">
    <div class="landing-intro">
      <h2 class="h2">Things being made — in public, in flight, <em>sometimes parked</em>.</h2>
      <p class="body-lead">Sub-brands and ventures that started as side projects and grew into something worth shipping. Status is honest: live, in flight, or parked.</p>
    </div>
    <div class="room-grid">
      {ventures.map((v) => (
        <a class="room-card" href={`/ventures/${v.slug}/`}>
          <div class="room-card-img" style={`background-image: url('${coverFor(v.slug)}');`}></div>
          <div class="room-card-veil"></div>
          {v.data.pill && (
            <div class={`room-card-group-pill ${v.data.pill.cls || ''}`}>{v.data.pill.label}</div>
          )}
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">{v.data.eyebrow}</div>
            <div class="room-card-title" set:html={v.data.titleHtml || v.data.title}></div>
            <div class="room-card-line">{v.data.lede}</div>
          </div>
        </a>
      ))}

      {/* Three additional prominent ventures from the mockup. No detail
          pages — these are display-only on the landing. Hrefs target
          the landing itself (mockup pattern). */}
      <a class="room-card" href="/ventures/">
        <div class="room-card-img" style="background-image: url('/section-rooms/ventures-hive-doctrine.png');"></div>
        <div class="room-card-veil"></div>
        <div class="room-card-group-pill is-orange">In flight</div>
        <div class="room-card-arrow">↗</div>
        <div class="room-card-meta">
          <div class="room-card-eyebrow">Sub-brand · In flight</div>
          <div class="room-card-title">Hive Doctrine</div>
          <div class="room-card-line">Marketplace + philosophy of multi-agent AI.</div>
        </div>
      </a>
      <a class="room-card" href="/ventures/">
        <div class="room-card-img" style="background-image: url('/section-rooms/exhibits/hive.jpg');"></div>
        <div class="room-card-veil"></div>
        <div class="room-card-group-pill is-signal">Live</div>
        <div class="room-card-arrow">↗</div>
        <div class="room-card-meta">
          <div class="room-card-eyebrow">Stack · Live</div>
          <div class="room-card-title">OpenClaw Self-Host</div>
          <div class="room-card-line">The Helsinki rig that runs everything quietly.</div>
        </div>
      </a>
      <a class="room-card" href="/ventures/">
        <div class="room-card-img" style="background-image: url('/card-projects-v1.png');"></div>
        <div class="room-card-veil"></div>
        <div class="room-card-group-pill is-signal">Live</div>
        <div class="room-card-arrow">↗</div>
        <div class="room-card-meta">
          <div class="room-card-eyebrow">Stack · Live</div>
          <div class="room-card-title">Polymarket Bots</div>
          <div class="room-card-line">Three Rust bots trading 30+ markets unattended.</div>
        </div>
      </a>
    </div>

    <hr class="rule" />

    {/* Mockup-canonical closing section: 10-item "Other things" list. */}
    <div class="landing-closing">
      <div class="section-eyebrow-small">Ten more projects · research, paused, ongoing</div>
      <h2 class="h2">Other things <em>in the studio</em>.</h2>
      <p class="body-lead">Sub-brand status is earned, not assumed. These are projects in research, paused, or running quietly that haven't earned their own brand yet — but they're part of the work.</p>
      <div class="item-list">
        <a class="item-row" href="#"><div class="num">01</div><div class="col-main"><h4>Polymarket trading bots</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">02</div><div class="col-main"><h4>OpenClaw multi-agent system</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">03</div><div class="col-main"><h4>NexusOS dashboard</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">04</div><div class="col-main"><h4>Persona Pantheon (12 sites)</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">05</div><div class="col-main"><h4>AI SDR pipeline</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">06</div><div class="col-main"><h4>Spell Stories (interactive fiction)</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">07</div><div class="col-main"><h4>Pantheon Market (agent marketplace)</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">08</div><div class="col-main"><h4>Saas Factory (project scaffold)</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">09</div><div class="col-main"><h4>Consultant OS</h4></div><div class="col-meta">In the lab</div></a>
        <a class="item-row" href="#"><div class="num">10</div><div class="col-main"><h4>Altar App</h4></div><div class="col-meta">In the lab</div></a>
      </div>
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

</AppLayout>
