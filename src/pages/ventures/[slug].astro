---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { itemHero, landingHero } from '../../lib/hero-image';
import { VENTURES_DETAIL } from '../../data/ventures';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('ventures');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'ventures'> };
const { item } = Astro.props as Props;
const data = item.data;
const detail = VENTURES_DETAIL[item.slug];
const rawEyebrow = detail?.eyebrow || data.eyebrow;
// The status (Live / Building / …) now rides in the coloured eyebrow
// pill, so strip a trailing "· <status>" from the eyebrow text to
// avoid saying it twice.
const eyebrow = rawEyebrow ? rawEyebrow.split('·')[0].trim() : rawEyebrow;
const titleHtml = detail?.title || data.titleHtml || data.title;
const lede = detail?.lede || data.lede;
const strip = detail?.strip || data.strip || [];
const sections = detail?.sections || [];
const pill = detail?.pill;
const cta = detail?.cta;
const problem = detail?.problem;
const capabilities = detail?.capabilities;
const pricing = detail?.pricing;
const whyNow = detail?.whyNow;
const proofPoints = detail?.proofPoints || [];
const asks = detail?.asks || [];
const siteUrl = detail?.siteUrl;
const cover = (data.cover && data.cover.startsWith('/'))
  ? data.cover
  : itemHero('projects', data.title.replace(/<[^>]+>/g, ''), item.slug) || landingHero('ventures');
---

<AppLayout title={data.title} pane="projects" inRoom description={lede}>
  <SectionHero
    cover={cover}
    eyebrow={eyebrow}
    title={data.title}
    titleHtml={titleHtml}
    eyebrowPill={pill}
  />

  <section class="section-body">
    <div class="v6-detail">
      {(!detail && data.status === 'coming-soon') ? (
        <div class="venture-stub">
          {data.groupV1 && (
            <span class="venture-stub-status">{data.groupV1}</span>
          )}
          <h2 class="h2">Detail page coming.</h2>
          <p class="body-lead">{data.lede || 'This venture is in flight — check back soon, or browse the live ventures.'}</p>
          <p class="body-lead">
            For the full picture, jump into <a href="/ventures/" style="color: var(--accent); border-bottom: 1px solid currentColor;">the ventures index</a> or have a look at the live ones below.
          </p>
          <div class="venture-stub-live">
            <div class="section-eyebrow-small">Live now</div>
            <ul class="venture-stub-live-list">
              <li><a href="/ventures/lighthouse/">Lighthouse — AI-native intelligence briefings</a></li>
              <li><a href="/ventures/holy-signal/">Holy Signal — Newsletter analytics for operators</a></li>
              <li><a href="/ventures/phantom-ink/">Phantom Ink — Editorial AI for serious writers</a></li>
            </ul>
          </div>
        </div>
      ) : (
        <>
          {strip.length > 0 && (
            <div class="vd-strip">
              {strip.map((s) => (
                <div class="vd-strip-item">
                  <div class="lbl">{s.lbl}</div>
                  <div class="val">{s.val}</div>
                </div>
              ))}
            </div>
          )}

          {sections.map((s) => (
            <section class="vd-section">
              <h3 class="vd-h3" set:html={s.h}></h3>
              <div class="vd-prose"><p>{s.body}</p></div>
            </section>
          ))}

          {/* ── Rich sales-page blocks (rendered when present) ── */}
          {problem && (
            <section class="vd-block vd-problem">
              <div class="vd-block-eyebrow">{problem.h}</div>
              <p class="vd-block-lead">{problem.body}</p>
            </section>
          )}

          {capabilities && (
            <section class="vd-block">
              <div class="vd-block-eyebrow">What it does</div>
              {capabilities.intro && <p class="vd-block-lead">{capabilities.intro}</p>}
              <div class="vd-cap-grid">
                {capabilities.groups.map((g) => (
                  <div class={`vd-cap vd-cap-${g.tone}`}>
                    <div class="vd-cap-head">
                      <span class="vd-cap-label">{g.label}</span>
                      {g.weight && <span class="vd-cap-weight">{g.weight}</span>}
                    </div>
                    <ul class="vd-cap-list">
                      {g.items.map((it) => <li>{it}</li>)}
                    </ul>
                  </div>
                ))}
              </div>
            </section>
          )}

          {pricing && (
            <section class="vd-block">
              <div class="vd-block-eyebrow">Pricing</div>
              {pricing.intro && <p class="vd-block-lead">{pricing.intro}</p>}
              <div class="vd-price-grid">
                {pricing.tiers.map((t) => (
                  <div class={`vd-price ${t.featured ? 'is-featured' : ''}`}>
                    {t.featured && <span class="vd-price-flag">Most popular</span>}
                    <div class="vd-price-name">{t.name}</div>
                    <div class="vd-price-amt">{t.price}</div>
                    <div class="vd-price-detail">{t.detail}</div>
                  </div>
                ))}
              </div>
            </section>
          )}

          {whyNow && (
            <section class="vd-block vd-whynow">
              <div class="vd-block-eyebrow">{whyNow.h}</div>
              <p class="vd-block-lead">{whyNow.body}</p>
            </section>
          )}

          {proofPoints.length > 0 && (
            <section class="vd-block">
              <div class="vd-block-eyebrow">Why it matters</div>
              <ul class="vd-proof-list">
                {proofPoints.map((p) => <li class="vd-proof">{p}</li>)}
              </ul>
            </section>
          )}

          {asks.length > 0 && (
            <section class="vd-block">
              <div class="vd-block-eyebrow">Three ways in</div>
              <div class="vd-ask-grid">
                {asks.map((a) => (
                  <div class="vd-ask">
                    <div class="vd-ask-audience">{a.audience}</div>
                    <p class="vd-ask-body">{a.body}</p>
                    <a class="vd-ask-cta" href={a.href} target={a.href.startsWith('http') ? '_blank' : undefined} rel={a.href.startsWith('http') ? 'noopener noreferrer' : undefined}>{a.cta}</a>
                  </div>
                ))}
              </div>
            </section>
          )}

          {cta && (
            <div class="vd-cta">
              <div class="vd-cta-title">{cta.title}</div>
              <div class="vd-cta-line">{cta.line}</div>
              {siteUrl && (
                <a class="vd-cta-btn" href={siteUrl} target="_blank" rel="noopener noreferrer">{cta.btn || 'Open ↗'}</a>
              )}
            </div>
          )}
        </>
      )}
    </div>
  </section>

  <style>
    /* ── Rich venture sales-page blocks ── */
    .v6-detail .vd-block {
      max-width: 880px;
      margin: 56px 0 0;
      padding-top: 40px;
      border-top: 1px solid var(--border-2, rgba(232,227,216,0.08));
    }
    .v6-detail .vd-block-eyebrow {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 18px;
    }
    .v6-detail .vd-block-lead {
      font-family: var(--font-display);
      font-size: 21px;
      line-height: 1.55;
      color: var(--text-1, var(--text));
      margin: 0 0 8px;
      max-width: 760px;
    }

    /* Capabilities — three signal columns */
    .v6-detail .vd-cap-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 28px;
    }
    .v6-detail .vd-cap {
      padding: 22px 22px 24px;
      border: 1px solid var(--border-2, rgba(232,227,216,0.08));
      border-top: 2px solid var(--cap-tone, var(--accent));
      background: rgba(255,255,255,0.015);
      border-radius: 4px;
    }
    .v6-detail .vd-cap-amber  { --cap-tone: #f5b342; }
    .v6-detail .vd-cap-accent { --cap-tone: #7c3aed; }
    .v6-detail .vd-cap-signal { --cap-tone: #5eead4; }
    .v6-detail .vd-cap-head {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 10px; margin-bottom: 16px;
    }
    .v6-detail .vd-cap-label {
      font-family: var(--font-display);
      font-size: 18px;
      color: var(--text-1, var(--text));
    }
    .v6-detail .vd-cap-weight {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--cap-tone, var(--accent));
    }
    .v6-detail .vd-cap-list { list-style: none; margin: 0; padding: 0; }
    .v6-detail .vd-cap-list li {
      font-size: 13px;
      line-height: 1.5;
      color: var(--text-2);
      padding: 7px 0 7px 16px;
      position: relative;
      border-bottom: 1px solid var(--border-2, rgba(232,227,216,0.05));
    }
    .v6-detail .vd-cap-list li:last-child { border-bottom: none; }
    .v6-detail .vd-cap-list li::before {
      content: ''; position: absolute; left: 0; top: 14px;
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--cap-tone, var(--accent));
    }

    /* Pricing tiers */
    .v6-detail .vd-price-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-top: 28px;
    }
    .v6-detail .vd-price {
      position: relative;
      padding: 24px 20px;
      border: 1px solid var(--border-2, rgba(232,227,216,0.08));
      background: rgba(255,255,255,0.015);
      border-radius: 6px;
      display: flex; flex-direction: column; gap: 10px;
    }
    .v6-detail .vd-price.is-featured {
      border-color: rgba(124,58,237,0.5);
      background: rgba(124,58,237,0.05);
    }
    .v6-detail .vd-price-flag {
      position: absolute; top: -9px; left: 20px;
      font-family: var(--font-mono);
      font-size: 8.5px; letter-spacing: 0.16em; text-transform: uppercase;
      color: #fff; background: var(--accent);
      padding: 3px 9px; border-radius: 999px;
    }
    .v6-detail .vd-price-name {
      font-family: var(--font-mono);
      font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--text-3);
    }
    .v6-detail .vd-price-amt {
      font-family: var(--font-display);
      font-size: 30px; line-height: 1;
      color: var(--text-1, var(--text));
    }
    .v6-detail .vd-price-detail {
      font-size: 12px; line-height: 1.55; color: var(--text-2);
    }

    /* Proof points */
    .v6-detail .vd-proof-list { list-style: none; margin: 24px 0 0; padding: 0; }
    .v6-detail .vd-proof {
      position: relative;
      padding: 14px 0 14px 28px;
      font-size: 15px; line-height: 1.6; color: var(--text-2);
      border-bottom: 1px solid var(--border-2, rgba(232,227,216,0.06));
      max-width: 820px;
    }
    .v6-detail .vd-proof:last-child { border-bottom: none; }
    .v6-detail .vd-proof::before {
      content: '→'; position: absolute; left: 0; top: 14px;
      color: var(--accent); font-family: var(--font-display);
    }

    /* The triple ask */
    .v6-detail .vd-ask-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 28px;
    }
    .v6-detail .vd-ask {
      display: flex; flex-direction: column;
      padding: 26px 24px;
      border: 1px solid var(--border-2, rgba(232,227,216,0.08));
      background: rgba(255,255,255,0.015);
      border-radius: 6px;
    }
    .v6-detail .vd-ask-audience {
      font-family: var(--font-mono);
      font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 14px;
    }
    .v6-detail .vd-ask-body {
      font-size: 14px; line-height: 1.6; color: var(--text-2);
      margin: 0 0 20px; flex: 1;
    }
    .v6-detail .vd-ask-cta {
      font-family: var(--font-mono);
      font-size: 11px; letter-spacing: 0.12em;
      color: var(--text-1, var(--text));
      text-decoration: none;
      border-bottom: 1px solid var(--accent);
      padding-bottom: 3px;
      align-self: flex-start;
      transition: color 160ms ease;
    }
    .v6-detail .vd-ask-cta:hover { color: var(--accent); }

    /* CTA button */
    .v6-detail .vd-cta-btn {
      display: inline-block;
      margin-top: 18px;
      padding: 13px 22px;
      background: var(--accent); color: #fff;
      border-radius: 8px;
      font-family: var(--font-mono);
      font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
      text-decoration: none;
      transition: filter 160ms ease, transform 120ms ease;
    }
    .v6-detail .vd-cta-btn:hover { filter: brightness(1.08); transform: translateY(-1px); }

    @media (max-width: 900px) {
      .v6-detail .vd-cap-grid,
      .v6-detail .vd-price-grid,
      .v6-detail .vd-ask-grid { grid-template-columns: 1fr; }
    }

    .venture-stub {
      padding: 28px 0;
    }
    .venture-stub-status {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      padding: 4px 10px;
      border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
      border-radius: 20px;
      margin-bottom: 16px;
    }
    .venture-stub .h2 { margin: 8px 0 12px; }
    .venture-stub .body-lead { margin: 0 0 14px; }
    .venture-stub-live {
      margin-top: 32px;
      padding-top: 20px;
      border-top: 1px solid var(--border-2);
    }
    .venture-stub-live-list {
      list-style: none;
      padding: 0;
      margin: 8px 0 0;
    }
    .venture-stub-live-list li {
      padding: 6px 0;
    }
    .venture-stub-live-list a {
      color: var(--text-1);
      text-decoration: none;
      border-bottom: 1px solid var(--border-2);
      padding-bottom: 1px;
      transition: color 0.15s ease, border-color 0.15s ease;
    }
    .venture-stub-live-list a:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
  </style>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>
</AppLayout>
