---
import { getCollection, type CollectionEntry } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('newsletter');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'newsletter'> };
const { item } = Astro.props as Props;
const { Content } = await item.render();
const data = item.data;
const cover = data.cover || '/hero-newsletter.png';
---

<AppLayout title={data.title} pane="newsletter" inRoom description={data.lede}>
  <section class="section-header">
    <div class="section-hero-bg" style={`background-image: url('${cover}');`}></div>
    <div class="section-hero-veil"></div>
    <div class="section-header-inner">
      <a class="back-link" href="/newsletter/" data-pane="newsletter">← back to Newsletter</a>
      <div class="section-title-block">
        {data.eyebrow && <div class="section-eyebrow">{data.eyebrow}</div>}
        <h1 class="section-title" set:html={data.titleHtml || data.title}></h1>
        {data.lede && <p class="section-lead">{data.lede}</p>}
        {data.byline && <p class="section-byline" style="margin-top:8px;font-family:var(--font-mono);font-size:11px;color:var(--text-3);letter-spacing:0.06em;">{data.byline}</p>}
      </div>
    </div>
  </section>

  <section class="section-body">
    <article class="article-content">
      <Content />
    </article>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>
</AppLayout>
