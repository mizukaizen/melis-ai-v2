---
import AppLayout from '../../layouts/AppLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import html from '../../_html/pane-newsletter.html?raw';

export const prerender = true;
---

<AppLayout
  title="Newsletter"
  pane="newsletter"
  description="Soul of the Machine — sent at dawn, six days a week. 23,000+ readers."
>
  <Fragment set:html={html} />
  <div class="newsletter-subscribe-block" style="max-width:1280px;margin:48px auto 80px;padding:0 clamp(24px,3vw,56px);">
    <NewsletterForm />
  </div>
</AppLayout>
