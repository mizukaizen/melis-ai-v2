---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import FilterDropdown from '../../components/FilterDropdown.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const issues = (await getCollection('newsletter'))
  .filter((n) => !n.data.draft)
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

const filters = ['All', 'Soul of the Machine', "Operator's Brief", 'Hive Doctrine'];
---

<AppLayout
  title="Newsletter"
  pane="newsletter"
  description="A daily dispatch from inside the operation. Field notes, observations, and one-line wins from a working studio."
>
  <SectionHero
    cover={landingHero('newsletter')}
    eyebrow="Channel · the dispatches"
    title="Newsletter"
    titleHtml="<em>Newsletter</em>"
    lede="A daily dispatch from inside the operation. Field notes, observations, and one-line wins from a working studio."
  />

  <section class="section-body">
    <div class="newsletter-subscribe-block">
      <NewsletterForm />
    </div>

    <div class="articles-headstrip" style="margin-top:4em;">
      <div>
        <div class="section-eyebrow-small">{issues.length} issues · three threads</div>
        <h2 class="h2"><em>Bi-weekly</em> dispatches from the studio.</h2>
      </div>
      <FilterDropdown id="newsletter-filter" options={filters} />
    </div>

    <div class="item-list" id="newsletter-list">
      {issues.map((n, i) => (
        <a class="item-row" href={`/newsletter/${n.slug}/`} data-category={n.data.byline?.split('·')[1]?.trim() || ''}>
          <div class="num">No. {String(i + 1).padStart(2, '0')}</div>
          <div class="col-main">
            <h4>{n.data.title}</h4>
            {n.data.lede && <p>{n.data.lede}</p>}
          </div>
          <div class="col-meta">{n.data.publishedAt || ''}</div>
        </a>
      ))}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .newsletter-subscribe-block { max-width: 540px; margin-top: 12px; }
    .articles-headstrip { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; margin-bottom: 24px; }
    @media (max-width: 720px) { .articles-headstrip { flex-direction: column; align-items: flex-start; } }
  </style>

  <script>
    function wireFilter() {
      const sel = document.getElementById('newsletter-filter');
      const list = document.getElementById('newsletter-list');
      if (!sel || !list) return;
      sel.addEventListener('filter:change', (e) => {
        const val = (e as CustomEvent).detail as string;
        list.querySelectorAll<HTMLAnchorElement>('a.item-row').forEach((row) => {
          if (val === 'All' || (row.dataset.category || '').includes(val)) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }
    document.addEventListener('astro:page-load', wireFilter);
    wireFilter();
  </script>
</AppLayout>
