---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import FilterDropdown from '../../components/FilterDropdown.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

// Show ALL issues (live + coming-soon) on the index, sorted publishedAt desc.
// Coming-soon entries render as non-clickable cards with a badge.
const issues = (await getCollection('newsletter'))
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

const filters = ['All', 'Soul of the Machine', "Operator's Brief", 'Hive Doctrine'];

function formatDate(iso?: string) {
  // Mockup-canonical format: ISO YYYY-MM-DD.
  if (!iso) return '';
  return iso.slice(0, 10);
}

function newsletterCover(slug: string, fallbackIndex: number) {
  // Per-issue paper-craft images live at /section-rooms/news-1.png ... news-6.png.
  // Cycle through them deterministically so each issue gets a stable cover.
  return `/section-rooms/news-${(fallbackIndex % 6) + 1}.png`;
}

function tagFor(byline?: string) {
  if (!byline) return '';
  const parts = byline.split('·').map((s) => s.trim());
  return parts[1] || '';
}
---

<AppLayout
  title="Newsletter"
  pane="newsletter"
  description="Bi-weekly dispatches from the studio — Soul of the Machine, Operator's Brief, Hive Doctrine. Three threads, one tight signal-to-noise."
>
  <SectionHero
    cover={landingHero('newsletter')}
    eyebrow="Channel · three threads"
    title="Soul of the Machine"
    titleHtml="Soul of the <em>Machine</em>"
  />

  <section class="section-body">
    <div class="flat-list-header">
      <div>
        <h2 class="h2"><em>Bi-weekly</em> dispatches from the studio.</h2>
        <p class="body-lead">What broke, what worked, what's coming. Soul of the Machine, Operator's Brief, Hive Doctrine — three threads, one tight signal-to-noise.</p>
      </div>
      <FilterDropdown id="newsletter-filter" options={filters} />
    </div>

    <div class="flat-list-grid" id="newsletter-list">
      {issues.map((n, i) => {
        const cover = n.data.cover || newsletterCover(n.slug, i);
        // Newsletter `tag` source order: byline (if present), then eyebrow (mockup
        // format "Soul of the Machine · 2026-04-28" — second part is the date,
        // first part is the channel). Falls back to empty string.
        let tag = tagFor(n.data.byline);
        if (!tag && n.data.eyebrow) {
          tag = n.data.eyebrow.split('·')[0].trim();
        }
        const date = formatDate(n.data.publishedAt);
        const tagLine = [tag, date].filter(Boolean).join(' · ');
        const isComingSoon = n.data.status === 'coming-soon';
        const Tag = isComingSoon ? 'div' : 'a';
        const cardProps = isComingSoon
          ? { class: 'flat-card flat-card-coming-soon', 'data-category': tag }
          : { class: 'flat-card', href: `/newsletter/${n.slug}/`, 'data-category': tag };
        return (
          <Tag {...cardProps}>
            <div class="flat-card-img" style={`background-image: url('${cover}');`}></div>
            <div class="flat-card-veil"></div>
            {isComingSoon && <div class="flat-card-badge">Coming soon</div>}
            <div class="flat-card-meta">
              {tagLine && <div class="flat-card-tag">{tagLine}</div>}
              <div class="flat-card-title">{n.data.title}</div>
              {n.data.lede && <div class="flat-card-line">{n.data.lede}</div>}
            </div>
          </Tag>
        );
      })}
    </div>

  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <script>
    function wireFilter() {
      const sel = document.getElementById('newsletter-filter');
      const list = document.getElementById('newsletter-list');
      if (!sel || !list) return;
      sel.addEventListener('filter:change', (e) => {
        const val = (e as CustomEvent).detail as string;
        list.querySelectorAll<HTMLElement>('.flat-card').forEach((card) => {
          if (val === 'All' || (card.dataset.category || '').includes(val)) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    }
    document.addEventListener('astro:page-load', wireFilter);
    wireFilter();
  </script>
</AppLayout>
