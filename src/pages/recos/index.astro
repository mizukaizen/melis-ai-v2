---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const recos = (await getCollection('recos')).filter((r) => !r.data.draft);

// Slug → paper-craft asset. Files live in public/section-rooms/recos-*.png.
const COVER_MAP: Record<string, string> = {
  'tools-i-use-daily':   '/section-rooms/recos-tools.png',
  'books-that-compound': '/section-rooms/recos-books.png',
  'newsletters-i-read':  '/section-rooms/recos-newsletters.png',
};
function coverFor(slug: string) {
  return COVER_MAP[slug] || '/section-rooms/recos-landing.png';
}
---

<AppLayout
  title="Recos"
  pane="recos"
  description="The actual stack — AI tools, infrastructure and SaaS Sean uses daily."
>
  <SectionHero
    cover={landingHero('recos')}
    eyebrow="Resources · honest only"
    title="Sean's Recos"
    titleHtml="Sean's <em>Recos</em>"
    lede="What I actually use. Tools, books, newsletters, hardware. No affiliate bait."
  />

  <section class="section-body">
    <div class="landing-intro">
      <h2 class="h2">What I actually <em>use</em>.</h2>
      <p class="body-lead">No affiliate padding. No "this changed my life!!" copy. These are the tools, books, courses, and apps I genuinely use and would buy again. If a link earns me anything, I'll say so on the line. Otherwise it doesn't.</p>
    </div>
    <div class="room-grid">
      {recos.map((r) => (
        <a class="room-card" href={`/recos/${r.slug}/`}>
          <div class="room-card-img" style={`background-image: url('${coverFor(r.slug)}');`}></div>
          <div class="room-card-veil"></div>
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">{r.data.eyebrow}</div>
            <div class="room-card-title">{r.data.title}</div>
            <div class="room-card-line">{r.data.lede}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .landing-intro { max-width: 720px; margin: 0 auto 2em; }
    .landing-intro .h2 { font-family: var(--font-display); font-size: clamp(28px, 3vw, 42px); font-weight: 500; line-height: 1.15; color: var(--text-1); margin: 0 0 14px; }
    .landing-intro .h2 :global(em) { font-style: italic; color: var(--accent); }
    .landing-intro .body-lead { font-family: var(--font-body); font-size: 16px; color: var(--text-2); line-height: 1.7; margin: 0 0 24px; max-width: 60ch; }
  </style>
</AppLayout>
