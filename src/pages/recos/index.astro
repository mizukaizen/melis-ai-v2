---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const recos = (await getCollection('recos')).filter((r) => !r.data.draft);

// 3-tier cover resolution for the /recos/ landing card grid:
//   1. MDX `cover:` frontmatter (explicit override)
//   2. Slug-derived convention path — only for slugs we know ship art
//   3. Shared landing scene fallback (movies, music-sets, tv-shows
//      land here until per-category paper-craft scenes are commissioned)
//
// Mirrors the convention in src/pages/lab/exhibits/index.astro, with
// the addition of a known-assets guard so categories without bespoke
// art don't 404 their card-img background.
const KNOWN_RECO_COVERS = new Set([
  'software', 'books', 'newsletters', 'courses',
  'apps', 'hardware', 'podcasts',
]);
function coverFor(entry: { slug: string; data: { cover?: string } }): string {
  if (entry.data.cover) return entry.data.cover;
  if (KNOWN_RECO_COVERS.has(entry.slug)) return `/section-rooms/recos-${entry.slug}.png`;
  return '/section-rooms/recos-landing.png';
}
---

<AppLayout
  title="Recos"
  pane="recos"
  description="The actual stack — AI tools, infrastructure and SaaS Sean uses daily."
>
  <SectionHero
    cover={landingHero('recos')}
    eyebrow="Resources · honest only"
    title="Sean's Recos"
    titleHtml="Sean's <em>Recos</em>"
  />

  <section class="section-body">
    <div class="landing-intro">
      <div class="section-eyebrow-small">53 picks · {recos.length} categories · only what I actually use</div>
      <h2 class="h2">What I actually <em>use</em>.</h2>
      <p class="body-lead">No affiliate padding. No "this changed my life!!" copy. These are the tools, books, courses, and apps I genuinely use and would buy again. If a link earns me anything, I'll say so on the line. Otherwise it doesn't.</p>
    </div>
    <div class="room-grid">
      {recos.map((r) => (
        <a class="room-card" href={`/recos/${r.slug}/`}>
          <div class="room-card-img" style={`background-image: url('${coverFor(r)}');`}></div>
          <div class="room-card-veil"></div>
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">{r.data.eyebrow}</div>
            <div class="room-card-title">{r.data.title}</div>
            <div class="room-card-line">{r.data.lede}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

</AppLayout>
