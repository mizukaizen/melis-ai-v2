---
import AppLayout from '../../layouts/AppLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('recos');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

function withUtm(rawUrl: string, slug: string): string {
  try {
    const u = new URL(rawUrl);
    u.searchParams.set('utm_source', 'melis-ai');
    u.searchParams.set('utm_medium', 'recos');
    u.searchParams.set('utm_campaign', slug);
    return u.toString();
  } catch {
    return rawUrl;
  }
}

type Props = { item: CollectionEntry<'recos'> };
const { item } = Astro.props as Props;
const data = item.data;
const cover = data.cover || '/card-products-v1.png';
const tools = data.tools || [];
---

<AppLayout title={data.title} pane="recos" inRoom description={data.lede}>
  <section class="section-header">
    <div class="section-hero-bg" style={`background-image: url('${cover}');`}></div>
    <div class="section-hero-veil"></div>
    <div class="section-header-inner">
      <a class="back-link" href="/recos/" data-pane="recos">← back to Recos</a>
      <div class="section-title-block">
        <div class="section-eyebrow">{data.eyebrow}</div>
        <h1 class="section-title" set:html={data.titleHtml || data.title}></h1>
        {data.lede && <p class="section-lead">{data.lede}</p>}
      </div>
    </div>
  </section>

  <section class="section-body">
    <ul class="tools-list">
      {tools.map((t) => (
        <li class="tool-row">
          <div class="tr-main">
            <div class="tr-name">{t.name}</div>
            {t.attr && <div class="tr-attr">{t.attr}</div>}
            {t.take && <div class="tr-take">{t.take}</div>}
          </div>
          {t.url ? (
            <a class="tr-cta" href={withUtm(t.url, item.slug)} target="_blank" rel="noopener nofollow sponsored">
              {t.cta || 'Visit'} ↗
            </a>
          ) : t.cta ? (
            <div class="tr-cta tr-cta-muted">{t.cta}</div>
          ) : null}
        </li>
      ))}
    </ul>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .tools-list {
      list-style: none;
      padding: 0;
      margin: 0 auto;
      max-width: 1000px;
    }
    .tool-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 24px;
      align-items: center;
      padding: 22px 0;
      border-bottom: 1px solid var(--border-1);
    }
    .tr-name {
      font-family: var(--font-display);
      font-size: 22px;
      color: var(--text-1);
      margin: 0 0 4px;
    }
    .tr-attr {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--text-3);
      letter-spacing: 0.06em;
      margin-bottom: 10px;
    }
    .tr-take {
      font-family: var(--font-body);
      font-size: 15px;
      color: var(--text-2);
      line-height: 1.55;
    }
    .tr-cta {
      padding: 8px 16px;
      background: rgba(168, 85, 247, 0.10);
      color: var(--accent);
      border-radius: 6px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      text-decoration: none;
    }
    .tr-cta-muted {
      background: transparent;
      color: var(--text-3);
    }
  </style>
</AppLayout>
