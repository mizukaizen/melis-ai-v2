---
// /about/melis-ai — studio intro + the full brand book.
// Composition: Ventures-pattern hero + 22 brand book sections + Legals tail.
// Section components live under src/components/about/brand/.

import AppLayout from '../../layouts/AppLayout.astro';
import Manifesto from '../../components/about/brand/Manifesto.astro';
import Promise   from '../../components/about/brand/Promise.astro';
import Values    from '../../components/about/brand/Values.astro';
import Goal      from '../../components/about/brand/Goal.astro';
import Stance    from '../../components/about/brand/Stance.astro';
import Lexicon   from '../../components/about/brand/Lexicon.astro';
import Compass      from '../../components/about/brand/Compass.astro';
import Wordmark     from '../../components/about/brand/Wordmark.astro';
import Colour       from '../../components/about/brand/Colour.astro';
import Typography   from '../../components/about/brand/Typography.astro';
import Voice        from '../../components/about/brand/Voice.astro';
import Imagery      from '../../components/about/brand/Imagery.astro';
import Influences   from '../../components/about/brand/Influences.astro';
import Placeholders from '../../components/about/brand/Placeholders.astro';
import Channels         from '../../components/about/brand/Channels.astro';
import SubBrands        from '../../components/about/brand/SubBrands.astro';
import ComponentLibrary from '../../components/about/brand/ComponentLibrary.astro';
import DoDont           from '../../components/about/brand/DoDont.astro';
import Closing          from '../../components/about/brand/Closing.astro';
import Sources          from '../../components/about/brand/Sources.astro';
import Legals           from '../../components/about/brand/Legals.astro';
import LayerDivider     from '../../components/about/brand/LayerDivider.astro';

// All 22 brand book sections + § Sources are now backed by dedicated
// components — no PENDING placeholders remaining.
---

<AppLayout
  title="About · melis.ai"
  pane="about-studio"
  description="The studio behind it all — what melis.ai is, the brand system, the manifesto, the visual language, voice, lexicon, sigils. Published, not hidden."
>
  <section class="melis-main">
    <header class="melis-hero melis-hero-cover">
      <div class="melis-hero-bg">
        <img src="/brand/cover-image.png" alt="A tilt-shift papercraft scene of a small home studio at twilight: a small paper figure stands at the centre of a wide room filled with completed and in-progress works — paper books, paper screens, paper prototypes, scattered paper drafts — lit by warm amber lamps and a cool teal twilight from a tall paper window. A small violet paper lotus glows on the central desk." />
      </div>
      <div class="melis-hero-veil"></div>
      <div class="melis-hero-inner">
        <div class="melis-hero-eyebrow">
          <span class="melis-hero-live"></span>
          Brand system <span class="sep">·</span> living document <span class="sep">·</span> v2026.04.29
        </div>
        <h1 class="melis-hero-title">melis<em>.</em>ai</h1>
        <div class="melis-hero-rule"></div>
        <p class="melis-hero-lead"><em>The studio behind the work — its why, its look, its voice.</em></p>
        <p class="melis-hero-intro">An AI studio run by Sean Melis from London. Courses, products, dispatches. What follows is everything that holds it together.</p>
        <div class="melis-hero-meta">
          <span><strong>22</strong>numbered sections</span>
          <span><strong>33</strong>lexicon concepts</span>
          <span><strong>15</strong>compass frames</span>
          <span><strong>6</strong>sub-brands</span>
          <span><strong>81</strong>hand-coded components</span>
        </div>
      </div>
    </header>

    <Manifesto />
    <Promise />
    <Values />
    <Goal />
    <Stance />
    <Lexicon />
    <Compass />

    <LayerDivider slug="identity" />
    <Wordmark />
    <Colour />
    <Typography />
    <Placeholders slug="spacing" />
    <Voice />
    <Imagery />
    <Placeholders slug="motion" />
    <Placeholders slug="dataviz" />
    <Placeholders slug="accessibility" />
    <Influences />

    <LayerDivider slug="channels" />
    <Channels />

    <LayerDivider slug="toolkit" />
    <SubBrands />
    <ComponentLibrary />

    <LayerDivider slug="conclusion" />
    <DoDont />
    <Closing />
    <Sources />
    <Legals />
  </section>
</AppLayout>

<style is:global>
  /* ════════════════════════════════════════════════════════════
   * /about/melis-ai chrome — scoped under .melis-main.
   * Reproduces the brand book treatment from the gold-standard mockup.
   * ════════════════════════════════════════════════════════════ */
  .melis-main {
    padding: 28px 60px 120px;
    max-width: none;
  }

  /* Hero — full-bleed cover image (papercraft scene) behind a dark
     gradient veil, with the wordmark + lead + intro + meta-chip row
     stacked on top. Mirrors the cover section from brand-guidelines.html
     lines 4377-4408. */
  .melis-hero-cover {
    position: relative;
    margin: -28px -60px 96px;  /* break the .melis-main padding to go full-bleed */
    min-height: 560px;
    overflow: hidden;
    display: flex; align-items: flex-end;
    isolation: isolate;
  }
  .melis-hero-bg {
    position: absolute; inset: 0;
    z-index: 0;
  }
  .melis-hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
    /* Canonical hero fade — same --hero-fade token used on every other
       section-hero across the site (prompts, dossiers, articles, etc).
       Image opaque for the top 25%, fades to fully transparent by 95%
       so the papercraft scene dissolves into the felt var(--bg). */
    -webkit-mask-image: var(--hero-fade);
            mask-image: var(--hero-fade);
  }
  .melis-hero-veil {
    position: absolute; inset: 0;
    /* Top-weighted veil mirrors the canonical .section-hero-veil pattern.
       Keeps the eyebrow + wordmark legible against the upper image without
       fighting the mask fade — the bottom stays clean so the image-to-felt
       transition reads. A second bottom-soft darken (below) gives the
       wordmark just enough contrast over the lower transparent zone. */
    background:
      linear-gradient(180deg,
        rgba(5, 5, 5, 0.40) 0%,
        rgba(5, 5, 5, 0.12) 22%,
        transparent 50%,
        transparent 100%),
      linear-gradient(0deg,
        rgba(15, 15, 15, 0.42) 0%,
        rgba(15, 15, 15, 0.18) 18%,
        transparent 40%,
        transparent 100%);
    z-index: 1;
  }
  .melis-hero-inner {
    position: relative;
    z-index: 2;
    padding: 56px 60px 56px;
    max-width: 880px;
    width: 100%;
  }
  .melis-hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-2);
    margin-bottom: 28px;
    display: inline-flex; align-items: center; gap: 10px;
  }
  .melis-hero-eyebrow .sep { color: var(--text-3); opacity: 0.6; margin: 0 6px; }
  .melis-hero-live {
    display: inline-block;
    width: 8px; height: 8px;
    background: #5eead4;
    border-radius: 50%;
    box-shadow: 0 0 10px #5eead4;
  }
  .melis-hero-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 96px;
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 0 0 24px;
    color: var(--text-1, var(--text));
  }
  .melis-hero-title em { font-style: normal; color: var(--accent); font-weight: 400; }
  .melis-hero-rule {
    width: 64px; height: 1px;
    background: var(--accent);
    margin: 0 0 28px;
  }
  .melis-hero-lead {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.4;
    color: var(--accent);
    margin: 0 0 22px;
    max-width: 640px;
  }
  .melis-hero-lead em { font-style: italic; color: var(--accent); }
  .melis-hero-intro {
    margin: 0 0 36px;
    max-width: 640px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-2);
  }
  .melis-hero-meta {
    display: flex; flex-wrap: wrap;
    gap: 8px 28px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
    border-top: 1px solid rgba(232,227,216,0.12);
    padding-top: 18px;
  }
  .melis-hero-meta span {
    display: inline-flex; align-items: baseline; gap: 8px;
  }
  .melis-hero-meta strong {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    letter-spacing: -0.02em;
    color: var(--accent);
    text-transform: none;
  }
  @media (max-width: 1100px) {
    .melis-hero-cover { margin-left: 0; margin-right: 0; min-height: 480px; }
    .melis-hero-inner { padding: 40px 24px; }
    .melis-hero-title { font-size: 64px; }
  }

  /* Section frame */
  .melis-section {
    scroll-margin-top: 80px;
    margin-bottom: 96px;
    max-width: 880px;
  }
  .melis-section-eyebrow-row {
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 24px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .melis-section-eyebrow-row .num { color: var(--accent); }
  .melis-section-eyebrow-row .line {
    flex: 1;
    height: 1px;
    background: var(--border-2, rgba(232,227,216,0.08));
  }
  .melis-section-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 40px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    color: var(--text-1, var(--text));
  }
  .melis-section-title em {
    font-style: italic;
    color: var(--accent);
    font-weight: 400;
  }

  /* Prose blocks within a section */
  .melis-prose {
    max-width: 720px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-2);
  }
  .melis-prose > p { margin: 0 0 20px; }
  .melis-prose > p:last-child { margin-bottom: 0; }
  .melis-prose em {
    font-style: italic;
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
  }
  .melis-ul { padding-left: 22px; }
  .melis-ul li {
    margin-bottom: 10px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-2);
  }
  .melis-ul li strong { color: var(--text-1, var(--text)); font-weight: 500; }
  .melis-aside {
    margin: 28px 0 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-3);
    font-style: italic;
  }

  /* Quote callout */
  .melis-quote {
    margin: 56px 0 0;
    padding: 28px 32px;
    border-left: 2px solid var(--accent);
    background: rgba(124, 58, 237, 0.04);
    max-width: 720px;
  }
  .melis-quote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.45;
    color: var(--text-1, var(--text));
    margin: 0 0 12px;
  }
  .melis-quote cite {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
    font-style: normal;
    display: block;
  }

  /* Promise (Section 01) — principle grid */
  .promise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 56px;
  }
  .promise-card {
    padding: 28px 28px 32px;
    border: 1px solid var(--border-2, rgba(232,227,216,0.08));
    background: rgba(255,255,255,0.015);
    display: flex; flex-direction: column;
  }
  .promise-mark {
    color: var(--accent);
    width: 36px; height: 36px;
    margin-bottom: 22px;
    display: inline-flex;
  }
  .promise-mark svg { width: 100%; height: 100%; }
  .promise-meta {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 8px;
  }
  .promise-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 26px;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0 0 10px;
    color: var(--text-1, var(--text));
  }
  .promise-greek {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .promise-translit {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 10px;
    color: var(--text-3);
    margin-left: 6px;
    letter-spacing: 0.06em;
  }
  .promise-body {
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--text-2);
    margin: 0;
  }
  .promise-body em {
    font-style: italic;
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 15px;
  }

  /* Values (Section 02) — chart cards */
  .values-northstar {
    margin: 40px 0 32px;
    padding: 24px 28px;
    border: 1px dashed var(--border-2, rgba(232,227,216,0.14));
    border-radius: 4px;
    max-width: 720px;
  }
  .values-northstar-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .values-northstar-q {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.35;
    color: var(--text-1, var(--text));
    margin: 0;
  }
  .values-northstar-q em {
    font-style: italic;
    color: var(--accent);
  }
  .value-card {
    margin-top: 32px;
    padding: 32px 32px 12px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border-2, rgba(232,227,216,0.08));
  }
  .value-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .value-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0 0 14px;
    color: var(--text-1, var(--text));
  }
  .value-lede {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-2);
    margin: 0 0 24px;
  }
  .value-lede em {
    font-style: italic;
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 17px;
  }
  .value-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 24px;
    padding: 16px 0;
    border-top: 1px solid var(--border-2, rgba(232,227,216,0.06));
  }
  .value-row-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .value-row-body {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-2);
  }

  /* Stance (Section 04) — 8-cell grid */
  .stance-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--border-2, rgba(232,227,216,0.08));
    border-left: 1px solid var(--border-2, rgba(232,227,216,0.08));
    margin-top: 32px;
  }
  .stance-cell {
    padding: 32px 30px;
    border-right: 1px solid var(--border-2, rgba(232,227,216,0.08));
    border-bottom: 1px solid var(--border-2, rgba(232,227,216,0.08));
    display: flex; flex-direction: column; gap: 18px;
    min-height: 200px;
  }
  .stance-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #f0a0a0;
    margin-bottom: 6px;
  }
  .stance-statement {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 26px;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--text-1, var(--text));
  }
  .stance-statement em {
    font-style: italic;
    color: var(--accent);
    font-weight: 500;
  }
  .stance-body {
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--text-2);
    margin: auto 0 0;
  }

  /* Placeholder section block */
  .melis-section-placeholder-body {
    padding: 18px 22px;
    border: 1px dashed var(--border-2, rgba(232,227,216,0.14));
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-3);
    line-height: 1.7;
    margin: 0;
  }
  .melis-section-placeholder-body em {
    color: var(--accent);
    font-style: italic;
  }

  /* Responsive: collapse multi-column grids on narrower viewports */
  @media (max-width: 1100px) {
    .stance-grid { grid-template-columns: 1fr; }
    .promise-grid { grid-template-columns: 1fr; }
    .value-row { grid-template-columns: 1fr; gap: 6px; }
  }
</style>
