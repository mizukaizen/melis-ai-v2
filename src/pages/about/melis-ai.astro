---
// /about/melis-ai — the consolidated studio + brand system page.
// Foundation: scaffold only. "The studio" intro + 22 placeholder
// section anchors so the Sidebar2MelisAI scroll-spy has targets
// immediately. Brand book content lands in subsequent PRs.

import AppLayout from '../../layouts/AppLayout.astro';

// Section roster — kept in sync with Sidebar2MelisAI's TOC. Each
// section renders as a placeholder pane in this foundation PR.
type Section = { id: string; num: string; group: string; name: string };
const SECTIONS: Section[] = [
  { id: 'manifesto',     num: '00', group: 'Why we exist',          name: 'Manifesto' },
  { id: 'promise',       num: '01', group: 'Why we exist',          name: 'Promise' },
  { id: 'values',        num: '02', group: 'Why we exist',          name: 'Values' },
  { id: 'goal',          num: '03', group: 'Why we exist',          name: 'Goal' },
  { id: 'stance',        num: '04', group: 'Why we exist',          name: "Stance · what we're not" },
  { id: 'lexicon',       num: 'L',  group: 'Why we exist',          name: 'The Lexicon' },
  { id: 'compass',       num: 'C',  group: 'Why we exist',          name: 'The Compass' },
  { id: 'wordmark',      num: '05', group: 'How we appear',          name: 'Wordmark' },
  { id: 'colour',        num: '06', group: 'How we appear',          name: 'Colour' },
  { id: 'typography',    num: '07', group: 'How we appear',          name: 'Typography' },
  { id: 'spacing',       num: '08', group: 'How we appear',          name: 'Spacing & layout' },
  { id: 'voice',         num: '09', group: 'How we appear',          name: 'Voice' },
  { id: 'imagery',       num: '10', group: 'How we appear',          name: 'Imagery' },
  { id: 'motion',        num: '11', group: 'How we appear',          name: 'Motion' },
  { id: 'dataviz',       num: '12', group: 'How we appear',          name: 'Data viz' },
  { id: 'accessibility', num: '13', group: 'How we appear',          name: 'Accessibility' },
  { id: 'influences',    num: '14', group: 'How we appear',          name: 'Influences' },
  { id: 'website',       num: '15', group: 'Where the brand lives',  name: 'The website' },
  { id: 'soul',          num: '16', group: 'Where the brand lives',  name: 'Soul of the Machine' },
  { id: 'youtube',       num: '17', group: 'Where the brand lives',  name: 'YouTube' },
  { id: 'subbrands',     num: '18', group: 'Toolkit',                 name: 'Sub-brands' },
  { id: 'library',       num: '19', group: 'Toolkit',                 name: 'Component library' },
  { id: 'dodont',        num: '20', group: 'Conclusion',              name: "Do · Don't" },
  { id: 'closing',       num: '21', group: 'Conclusion',              name: 'Closing' },
  { id: 'sources',       num: '§',  group: 'Conclusion',              name: 'Sources' },
];
---

<AppLayout
  title="About · melis.ai"
  pane="about-studio"
  description="The studio behind it all — what melis.ai is, the brand system, the manifesto, the visual language, voice, lexicon, sigils. Published, not hidden."
>
  <section class="melis-main">
    <div class="melis-topbar">
      <div class="melis-topbar-left">
        <span class="melis-signal-dot"></span>
        <span>melis.ai · brand system · v2026.04.29</span>
      </div>
      <div class="melis-topbar-right">LIVING DOCUMENT</div>
    </div>

    <header class="melis-hero">
      <div class="melis-hero-eyebrow">About <span class="sep">·</span> melis.ai</div>
      <h1 class="melis-hero-title">melis<em>.</em>ai</h1>
      <p class="melis-hero-lead"><em>The studio behind the work — its why, its look, its voice.</em></p>
      <p class="melis-hero-intro">An AI studio run by Sean Melis from London. Courses, products, dispatches. What follows is everything that holds it together.</p>
    </header>

    {SECTIONS.map((s) => (
      <section id={s.id} data-brand-section class="melis-section melis-section-placeholder">
        <div class="melis-section-eyebrow-row">
          <span class="num">{s.num}</span>
          <span class="name">{s.group} · {s.name}</span>
          <span class="line"></span>
        </div>
        <h2 class="melis-section-title">{s.name}</h2>
        <p class="melis-section-placeholder-body">
          <em>Section content lands in a subsequent PR.</em> This anchor exists so the
          sb2 scroll-spy has a target. See the standalone brand book at
          <a href="/Users/seanmelis/Documents/02-AREAS/01-melis-ai/brand/brand-guidelines.html">brand-guidelines.html</a>
          for the current source.
        </p>
      </section>
    ))}
  </section>
</AppLayout>

<style is:global>
  /* Scoped under .melis-main — won't leak. Mirrors the gold-standard
     brand book mockup chrome. */
  .melis-main {
    padding: 28px 60px 120px;
    max-width: none;
  }
  .melis-topbar {
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: lowercase;
    color: var(--text-3);
    padding-bottom: 32px;
    margin-bottom: 56px;
    border-bottom: 1px solid var(--border-2, rgba(232,227,216,0.08));
  }
  .melis-topbar-left { display: flex; align-items: center; gap: 10px; }
  .melis-signal-dot {
    width: 8px; height: 8px;
    background: #5eead4;
    border-radius: 50%;
    box-shadow: 0 0 12px #5eead4;
  }
  .melis-topbar-right {
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .melis-hero {
    margin-bottom: 96px;
    max-width: 880px;
  }
  .melis-hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 22px;
  }
  .melis-hero-eyebrow .sep { color: var(--text-3); opacity: 0.6; margin: 0 8px; }
  .melis-hero-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 72px;
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 0 0 20px;
    color: var(--text-1, var(--text));
  }
  .melis-hero-title em {
    font-style: normal;
    color: var(--accent);
    font-weight: 400;
  }
  .melis-hero-lead {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.4;
    color: var(--accent);
    margin: 0 0 24px;
    max-width: 640px;
  }
  .melis-hero-lead em {
    font-style: italic;
    color: var(--accent);
  }
  .melis-hero-intro {
    margin: 0;
    max-width: 640px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-2);
  }

  .melis-section {
    scroll-margin-top: 80px;
    margin-bottom: 96px;
    max-width: 880px;
  }
  .melis-section-eyebrow-row {
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 24px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .melis-section-eyebrow-row .num { color: var(--accent); }
  .melis-section-eyebrow-row .line {
    flex: 1;
    height: 1px;
    background: var(--border-2, rgba(232,227,216,0.08));
  }
  .melis-section-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 40px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
    color: var(--text-1, var(--text));
  }
  .melis-section-title em {
    font-style: italic;
    color: var(--accent);
    font-weight: 400;
  }
  .melis-section-placeholder-body {
    padding: 18px 22px;
    border: 1px dashed var(--border-2, rgba(232,227,216,0.14));
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-3);
    line-height: 1.7;
    margin: 0;
  }
  .melis-section-placeholder-body em {
    color: var(--accent);
    font-style: italic;
  }
  .melis-section-placeholder-body a {
    color: var(--accent);
    border-bottom: 1px solid currentColor;
  }
</style>
