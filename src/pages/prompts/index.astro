---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero, itemHero } from '../../lib/hero-image';

export const prerender = true;

const prompts = (await getCollection('prompts')).filter((p) => !p.data.draft);

// Filter pill categories — derived from the collection. Keeps mockup's filter
// behaviour while flattening the underlying grid (no per-category sections).
const categories = ['All', ...Array.from(new Set(prompts.map((p) => p.data.category)))];

function coverFor(p: { data: { category: string; cover?: string }; slug: string }) {
  if (p.data.cover && p.data.cover.startsWith('/')) return p.data.cover;
  return itemHero('prompts', p.data.category, p.slug);
}
---

<AppLayout
  title="Prompts"
  pane="prompts"
  description="A working operator's prompt library — flat searchable grid, tested in real work, ready to copy."
>
  <SectionHero
    cover={landingHero('prompts')}
    eyebrow={`Resources · the library · ${prompts.length} prompts`}
    title="The Prompt Library"
    titleHtml="The Prompt <em>Library</em>"
    lede="A working operator's library — tested, categorised, ready to copy. Variables in [purple brackets] are your fill-in points."
  />

  <section class="section-body">
    <div class="landing-intro">
      <h2 class="h2">Operator prompts — <em>tested in real work</em>.</h2>
      <p class="body-lead">Every prompt here started as something I needed for a real client problem, then got refined enough to reuse. Copy, fill the [brackets], ship.</p>
    </div>

    {categories.length > 1 && (
      <div class="pc-type-toggle" id="prompts-filter">
        {categories.map((c) => (
          <button class="ptt-btn" class:list={[{ active: c === 'All' }]} type="button" data-filter={c}>{c}</button>
        ))}
      </div>
    )}

    <div class="room-grid" id="prompts-grid">
      {prompts.map((p) => (
        <a class="room-card" href={`/prompts/${p.slug}/`} data-category={p.data.category}>
          <div class="room-card-img" style={`background-image: url('${coverFor(p)}');`}></div>
          <div class="room-card-veil"></div>
          <div class="room-card-group-pill is-muted">{p.data.category}</div>
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">Prompt</div>
            <div class="room-card-title">{p.data.title}</div>
            <div class="room-card-line">{p.data.lede}</div>
          </div>
        </a>
      ))}
    </div>
    {prompts.length === 0 && (
      <p style="text-align:center;color:var(--text-3);">No prompts yet. Check back soon.</p>
    )}
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <script>
    function wirePromptFilter() {
      const wrap = document.getElementById('prompts-filter');
      const grid = document.getElementById('prompts-grid');
      if (!wrap || !grid) return;
      if (wrap.dataset.wired === '1') return;
      wrap.dataset.wired = '1';
      wrap.querySelectorAll<HTMLButtonElement>('.ptt-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.dataset.filter || 'All';
          wrap.querySelectorAll('.ptt-btn').forEach((b) => b.classList.toggle('active', b === btn));
          grid.querySelectorAll<HTMLElement>('.room-card').forEach((card) => {
            card.style.display = (val === 'All' || card.dataset.category === val) ? '' : 'none';
          });
        });
      });
    }
    document.addEventListener('astro:page-load', wirePromptFilter);
    wirePromptFilter();
  </script>
</AppLayout>
