---
// /prompts/ landing — category browse (mirrors /dossiers/ landing).
// 22 paper-craft room-cards, one per category, each linking to
// /prompts/<category>/ where the actual 2-col prompt grid lives.
//
// The 335-card flat browse + payoff filter lives on per-category pages,
// not here. This page is for picking a category to dive into.
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';
import { PROMPT_CATEGORIES, PROMPT_CATEGORY_ORDER } from '../../data/prompt-categories';

export const prerender = true;

// Authoritative live count straight from the collection — keeps the body-lead
// honest if prompts ever get added/removed.
const totalPrompts = (await getCollection('prompts')).filter((p) => !p.data.draft).length;
const totalCategories = PROMPT_CATEGORY_ORDER.length;

const cats = PROMPT_CATEGORY_ORDER
  .map((slug) => ({ slug, ...PROMPT_CATEGORIES[slug] }))
  .filter((c) => c.title);
---

<AppLayout
  title="Prompt Library"
  pane="prompts"
  description={`${totalPrompts} tested operator prompts across ${totalCategories} categories. Pick a category to dive in.`}
>
  <SectionHero
    cover={landingHero('prompts')}
    eyebrow="Resources · the library"
    title="Prompt Library"
    titleHtml='Prompt <em>Library</em>'
  />

  <section class="section-body">
    <div class="prompts-landing">
      <div class="section-eyebrow-small">{totalPrompts} prompts · {totalCategories} categories · all tested in real work</div>
      <h2 class="h2">A working library of <em>operator prompts</em>.</h2>
      <p class="body-lead">Variables in <span class="pv-var">[BRACKETS]</span> are your fill-in points. Pick a category below, or jump straight into <a href="/prompts/seans-edge/" style="color: var(--accent); border-bottom: 1px solid currentColor;">Sean's Edge</a> for the AI-first cognitive amplification set.</p>
      <div class="room-grid">
        {cats.map((c) => (
          <a class="room-card" href={`/prompts/${c.slug}/`}>
            <div class="room-card-img" style={`background-image: url('/${c.image}');`}></div>
            <div class="room-card-veil"></div>
            <div class="room-card-arrow">↗</div>
            <div class="room-card-meta">
              <div class="room-card-eyebrow">{c.group} · {c.count} prompts</div>
              <div class="room-card-title">{c.title}</div>
              <div class="room-card-line">{c.line}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .prompts-landing .section-eyebrow-small { margin-bottom: 8px; }
    .prompts-landing .h2 { margin-bottom: 10px; }
    .prompts-landing .body-lead { margin-bottom: 20px; max-width: 60ch; }
  </style>
</AppLayout>
