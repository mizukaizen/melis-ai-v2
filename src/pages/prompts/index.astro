---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;

const prompts = (await getCollection('prompts')).filter((p) => !p.data.draft);
const byCategory = new Map<string, typeof prompts>();
for (const p of prompts) {
  const c = p.data.category;
  if (!byCategory.has(c)) byCategory.set(c, [] as never);
  byCategory.get(c)!.push(p);
}

// Featured = first Sean's Edge prompt (the flagship). Falls back to the
// first prompt overall if Sean's Edge isn't present.
const seansEdge = byCategory.get("Sean's Edge") || [];
const featured = seansEdge[0] || prompts[0];

// Per-category Phosphor icon palette (mirrors Sidebar2Prompts CAT_ICON).
const CAT_ICON: Record<string, { i: string; c: string }> = {
  "Sean's Edge":        { i: 'ph-lightning',     c: '#ff6b6b' },
  'Business':           { i: 'ph-handshake',     c: '#fb923c' },
  'Think & Communicate':{ i: 'ph-compass',       c: '#a78bfa' },
  'Life & Career':      { i: 'ph-map-trifold',   c: '#fb7185' },
  'Build':              { i: 'ph-cpu',           c: '#5eead4' },
};
function iconFor(cat: string) {
  return CAT_ICON[cat] || { i: 'ph-sparkle', c: '#a78bfa' };
}
---

<AppLayout
  title="Prompts"
  pane="prompts"
  description="A working operator's prompt library — categorised, tested, and ready to copy."
>
  <SectionHero
    cover={landingHero('prompts')}
    eyebrow={`Resources · the library · ${prompts.length} prompts`}
    title="The Prompt Library"
    titleHtml="The Prompt <em>Library</em>"
    lede="A working operator's library — tested, categorised, ready to copy. Variables in [purple brackets] are your fill-in points."
  />

  <section class="section-body">
    {featured && (
      <a class="featured-prompt-card" href={`/prompts/${featured.slug}/`}>
        <div class="fpc-eyebrow">
          <i class="ph ph-lightning" aria-hidden="true"></i>
          Sean's Edge · the flagship
        </div>
        <h3 class="fpc-title">{featured.data.title}</h3>
        <p class="fpc-lede">{featured.data.lede}</p>
        <div class="fpc-cta">Open the prompt →</div>
      </a>
    )}

    {Array.from(byCategory.entries()).map(([category, items]) => {
      const ic = iconFor(category);
      const visible = items.filter((p) => p.slug !== featured?.slug);
      if (visible.length === 0) return null;
      return (
        <section class="prompt-category">
          <div class="prompt-category-head">
            <i class={`ph ${ic.i}`} style={`color:${ic.c}`} aria-hidden="true"></i>
            <h2 class="h2">{category}</h2>
            <span class="prompt-category-count">{items.length}</span>
          </div>
          <div class="prompt-grid">
            {visible.map((p) => (
              <a class="prompt-card" href={`/prompts/${p.slug}/`}>
                <i class={`ph ${ic.i} pc-icon`} style={`color:${ic.c}`} aria-hidden="true"></i>
                <div class="pc-title">{p.data.title}</div>
                <div class="pc-line">{p.data.lede}</div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
    {prompts.length === 0 && (
      <p style="text-align:center;color:var(--text-3);">No prompts yet. Check back soon.</p>
    )}
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .featured-prompt-card {
      display: block;
      max-width: 1100px;
      margin: 0 auto 3em;
      padding: 32px 36px;
      background: linear-gradient(135deg, rgba(255, 107, 107, 0.12) 0%, rgba(168, 85, 247, 0.08) 100%);
      border: 1px solid rgba(255, 107, 107, 0.25);
      border-radius: 14px;
      text-decoration: none;
      color: inherit;
      transition: transform 0.2s var(--ease), border-color 0.2s var(--ease);
    }
    .featured-prompt-card:hover { transform: translateY(-2px); border-color: rgba(255, 107, 107, 0.5); }
    .fpc-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: #ff6b6b; margin-bottom: 12px; }
    .fpc-title { font-family: var(--font-display); font-size: clamp(28px, 3.4vw, 40px); font-weight: 500; line-height: 1.15; color: var(--text-1); margin: 0 0 12px; }
    .fpc-lede { font-family: var(--font-body); font-size: 16px; color: var(--text-2); line-height: 1.55; margin: 0 0 18px; max-width: 60ch; }
    .fpc-cta { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; color: var(--accent); padding: 8px 14px; background: rgba(168, 85, 247, 0.12); border: 1px solid rgba(168, 85, 247, 0.3); border-radius: 6px; }

    .prompt-category { margin-bottom: 3em; }
    .prompt-category-head { display: flex; align-items: center; gap: 10px; margin-bottom: 1em; }
    .prompt-category-head i { font-size: 18px; }
    .prompt-category-head .h2 { font-family: var(--font-display); font-size: 26px; font-weight: 500; color: var(--text-1); margin: 0; flex: 1; }
    .prompt-category-count { font-family: var(--font-mono); font-size: 11px; color: var(--text-3); letter-spacing: 0.1em; }
    .prompt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
    .prompt-card { display: flex; flex-direction: column; gap: 8px; padding: 18px 20px; background: rgba(20, 20, 24, 0.45); border: 1px solid var(--border-2); border-radius: 10px; text-decoration: none; color: inherit; transition: border-color 0.2s var(--ease), transform 0.2s var(--ease); }
    .prompt-card:hover { border-color: rgba(168, 85, 247, 0.3); transform: translateY(-2px); }
    .pc-icon { font-size: 18px; opacity: 0.85; }
    .pc-title { font-family: var(--font-display); font-size: 18px; font-weight: 500; color: var(--text-1); line-height: 1.2; }
    .pc-line { font-family: var(--font-body); font-size: 13px; color: var(--text-2); line-height: 1.45; }
  </style>
</AppLayout>
