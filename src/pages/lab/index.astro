---
import AppLayout from '../../layouts/AppLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { landingHero } from '../../lib/hero-image';

export const prerender = true;
---

<AppLayout title="The Lab" pane="exhibits" description="Live builds, exhibits, and experiments from melis.ai.">
  <SectionHero
    cover={landingHero('exhibits')}
    eyebrow="Work in progress"
    title="The Lab"
    titleHtml="The <em>Lab</em>"
  />

  <section class="section-body">
    <div class="landing-intro">
      <h2 class="h2">Things being made — in public, in flight, <em>sometimes parked</em>.</h2>
      <p class="body-lead">Sub-brands and ventures that started as side projects and grew into something worth shipping. Status is honest: live, in flight, or parked.</p>
    </div>
    <div class="lab-pillars room-grid">
      <a class="room-card" href="/ventures/lighthouse/">
        <div class="room-card-img" style="background-image: url('/section-rooms/ventures-lighthouse.png');"></div>
        <div class="room-card-veil"></div>
        <div class="room-card-arrow">↗</div>
        <div class="room-card-meta">
          <div class="room-card-eyebrow">SUB-BRAND</div>
          <div class="room-card-title">Lighthouse</div>
          <div class="room-card-line">AI intelligence briefings. You set a beacon, the system scans, analyses, delivers.</div>
        </div>
      </a>
      <a class="room-card" href="/ventures/holy-signal/">
        <div class="room-card-img" style="background-image: url('/section-rooms/ventures-holy-signal.png');"></div>
        <div class="room-card-veil"></div>
        <div class="room-card-arrow">↗</div>
        <div class="room-card-meta">
          <div class="room-card-eyebrow">SUB-BRAND</div>
          <div class="room-card-title">Holy Signal</div>
          <div class="room-card-line">SEO + AEO + agent-discoverability auditor. Three signals, one verdict.</div>
        </div>
      </a>
      <a class="room-card" href="/ventures/" data-lab-pillar="hive">
        <div class="room-card-img" style="background-image: url('/section-rooms/ventures-hive-doctrine.png');"></div>
        <div class="room-card-veil"></div>
        <div class="room-card-arrow">↗</div>
        <div class="room-card-meta">
          <div class="room-card-eyebrow">SUB-BRAND</div>
          <div class="room-card-title">Hive Doctrine</div>
          <div class="room-card-line">Marketplace and philosophy of multi-agent AI. Bee, Melissae, hexagon.</div>
        </div>
      </a>
    </div>

    <div class="lab-grid">
      <a class="lab-card" href="/ventures/">
        <div class="lc-eyebrow">42 in flight</div>
        <h3 class="lc-title">Ventures</h3>
        <p class="lc-lede">Live builds and sub-brands — what's being shipped this season.</p>
      </a>
      <a class="lab-card" href="/lab/exhibits/">
        <div class="lc-eyebrow">10 assembled</div>
        <h3 class="lc-title">Exhibits</h3>
        <p class="lc-lede">Paper-craft cinematography, immersive scroll stories, one-off pieces.</p>
      </a>
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

</AppLayout>
