---
import AppLayout from '../../../layouts/AppLayout.astro';
import SectionHero from '../../../components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { EXHIBITS_ORDER } from '../../../data/exhibits-order';
import { landingHero } from '../../../lib/hero-image';

export const prerender = true;

const all = (await getCollection('exhibits')).filter((e) => !e.data.draft);
const byTitle = new Map(all.map((e) => [e.data.title, e]));
const ordered = EXHIBITS_ORDER
  .map((title) => byTitle.get(title))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

// Map exhibit slug to its paper-craft scene in public/section-rooms/exhibits/.
function coverFor(slug: string): string {
  const base = slug.replace(/^the-/, '');
  const ext = base === 'hive' ? 'jpg' : 'png';
  return `/section-rooms/exhibits/${base}.${ext}`;
}
---

<AppLayout
  title="Exhibits"
  pane="exhibits"
  description="Paper-craft cinematography, immersive scroll stories, one-off pieces."
>
  <SectionHero
    cover={landingHero('exhibits')}
    eyebrow="The Lab · Exhibits"
    title="Exhibits"
    titleHtml="<em>Exhibits</em>"
    lede="Immersive scroll-experiences. Paper-craft worlds, one image at a time."
  />

  <section class="section-body">
    <div class="landing-intro">
      <h2 class="h2">Immersive paper-craft <em>exhibitions</em>.</h2>
      <p class="body-lead">Ten scroll-experiences. Each one a self-contained world — bees, hives, keepers, thresholds, arcs of a life. Best experienced full-screen with sound on.</p>
    </div>
    <div class="room-grid">
      {ordered.map((ex, i) => (
        <a class="room-card" href={`/lab/exhibits/${ex.slug}/`}>
          <div class="room-card-img" style={`background-image: url('${coverFor(ex.slug)}');`}></div>
          <div class="room-card-veil"></div>
          {ex.data.status === 'live' && (
            <div class="room-card-group-pill is-signal">LIVE</div>
          )}
          <div class="room-card-arrow">↗</div>
          <div class="room-card-meta">
            <div class="room-card-eyebrow">No. {String(i + 1).padStart(2, '0')} · Exhibit</div>
            <div class="room-card-title">{ex.data.title}</div>
            <div class="room-card-line">{ex.data.lede}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .landing-intro { max-width: 720px; margin: 0 auto 2em; }
    .landing-intro .h2 { font-family: var(--font-display); font-size: clamp(28px, 3vw, 42px); font-weight: 500; line-height: 1.15; color: var(--text-1); margin: 0 0 14px; }
    .landing-intro .h2 :global(em) { font-style: italic; color: var(--accent); }
    .landing-intro .body-lead { font-family: var(--font-body); font-size: 16px; color: var(--text-2); line-height: 1.7; margin: 0 0 24px; max-width: 60ch; }
  </style>
</AppLayout>
