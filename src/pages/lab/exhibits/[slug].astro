---
import AppLayout from '../../../layouts/AppLayout.astro';
import SectionHero from '../../../components/SectionHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { itemHero, landingHero } from '../../../lib/hero-image';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('exhibits');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'exhibits'> };
const { item } = Astro.props as Props;
const data = item.data;
const cover = (data.cover && data.cover.startsWith('/'))
  ? data.cover
  : itemHero('exhibits', data.title, item.slug) || landingHero('exhibits');

// Meta strip lifted from mockup EXHIBITS_DETAIL (line 12989).
const META = data.title === 'Lessons'
  ? { works: '33 lessons', format: 'Paper-craft, immersive scroll', year: '2026', status: 'Live' }
  : { works: '9 works',    format: 'Paper-craft, immersive scroll', year: '2026', status: 'Live' };
---

<AppLayout title={data.title} pane="exhibits" inRoom description={data.lede}>
  <SectionHero
    cover={cover}
    eyebrow={data.eyebrow}
    title={data.title}
    lede={data.lede}
  />

  <section class="section-body">
    <div class="exhibit-meta">
      <div class="em-cell"><div class="em-lbl">Works</div><div class="em-val">{META.works}</div></div>
      <div class="em-cell"><div class="em-lbl">Format</div><div class="em-val">{META.format}</div></div>
      <div class="em-cell"><div class="em-lbl">Year</div><div class="em-val">{META.year}</div></div>
      <div class="em-cell"><div class="em-lbl">Status</div><div class="em-val">{META.status}</div></div>
    </div>

    <section class="exhibit-inside">
      <div class="section-eyebrow-small">What's inside?</div>
      <h2 class="h2">A scroll-experience, paper-craft front to back.</h2>
      <p class="body-lead">{data.lede}</p>
    </section>

    {data.liveUrl && (
      <div class="exhibit-cta">
        <a class="ec-link" href={data.liveUrl} target="_blank" rel="noopener">View the exhibit ↗</a>
      </div>
    )}
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  <style>
    .exhibit-meta { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 16px; max-width: 920px; margin: 0 auto 3em; padding: 22px 26px; background: rgba(20, 20, 24, 0.45); border: 1px solid var(--border-2); border-radius: 12px; }
    .em-lbl { font-family: var(--font-mono); font-size: 10px; color: var(--text-3); letter-spacing: 0.06em; margin-bottom: 6px; }
    .em-val { font-family: var(--font-display); font-size: 18px; color: var(--text-1); }
    .exhibit-inside { max-width: 720px; margin: 0 auto 3em; }
    .exhibit-inside .h2 { font-family: var(--font-display); font-size: clamp(24px, 2.4vw, 32px); font-weight: 500; color: var(--text-1); margin: 0 0 12px; }
    .exhibit-inside p { font-family: var(--font-body); font-size: 16px; color: var(--text-2); line-height: 1.7; margin: 0; }
    .exhibit-cta { text-align: center; margin: 3em 0; }
    .ec-link { display: inline-block; padding: 14px 28px; background: var(--accent); color: white; border-radius: 8px; font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.04em; text-decoration: none; }
    .ec-link:hover { background: #9333ea; }
  </style>
</AppLayout>
