---
import AppLayout from '../../../layouts/AppLayout.astro';
import SectionHero from '../../../components/SectionHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { itemHero, landingHero } from '../../../lib/hero-image';
import {
  EXHIBIT_DETAILS,
  EXHIBIT_ARTIST,
  EXHIBIT_MEDIUM,
  EXHIBIT_CREDITS,
  EXHIBIT_BUY_URL,
} from '../../../data/exhibits-detail';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('exhibits');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'exhibits'> };
const { item } = Astro.props as Props;
const data = item.data;
const cover = (data.cover && data.cover.startsWith('/'))
  ? data.cover
  : itemHero('exhibits', data.title, item.slug) || landingHero('exhibits');

const detail = EXHIBIT_DETAILS[item.slug];

// Local vendored experience path: derive the series slug from the
// liveUrl host (https://keeper-series.vercel.app/ → keeper-series).
const seriesSlug = data.liveUrl
  ? (data.liveUrl.match(/https?:\/\/([a-z0-9-]+)\.vercel\.app/)?.[1] ?? null)
  : null;
const localExhibit = seriesSlug ? `/exhibits/${seriesSlug}/index.html` : null;
const exhibitHref = localExhibit ?? data.liveUrl;

const works = detail?.works ?? '9 works';
const year = detail?.year ?? '2026';
const statusLabel = data.status === 'live' ? 'Live' : data.status === 'archived' ? 'Archived' : 'Concept';
---

<AppLayout title={data.title} pane="exhibits" inRoom description={data.lede}>
  <SectionHero
    cover={cover}
    eyebrow={data.eyebrow}
    title={data.title}
  />

  <section class="section-body">
    <div class="exhibit-detail">
      <!-- Plaque -->
      <div class="exb-plaque">
        <div class="exb-plaque-eyebrow">The plaque</div>
        {detail?.plaque?.length
          ? detail.plaque.map((p) => <p class="exb-plaque-para">{p}</p>)
          : <p class="exb-plaque-para">{data.lede}</p>}
      </div>

      <!-- Meta credits panel -->
      <aside class="exb-credits">
        <div class="exb-credits-grid">
          <div class="exb-cred">
            <div class="exb-cred-lbl">Artist</div>
            <div class="exb-cred-val">{EXHIBIT_ARTIST}</div>
          </div>
          <div class="exb-cred">
            <div class="exb-cred-lbl">Works</div>
            <div class="exb-cred-val">{works}</div>
          </div>
          <div class="exb-cred">
            <div class="exb-cred-lbl">Year</div>
            <div class="exb-cred-val">{year}</div>
          </div>
          <div class="exb-cred">
            <div class="exb-cred-lbl">Status</div>
            <div class="exb-cred-val"><span class="exb-status-dot"></span>{statusLabel}</div>
          </div>
          <div class="exb-cred exb-cred-wide">
            <div class="exb-cred-lbl">Medium</div>
            <div class="exb-cred-val">{EXHIBIT_MEDIUM}</div>
          </div>
        </div>

        <div class="exb-prod">
          <div class="exb-prod-eyebrow">Production</div>
          <dl class="exb-prod-list">
            {EXHIBIT_CREDITS.map((c) => (
              <div class="exb-prod-row">
                <dt class="exb-prod-role">{c.role}</dt>
                <dd class="exb-prod-name">{c.name}</dd>
              </div>
            ))}
          </dl>
        </div>

        <div class="exb-actions">
          {exhibitHref && (
            <button
              class="exb-action exb-action-primary"
              type="button"
              data-exhibit-open
              data-exhibit-src={exhibitHref}
              data-exhibit-title={data.title}
            >View the exhibit ↗</button>
          )}
          <a
            class="exb-action exb-action-secondary"
            href={EXHIBIT_BUY_URL}
            target="_blank"
            rel="noopener noreferrer"
          >Buy the artwork ↗</a>
        </div>
      </aside>

      <!-- Movements / contents -->
      {detail?.movements?.length && (
        <div class="exb-movements">
          <div class="exb-movements-head">
            <span class="exb-movements-eyebrow">The movements</span>
            <span class="exb-movements-count">{detail.movements.length} scenes</span>
          </div>
          <ol class="exb-movements-list">
            {detail.movements.map((m, i) => (
              <li class="exb-movement">
                <span class="exb-movement-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="exb-movement-name">{m}</span>
              </li>
            ))}
          </ol>
        </div>
      )}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>

  {/* Full-screen exhibit viewer — chromeless. The exhibit fills the
      whole viewport; the embedded experience surfaces its own "ESC to
      exit" hint and posts a message back here to close. */}
  <div class="exhibit-viewer" id="exhibit-viewer" hidden role="dialog" aria-modal="true" aria-label="Exhibit viewer">
    <iframe class="exhibit-viewer-frame" id="exhibit-viewer-frame" title="Exhibit" src="about:blank"></iframe>
  </div>
</AppLayout>

<style is:global>
  /* ════════════════════════════════════════════════════════════
   * Exhibit detail — gallery-plaque layout. Plaque prose on the left,
   * a credits panel + view CTA on the right, movements list beneath.
   * ════════════════════════════════════════════════════════════ */
  .pane[data-pane="exhibits"] .exhibit-detail {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px 56px;
    align-items: start;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Plaque */
  .pane[data-pane="exhibits"] .exb-plaque {
    grid-column: 1;
  }
  .pane[data-pane="exhibits"] .exb-plaque-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(232, 227, 216, 0.10);
  }
  .pane[data-pane="exhibits"] .exb-plaque-para {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.6;
    color: var(--text-1, var(--text));
    margin: 0 0 22px;
  }
  .pane[data-pane="exhibits"] .exb-plaque-para:first-of-type {
    font-size: 23px;
    line-height: 1.55;
  }
  .pane[data-pane="exhibits"] .exb-plaque-para:last-child { margin-bottom: 0; }

  /* Credits panel */
  .pane[data-pane="exhibits"] .exb-credits {
    grid-column: 2;
    grid-row: 1 / span 2;
    position: sticky;
    top: 24px;
    padding: 28px 28px 24px;
    border: 1px solid rgba(168, 85, 247, 0.22);
    background: rgba(168, 85, 247, 0.04);
    border-radius: 10px;
  }
  .pane[data-pane="exhibits"] .exb-credits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px 20px;
    margin-bottom: 28px;
  }
  .pane[data-pane="exhibits"] .exb-cred-wide { grid-column: 1 / -1; }
  .pane[data-pane="exhibits"] .exb-cred-lbl {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 7px;
  }
  .pane[data-pane="exhibits"] .exb-cred-val {
    font-family: var(--font-display);
    font-size: 17px;
    line-height: 1.35;
    color: var(--text-1, var(--text));
    display: flex; align-items: center; gap: 8px;
  }
  .pane[data-pane="exhibits"] .exb-status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #5eead4; box-shadow: 0 0 8px #5eead4;
    flex-shrink: 0;
  }
  /* Production credits — role-attributed, plaque/film-credit style */
  .pane[data-pane="exhibits"] .exb-prod {
    margin: 24px 0 28px;
    padding-top: 22px;
    border-top: 1px solid rgba(232, 227, 216, 0.10);
  }
  .pane[data-pane="exhibits"] .exb-prod-eyebrow {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 14px;
  }
  .pane[data-pane="exhibits"] .exb-prod-list { margin: 0; }
  .pane[data-pane="exhibits"] .exb-prod-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px;
    padding: 9px 0;
    border-bottom: 1px solid rgba(232, 227, 216, 0.05);
  }
  .pane[data-pane="exhibits"] .exb-prod-row:last-child { border-bottom: none; }
  .pane[data-pane="exhibits"] .exb-prod-role {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
    flex-shrink: 0;
  }
  .pane[data-pane="exhibits"] .exb-prod-name {
    font-family: var(--font-display);
    font-size: 15px;
    line-height: 1.3;
    color: var(--text-1, var(--text));
    margin: 0;
    text-align: right;
  }

  /* Action buttons — single-line primary (view) + secondary (buy) */
  .pane[data-pane="exhibits"] .exb-actions {
    display: flex; flex-direction: column; gap: 10px;
  }
  .pane[data-pane="exhibits"] .exb-action {
    display: flex; align-items: center; justify-content: center;
    width: 100%;
    padding: 14px 18px;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: filter 160ms ease, transform 120ms ease, background 160ms ease, border-color 160ms ease, color 160ms ease;
  }
  .pane[data-pane="exhibits"] .exb-action-primary {
    background: var(--accent);
    border: 1px solid var(--accent);
    color: #fff;
  }
  .pane[data-pane="exhibits"] .exb-action-primary:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .pane[data-pane="exhibits"] .exb-action-secondary {
    background: transparent;
    border: 1px solid rgba(168, 85, 247, 0.32);
    color: var(--text-1, var(--text));
  }
  .pane[data-pane="exhibits"] .exb-action-secondary:hover {
    border-color: rgba(168, 85, 247, 0.6);
    background: rgba(168, 85, 247, 0.06);
    transform: translateY(-1px);
  }

  /* Movements */
  .pane[data-pane="exhibits"] .exb-movements {
    grid-column: 1;
    margin-top: 8px;
  }
  .pane[data-pane="exhibits"] .exb-movements-head {
    display: flex; align-items: baseline; justify-content: space-between;
    padding-bottom: 14px;
    margin-bottom: 6px;
    border-bottom: 1px solid rgba(232, 227, 216, 0.10);
  }
  .pane[data-pane="exhibits"] .exb-movements-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .pane[data-pane="exhibits"] .exb-movements-count {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .pane[data-pane="exhibits"] .exb-movements-list {
    list-style: none;
    margin: 0; padding: 0;
    columns: 2;
    column-gap: 40px;
  }
  .pane[data-pane="exhibits"] .exb-movement {
    display: flex; align-items: baseline; gap: 14px;
    padding: 11px 0;
    border-bottom: 1px solid rgba(232, 227, 216, 0.06);
    break-inside: avoid;
  }
  .pane[data-pane="exhibits"] .exb-movement-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.10em;
    color: var(--accent);
    min-width: 18px;
  }
  .pane[data-pane="exhibits"] .exb-movement-name {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--text-1, var(--text));
    line-height: 1.3;
  }

  @media (max-width: 1000px) {
    .pane[data-pane="exhibits"] .exhibit-detail { grid-template-columns: 1fr; }
    .pane[data-pane="exhibits"] .exb-credits { grid-column: 1; grid-row: auto; position: static; }
    .pane[data-pane="exhibits"] .exb-movements { grid-column: 1; }
    .pane[data-pane="exhibits"] .exb-movements-list { columns: 1; }
  }

  /* ── Full-screen exhibit viewer — chromeless ── */
  .exhibit-viewer {
    position: fixed; inset: 0; z-index: 9600;
    background: var(--bg, #0f0f0f);
  }
  .exhibit-viewer[hidden] { display: none; }
  .exhibit-viewer-frame { width: 100%; height: 100%; border: 0; display: block; background: var(--bg, #0f0f0f); }
</style>

<script>
  (function wireExhibitViewer() {
    function portal() {
      const v = document.getElementById('exhibit-viewer');
      if (v && v.parentElement !== document.body) document.body.appendChild(v);
    }
    function open(src: string) {
      portal();
      const v = document.getElementById('exhibit-viewer') as HTMLElement | null;
      const frame = document.getElementById('exhibit-viewer-frame') as HTMLIFrameElement | null;
      if (!v || !frame) return;
      frame.src = src;
      v.hidden = false;
      document.documentElement.style.overflow = 'hidden';
    }
    function close() {
      const v = document.getElementById('exhibit-viewer') as HTMLElement | null;
      const frame = document.getElementById('exhibit-viewer-frame') as HTMLIFrameElement | null;
      if (!v) return;
      v.hidden = true;
      if (frame) frame.src = 'about:blank';
      document.documentElement.style.overflow = '';
    }
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const opener = target.closest<HTMLElement>('[data-exhibit-open]');
      if (opener) {
        e.preventDefault();
        open(opener.getAttribute('data-exhibit-src') || '');
      }
    });
    // ESC handled two ways: when the parent has focus (this listener),
    // and when the iframe has focus (the embed shim posts a message).
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const v = document.getElementById('exhibit-viewer');
      if (v && !v.hidden) close();
    });
    window.addEventListener('message', (e) => {
      if (e.data && e.data.type === 'exhibit-exit') close();
    });
    document.addEventListener('DOMContentLoaded', portal);
    document.addEventListener('astro:page-load', portal);
    if (document.readyState !== 'loading') portal();
  })();
</script>
