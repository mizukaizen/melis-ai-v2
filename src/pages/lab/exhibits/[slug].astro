---
import AppLayout from '../../../layouts/AppLayout.astro';
import SectionHero from '../../../components/SectionHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { itemHero, landingHero } from '../../../lib/hero-image';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('exhibits');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'exhibits'> };
const { item } = Astro.props as Props;
const data = item.data;
const cover = (data.cover && data.cover.startsWith('/'))
  ? data.cover
  : itemHero('exhibits', data.title, item.slug) || landingHero('exhibits');

// Meta strip lifted from mockup EXHIBITS_DETAIL (line 12989).
const META = data.title === 'Lessons'
  ? { works: '33 lessons', format: 'Paper-craft, immersive scroll', year: '2026', status: 'Live' }
  : { works: '9 works',    format: 'Paper-craft, immersive scroll', year: '2026', status: 'Live' };
---

<AppLayout title={data.title} pane="exhibits" inRoom description={data.lede}>
  <SectionHero
    cover={cover}
    eyebrow={data.eyebrow}
    title={data.title}
  />

  <section class="section-body">
    <div class="v6-detail">
      <div class="vd-strip">
        <div class="vd-strip-item"><div class="lbl">Works</div><div class="val">{META.works}</div></div>
        <div class="vd-strip-item"><div class="lbl">Format</div><div class="val">{META.format}</div></div>
        <div class="vd-strip-item"><div class="lbl">Year</div><div class="val">{META.year}</div></div>
        <div class="vd-strip-item"><div class="lbl">Status</div><div class="val">{META.status}</div></div>
      </div>

      <section class="vd-section">
        <h3 class="vd-h3">A scroll-experience, paper-craft front to back.</h3>
        <div class="vd-prose"><p>{data.lede}</p></div>
      </section>

      {data.liveUrl && (
        <div class="vd-cta">
          <div class="vd-cta-title">View the exhibit</div>
          <a class="vd-cta-btn" href={data.liveUrl} target="_blank" rel="noopener">Open ↗</a>
        </div>
      )}
    </div>
  </section>

  <div class="footer">
    <div>melis.ai · 2026</div>
    <div>Operator-built · Australia</div>
  </div>
</AppLayout>
