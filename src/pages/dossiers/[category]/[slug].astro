---
import AppLayout from '../../../layouts/AppLayout.astro';
import SectionHero from '../../../components/SectionHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { dossierHero } from '../../../lib/hero-image';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('dossiers');
  return items.map((item) => ({
    params: { category: item.data.category, slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'dossiers'> };
const { item } = Astro.props as Props;
const { Content } = await item.render();
const data = item.data;
const cover = dossierHero(data.category);
---

<AppLayout title={data.title} pane="library" inRoom description={data.lede}>
  <SectionHero
    cover={cover}
    eyebrow={data.eyebrow}
    title={data.title}
    titleHtml={data.titleHtml}
    byline={data.byline}
  />

  <section class="section-body">
    <article class="dossier-content">
      <!-- Canonical mockup order: lede → quote → body → why → keyIdeas → takeForward → keyConcept -->

      <p class="dossier-lede">{data.lede}</p>

      {data.quote && (
        <blockquote class="dossier-quote">
          <p>{data.quote.text}</p>
          <cite>{data.quote.cite}</cite>
        </blockquote>
      )}

      <div class="dossier-body">
        <Content />
      </div>

      {data.whyItMatters && (
        <section class="dossier-section dossier-why">
          <h2 class="h2">Why it <em>matters</em></h2>
          <p>{data.whyItMatters}</p>
        </section>
      )}

      {data.keyIdeas && data.keyIdeas.length > 0 && (
        <section class="dossier-section dossier-keyideas">
          <h2 class="h2">Key <em>ideas</em></h2>
          <ul class="dossier-list">
            {data.keyIdeas.map((idea) => <li set:html={idea}></li>)}
          </ul>
        </section>
      )}

      {data.takeForward && (
        <section class="dossier-section dossier-takeforward">
          <h2 class="h2">Take it <em>forward</em></h2>
          <p>{data.takeForward}</p>
        </section>
      )}

      {data.keyConcept && (
        <section class="dossier-keyconcept">
          <h3>Key concept</h3>
          <div class="kc-name">{data.keyConcept.name}</div>
          <div class="kc-desc">{data.keyConcept.desc}</div>
        </section>
      )}
    </article>
  </section>

  <style>
    .dossier-content {
      max-width: 720px;
      margin: 0 auto;
    }
    /* Lede — large serif, restrained-italic feel via Cormorant 500 */
    .dossier-lede {
      font-family: var(--font-display);
      font-size: 24px;
      line-height: 1.45;
      color: var(--text-1);
      margin: 0 0 32px;
      max-width: 720px;
      font-weight: 400;
    }
    /* Pull quote — left rule, italic Cormorant */
    .dossier-quote {
      border-left: 2px solid var(--accent);
      padding: 0.6em 0 0.6em 1.4em;
      margin: 0 0 36px;
      max-width: 640px;
    }
    .dossier-quote p {
      font-family: var(--font-display);
      font-size: 24px;
      font-style: italic;
      line-height: 1.4;
      color: var(--text-1);
      margin: 0 0 8px;
    }
    .dossier-quote cite {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-3);
      letter-spacing: 0.06em;
      font-style: normal;
    }
    /* Body paragraphs — Inter 17px, max 680px wide */
    .dossier-body :global(p) {
      font-family: var(--font-body);
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-1);
      margin: 0 0 1.4em;
      max-width: 680px;
    }
    .dossier-body :global(em) { color: var(--accent); font-style: italic; }
    .dossier-body :global(strong) { color: var(--text-1); font-weight: 600; }

    .dossier-section { margin-top: 56px; }
    .dossier-section .h2 {
      font-family: var(--font-display);
      font-size: 32px;
      font-weight: 500;
      line-height: 1.2;
      color: var(--text-1);
      margin: 0 0 16px;
      max-width: 680px;
    }
    .dossier-section .h2 em { color: var(--accent); font-style: italic; }
    .dossier-section p {
      font-family: var(--font-body);
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-1);
      margin: 0;
      max-width: 680px;
    }

    /* Key ideas list */
    .dossier-list {
      list-style: none;
      padding: 0;
      margin: 0;
      max-width: 680px;
    }
    .dossier-list :global(li) {
      padding: 16px 0;
      border-bottom: 1px solid var(--border-1);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.65;
      color: var(--text-2);
    }
    .dossier-list :global(li:last-child) { border-bottom: none; }
    .dossier-list :global(li strong) {
      color: var(--text-1);
      display: block;
      margin-bottom: 4px;
      font-weight: 600;
    }

    /* Key concept callout — bordered card at the end */
    .dossier-keyconcept {
      margin-top: 64px;
      padding: 28px 32px;
      background: rgba(168, 85, 247, 0.04);
      border: 1px solid rgba(168, 85, 247, 0.18);
      border-radius: 14px;
      max-width: 720px;
    }
    .dossier-keyconcept h3 {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.20em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 14px;
      font-weight: 500;
    }
    .kc-name {
      font-family: var(--font-display);
      font-size: 26px;
      font-style: italic;
      color: var(--text-1);
      margin-bottom: 8px;
    }
    .kc-desc {
      font-family: var(--font-body);
      font-size: 15px;
      color: var(--text-2);
      line-height: 1.55;
    }
  </style>
</AppLayout>
