---
import AppLayout from '../../../layouts/AppLayout.astro';
import SectionHero from '../../../components/SectionHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { dossierHero } from '../../../lib/hero-image';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('dossiers');
  return items.map((item) => ({
    params: { category: item.data.category, slug: item.slug },
    props: { item },
  }));
}

type Props = { item: CollectionEntry<'dossiers'> };
const { item } = Astro.props as Props;
const { Content } = await item.render();
const data = item.data;
const cover = dossierHero(data.category);
---

<AppLayout title={data.title} pane="library" inRoom description={data.lede}>
  <SectionHero
    cover={cover}
    eyebrow={data.eyebrow}
    title={data.title}
    titleHtml={data.titleHtml}
    byline={data.byline}
  />

  <section class="section-body">
    <article class="dossier-content">
      <!-- Canonical mockup order: lede → quote → body → why → keyIdeas → takeForward → keyConcept -->

      <p class="dossier-lede">{data.lede}</p>

      {data.quote && (
        <blockquote class="dossier-quote">
          <span class="dossier-quote-text">{data.quote.text}</span>
          <span class="dossier-quote-cite">{data.quote.cite}</span>
        </blockquote>
      )}

      <div class="dossier-body">
        <Content />
      </div>

      {data.whyItMatters && (
        <section class="dossier-section dossier-why">
          <h2 class="h2">Why it <em>matters</em></h2>
          <p>{data.whyItMatters}</p>
        </section>
      )}

      {data.keyIdeas && data.keyIdeas.length > 0 && (
        <section class="dossier-section dossier-keyideas">
          <h2 class="h2">Key <em>ideas</em></h2>
          <ul class="dossier-list">
            {data.keyIdeas.map((idea) => <li set:html={idea}></li>)}
          </ul>
        </section>
      )}

      {data.takeForward && (
        <section class="dossier-section dossier-takeforward">
          <h2 class="h2">Take it <em>forward</em></h2>
          <p>{data.takeForward}</p>
        </section>
      )}

      {data.keyConcept && (
        <section class="dossier-keyconcept">
          <h3>Key concept</h3>
          <div class="kc-name">{data.keyConcept.name}</div>
          <div class="kc-desc">{data.keyConcept.desc}</div>
        </section>
      )}
    </article>
  </section>
</AppLayout>
