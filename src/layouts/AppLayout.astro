---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  pane?: string; // e.g. "home" | "articles" | "library" — drives sb1 active state
}

const {
  title,
  description = 'Sean Melis builds at the frontier of AI. Articles, prompts, products, courses, and a public library of ideas.',
  ogImage = '/og-default.png',
  pane = 'home',
} = Astro.props;

const fullTitle = title === 'melis.ai' ? title : `${title} · melis.ai`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <ClientRouter />
  </head>
  <body data-pane={pane}>
    <div class="app">
      <slot name="sidebar1">
        <!-- default sb1 injected by AppShell-using pages -->
      </slot>
      <slot name="sidebar2" />
      <main class="pane" data-pane={pane}>
        <slot />
      </main>
    </div>

    <style>
      .app {
        display: grid;
        grid-template-columns: var(--sidebar-w) var(--sidebar-w2) 1fr;
        min-height: 100vh;
      }

      /* When no sb2 slot is rendered, collapse the column */
      .app:has(> [data-sb2-empty]) {
        grid-template-columns: var(--sidebar-w) 1fr;
      }

      .pane {
        min-width: 0;
        padding: var(--pane-pad-y) var(--pane-pad-x);
      }

      @media (max-width: 1024px) {
        .app {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
