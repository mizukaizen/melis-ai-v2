---
// BeeHiiv subscribe form. Posts to /api/subscribe which forwards to the
// BeeHiiv API. Email-validated client-side via the `type="email"` input;
// server re-validates with Zod.
---

<form class="newsletter-form" id="newsletter-form" novalidate>
  <div class="newsletter-form-row">
    <input
      class="newsletter-input"
      type="email"
      name="email"
      placeholder="your@email.com"
      autocomplete="email"
      required
    />
    <button class="newsletter-submit" type="submit">Subscribe — free →</button>
  </div>
  <p class="newsletter-status" data-state="idle"></p>
</form>

<style>
  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 540px;
  }
  .newsletter-form-row {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }
  .newsletter-input {
    flex: 1;
    padding: 12px 16px;
    background: rgba(20, 20, 24, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-1);
    outline: none;
    transition: border-color 0.2s var(--ease);
  }
  .newsletter-input:focus {
    border-color: var(--accent);
  }
  .newsletter-input::placeholder { color: var(--text-3); }
  .newsletter-submit {
    padding: 12px 18px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s var(--ease);
  }
  .newsletter-submit:hover { background: #9333ea; }
  .newsletter-submit:disabled { opacity: 0.5; cursor: not-allowed; }
  .newsletter-status {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    min-height: 1.4em;
  }
  .newsletter-status[data-state="error"] { color: #f87171; }
  .newsletter-status[data-state="success"] { color: #5eead4; }
  .newsletter-status[data-state="loading"] { color: var(--text-3); }
</style>

<script>
  function wire() {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    if (!form || form.dataset.wired === '1') return;
    form.dataset.wired = '1';
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const email = String(fd.get('email') || '').trim();
      const status = form.querySelector<HTMLParagraphElement>('.newsletter-status');
      const submit = form.querySelector<HTMLButtonElement>('.newsletter-submit');
      if (!status || !submit) return;
      if (!email || !/^\S+@\S+\.\S+$/.test(email)) {
        status.dataset.state = 'error';
        status.textContent = 'That email doesn\'t look right.';
        return;
      }
      submit.disabled = true;
      status.dataset.state = 'loading';
      status.textContent = 'Subscribing…';
      try {
        const url = new URL(window.location.href);
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            utm_source: url.searchParams.get('utm_source') || 'melis-ai-website',
            utm_campaign: url.searchParams.get('utm_campaign') || 'organic',
          }),
        });
        if (!res.ok) {
          const text = await res.text();
          status.dataset.state = 'error';
          status.textContent = res.status === 503 ? 'Newsletter not configured yet.' : text || 'Something went wrong.';
          submit.disabled = false;
          return;
        }
        status.dataset.state = 'success';
        status.textContent = 'Subscribed. Check your inbox.';
        form.reset();
      } catch (err) {
        status.dataset.state = 'error';
        status.textContent = 'Network error — try again.';
        submit.disabled = false;
      }
    });
  }
  document.addEventListener('astro:page-load', wire);
  wire();
</script>
