---
// Sidebar2Recos — single persistent sb2 across all /recos/* routes.
// Mirrors the Sidebar2Prompts pattern verbatim:
//   - 2 pinned panel-items at top (All Recommendations + Sean's Must-Haves)
//   - 3 panel-groups (Operate / Learn / Atmosphere), chevron-collapsible
//   - Each category = panel-item with icon + title + meta + count chip
//
// transition:persist key is "sb2-recos" (single instance, not slug-scoped),
// so the DOM survives navigation across /recos/, /recos/must-haves/, and
// every /recos/<category>/ — user-expanded groups stay open. Active state
// is re-synced by AppLayout's syncSb2Active() on each page-load.

import { getCollection } from 'astro:content';

const all = await getCollection('recos');

// Count map (slug → tools length). Used for the .pi-dot count chip.
const counts = new Map<string, number>();
for (const r of all) {
  counts.set(r.slug, (r.data.tools || []).length);
}

// Cross-category must-have count for the pinned row.
let mustHaveCount = 0;
for (const r of all) {
  if (r.data.draft || r.data.status === 'coming-soon') continue;
  for (const t of (r.data.tools || []) as { mustHave?: boolean }[]) {
    if (t.mustHave) mustHaveCount += 1;
  }
}

const totalLive = all.reduce((acc, r) => acc + (r.data.status === 'live' ? (r.data.tools || []).length : 0), 0);

type Cat = {
  slug: string;
  title: string;
  meta: string;
  icon: string;
  color: string;
  bg: string;
  count: number;
};

const PINNED: Cat[] = [
  {
    slug: '__all__',
    title: 'All Recommendations',
    meta: 'Everything I actually use',
    icon: 'ph-star',
    color: '#fbbf24',
    bg: 'rgba(251,191,36,0.15)',
    count: totalLive,
  },
  {
    slug: 'must-haves',
    title: "Sean's Must-Haves",
    meta: "Refuse-to-give-up picks",
    icon: 'ph-lightning',
    color: '#ff6b6b',
    bg: 'rgba(255,107,107,0.15)',
    count: mustHaveCount,
  },
];

// Group structure — Operate / Learn / Atmosphere. Counts come from
// the recos collection so the chip stays honest as content lands.
const GROUPS: { name: string; cats: Cat[] }[] = [
  {
    name: 'Operate',
    cats: [
      { slug: 'software', title: 'Software', meta: 'Tools I actually use',     icon: 'ph-desktop-tower', color: '#5eead4', bg: 'rgba(94,234,212,0.15)',  count: counts.get('software')  ?? 0 },
      { slug: 'apps',     title: 'Apps',     meta: 'Software that earned a spot', icon: 'ph-app-window',  color: '#e879f9', bg: 'rgba(232,121,249,0.15)', count: counts.get('apps')      ?? 0 },
      { slug: 'hardware', title: 'Hardware', meta: 'Hardware & peripherals',   icon: 'ph-wrench',        color: '#60a5fa', bg: 'rgba(96,165,250,0.15)',  count: counts.get('hardware')  ?? 0 },
    ],
  },
  {
    name: 'Learn',
    cats: [
      { slug: 'books',       title: 'Books',       meta: 'Worth reading cover to cover', icon: 'ph-books',         color: '#a78bfa', bg: 'rgba(167,139,250,0.15)', count: counts.get('books')       ?? 0 },
      { slug: 'courses',     title: 'Courses',     meta: "Online courses I'd retake",    icon: 'ph-graduation-cap',color: '#a3e635', bg: 'rgba(163,230,53,0.15)',  count: counts.get('courses')     ?? 0 },
      { slug: 'newsletters', title: 'Newsletters', meta: 'Signal over noise picks',      icon: 'ph-newspaper',     color: '#fbbf24', bg: 'rgba(251,191,36,0.15)',  count: counts.get('newsletters') ?? 0 },
      { slug: 'communities', title: 'Communities', meta: 'Worth your time & energy',     icon: 'ph-users-three',   color: '#4ade80', bg: 'rgba(74,222,128,0.15)',  count: counts.get('communities') ?? 0 },
    ],
  },
  {
    name: 'Atmosphere',
    cats: [
      { slug: 'podcasts',   title: 'Podcasts',   meta: 'What I listen to',     icon: 'ph-microphone',    color: '#f472b6', bg: 'rgba(244,114,182,0.15)', count: counts.get('podcasts')   ?? 0 },
      { slug: 'youtubers',  title: 'YouTubers',  meta: 'Channels worth watching', icon: 'ph-youtube-logo', color: '#fb923c', bg: 'rgba(251,146,60,0.15)',  count: counts.get('youtubers')  ?? 0 },
      { slug: 'tv-shows',   title: 'TV Shows',   meta: 'Currently watching',   icon: 'ph-television',    color: '#38bdf8', bg: 'rgba(56,189,248,0.15)',  count: counts.get('tv-shows')   ?? 0 },
      { slug: 'movies',     title: 'Movies',     meta: 'Worth your time',      icon: 'ph-film-strip',    color: '#c084fc', bg: 'rgba(192,132,252,0.15)', count: counts.get('movies')     ?? 0 },
      { slug: 'music-sets', title: 'Music Sets', meta: 'What I build to',      icon: 'ph-music-note',    color: '#fb7185', bg: 'rgba(251,113,133,0.15)', count: counts.get('music-sets') ?? 0 },
    ],
  },
];

// Path detection for initial active state (final state cascades from
// AppLayout's syncSb2Active() after page-load — this just seeds the
// server-rendered DOM so first-paint isn't blank).
const path = Astro.url.pathname.replace(/\/$/, '');
const isLanding = path === '/recos' || path === '';
const slugMatch = path.match(/^\/recos\/([^/]+)$/);
const slugSegment = slugMatch?.[1] ?? null;

const allCategorySlugs = new Set(GROUPS.flatMap((g) => g.cats.map((c) => c.slug)));

function isPinnedActive(p: Cat): boolean {
  if (p.slug === '__all__') return isLanding;
  return slugSegment === p.slug;
}
function isCategoryActive(slug: string): boolean {
  return slugSegment === slug;
}
function isGroupOpen(group: { name: string; cats: Cat[] }, idx: number): boolean {
  // Open the group whose category is currently active. Default: first
  // group open if no category is active.
  if (slugSegment && allCategorySlugs.has(slugSegment)) {
    return group.cats.some((c) => c.slug === slugSegment);
  }
  return idx === 0;
}
---

<aside class="sidebar-2" transition:persist="sb2-recos">
  <div class="sb2-pane active" data-pane="recos">
    <div class="sb2-header">
      <div class="sb2-title">Sean's <em>Recos</em></div>
    </div>
    <div class="panel-list" style="padding: 8px 0; flex: 1; overflow-y: auto;">

      {PINNED.map((p) => (
        <a
          class:list={['panel-item', { active: isPinnedActive(p) }]}
          href={p.slug === '__all__' ? '/recos/' : `/recos/${p.slug}/`}
        >
          <i class={`ph ${p.icon} pi-icon`} style={`color:${p.color};opacity:0.85`}></i>
          <div class="pi-body">
            <div class="pi-title">{p.title}</div>
            <div class="pi-meta">{p.meta}</div>
          </div>
          <div class="pi-dot" style={`background:${p.bg};color:${p.color}`}>{p.count}</div>
        </a>
      ))}

      {GROUPS.map((g, gi) => (
        <div class:list={['panel-group', { open: isGroupOpen(g, gi) }]}>
          <div class="panel-group-header" data-pgh-toggle>
            <span class="pgh-label">{g.name}</span>
            <svg class="pgh-chevron" viewBox="0 0 10 6" fill="none">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="panel-group-items">
            {g.cats.map((c) => (
              <a class:list={['panel-item', { active: isCategoryActive(c.slug) }]} href={`/recos/${c.slug}/`}>
                <i class={`ph ${c.icon} pi-icon`} style={`color:${c.color};opacity:0.85`}></i>
                <div class="pi-body">
                  <div class="pi-title">{c.title}</div>
                  <div class="pi-meta">{c.meta}</div>
                </div>
                <div class="pi-dot" style={`background:${c.bg};color:${c.color}`}>{c.count}</div>
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>
  </div>
</aside>
