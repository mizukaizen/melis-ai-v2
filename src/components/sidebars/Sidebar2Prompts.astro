---
// Mockup-canonical sb2 for Prompt Library
// (mockup HTML sb2-pane[data-pane="prompts"], lines ~6000-6062).
//
// Structure:
//   - "All Prompts" pinned at top (always active when on /prompts/ landing)
//   - "Sean's Edge" pinned at top
//   - 4 panel-groups: Business (open by default), Think & Communicate,
//     Life & Career, Build — all collapsible via chevron click
//
// Active state:
//   - /prompts/                 → All Prompts active
//   - /prompts/<category>/      → that category active, its group auto-opens
//   - /prompts/<slug>/          → category of that prompt active + group opens
import { getCollection } from 'astro:content';

const all = (await getCollection('prompts')).filter((p) => !p.data.draft);

// Current path detection
const path = Astro.url.pathname;
const isLanding = path === '/prompts/' || path === '/prompts';
const categoryMatch = path.match(/^\/prompts\/([^/]+)\/?$/);
const slugSegment = categoryMatch?.[1];

// Build a quick lookup: prompt slug → categorySlug
const promptCategoryBySlug = new Map<string, string>();
for (const p of all) {
  promptCategoryBySlug.set(p.slug, p.data.categorySlug || '');
}

// Detect whether the URL segment is a category slug or a prompt slug
const allCategorySlugs = new Set(all.map((p) => p.data.categorySlug || ''));
let activeCategorySlug = '';
if (slugSegment) {
  if (allCategorySlugs.has(slugSegment)) {
    activeCategorySlug = slugSegment;
  } else if (promptCategoryBySlug.has(slugSegment)) {
    activeCategorySlug = promptCategoryBySlug.get(slugSegment) || '';
  }
}

// Category roster (verbatim from mockup HTML)
type Cat = {
  slug: string;
  title: string;
  meta: string;
  icon: string;
  color: string;
  bg: string;
  count: number;
};

const PINNED: Cat[] = [
  { slug: 'all',         title: 'All Prompts',  meta: '335 · 22 cats',         icon: 'ph-chat-dots', color: '#5eead4', bg: 'rgba(94,234,212,0.15)', count: 335 },
  { slug: 'seans-edge',  title: "Sean's Edge",  meta: 'AI-first thinking',     icon: 'ph-lightning', color: '#ff6b6b', bg: 'rgba(255,107,107,0.15)', count: 20 },
];

const GROUPS: { name: string; cats: Cat[] }[] = [
  { name: 'Business', cats: [
    { slug: 'sales',         title: 'Sales',         meta: 'Close without cringe',       icon: 'ph-handshake',     color: '#fb923c', bg: 'rgba(251,146,60,0.15)',   count: 15 },
    { slug: 'marketing',     title: 'Marketing',     meta: 'Right audience, right msg',  icon: 'ph-megaphone',     color: '#f472b6', bg: 'rgba(244,114,182,0.15)', count: 15 },
    { slug: 'finance',       title: 'Finance',       meta: 'Own your numbers',           icon: 'ph-chart-line-up', color: '#4ade80', bg: 'rgba(74,222,128,0.15)',   count: 15 },
    { slug: 'operations',    title: 'Operations',    meta: 'Systems that run',           icon: 'ph-gear-six',      color: '#facc15', bg: 'rgba(250,204,21,0.15)',   count: 15 },
    { slug: 'hiring',        title: 'Hiring',        meta: 'Find people who deliver',    icon: 'ph-users',         color: '#f87171', bg: 'rgba(248,113,113,0.15)', count: 15 },
    { slug: 'customer',      title: 'Customer',      meta: 'Understand & delight',       icon: 'ph-heart',         color: '#e879f9', bg: 'rgba(232,121,249,0.15)', count: 15 },
    { slug: 'legal',         title: 'Legal',         meta: 'Contracts simplified',       icon: 'ph-scales',        color: '#94a3b8', bg: 'rgba(148,163,184,0.15)', count: 15 },
  ]},
  { name: 'Think & Communicate', cats: [
    { slug: 'strategy',      title: 'Strategy',      meta: 'Think clearer, decide faster', icon: 'ph-compass',         color: '#a78bfa', bg: 'rgba(167,139,250,0.15)', count: 15 },
    { slug: 'frameworks',    title: 'Frameworks',    meta: 'Right model, right problem',   icon: 'ph-circles-three',   color: '#60a5fa', bg: 'rgba(96,165,250,0.15)',   count: 15 },
    { slug: 'writing',       title: 'Writing',       meta: 'Faster, clearer, better',      icon: 'ph-pen-nib',         color: '#818cf8', bg: 'rgba(129,140,248,0.15)', count: 15 },
    { slug: 'research',      title: 'Research',      meta: 'Deep dives in minutes',        icon: 'ph-magnifying-glass',color: '#22d3ee', bg: 'rgba(34,211,238,0.15)',   count: 15 },
    { slug: 'communication', title: 'Communication', meta: 'Say what you mean',            icon: 'ph-chat-circle',     color: '#fbbf24', bg: 'rgba(251,191,36,0.15)',   count: 15 },
  ]},
  { name: 'Life & Career', cats: [
    { slug: 'life-design',   title: 'Life Design',   meta: 'Design the life you want',     icon: 'ph-map-trifold',     color: '#fb7185', bg: 'rgba(251,113,133,0.15)', count: 15 },
    { slug: 'goals',         title: 'Goals',         meta: "Goals you'll actually hit",    icon: 'ph-target',          color: '#34d399', bg: 'rgba(52,211,153,0.15)',   count: 15 },
    { slug: 'creative',      title: 'Creative',      meta: 'Unlock, break blocks',         icon: 'ph-palette',         color: '#a3e635', bg: 'rgba(163,230,53,0.15)',   count: 15 },
    { slug: 'career',        title: 'Career',        meta: 'Hired, paid, ahead',           icon: 'ph-briefcase',       color: '#f59e0b', bg: 'rgba(245,158,11,0.15)',   count: 15 },
  ]},
  { name: 'Build', cats: [
    { slug: 'ai-tools',      title: 'AI Tools',      meta: 'Claude, Cursor & co.',         icon: 'ph-cpu',             color: '#5eead4', bg: 'rgba(94,234,212,0.15)',   count: 15 },
    { slug: 'prompting',     title: 'Prompting',     meta: 'Better outputs from any AI',   icon: 'ph-magic-wand',      color: '#2dd4bf', bg: 'rgba(45,212,191,0.15)',   count: 15 },
    { slug: 'coding',        title: 'Coding',        meta: 'Ship better code, faster',     icon: 'ph-code',            color: '#38bdf8', bg: 'rgba(56,189,248,0.15)',   count: 15 },
    { slug: 'data',          title: 'Data',          meta: 'Numbers into decisions',       icon: 'ph-chart-bar',       color: '#f97316', bg: 'rgba(249,115,22,0.15)',   count: 15 },
    { slug: 'product-tech',  title: 'Product',       meta: 'Things people actually use',   icon: 'ph-rocket-launch',   color: '#c084fc', bg: 'rgba(192,132,252,0.15)', count: 15 },
  ]},
];

function isActive(slug: string): boolean {
  if (slug === 'all') return isLanding;
  return activeCategorySlug === slug;
}

function isGroupOpen(group: { name: string; cats: Cat[] }, idx: number): boolean {
  // Default: Business open. If a category in another group is active, open that group instead.
  if (activeCategorySlug && group.cats.some((c) => c.slug === activeCategorySlug)) return true;
  if (activeCategorySlug) return false;
  return idx === 0;
}
---

<aside class="sidebar-2" transition:persist="sb2-prompts">
  <div class="sb2-pane active" data-pane="prompts">
    <div class="sb2-header">
      <div class="sb2-title"><em>Prompt Library</em></div>
    </div>
    <div class="panel-list" style="padding: 8px 0; flex: 1; overflow-y: auto;">

      {PINNED.map((c) => (
        <a class:list={['panel-item', { active: isActive(c.slug) }]} href={c.slug === 'all' ? '/prompts/' : `/prompts/${c.slug}/`}>
          <i class={`ph ${c.icon} pi-icon`} style={`color:${c.color};opacity:0.85`}></i>
          <div class="pi-body"><div class="pi-title">{c.title}</div><div class="pi-meta">{c.meta}</div></div>
          <div class="pi-dot" style={`background:${c.bg};color:${c.color}`}>{c.count}</div>
        </a>
      ))}

      {GROUPS.map((g, gi) => (
        <div class:list={['panel-group', { open: isGroupOpen(g, gi) }]}>
          <div class="panel-group-header" data-pgh-toggle>
            <span class="pgh-label">{g.name}</span>
            <svg class="pgh-chevron" viewBox="0 0 10 6" fill="none">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="panel-group-items">
            {g.cats.map((c) => (
              <a class:list={['panel-item', { active: isActive(c.slug) }]} href={`/prompts/${c.slug}/`}>
                <i class={`ph ${c.icon} pi-icon`} style={`color:${c.color};opacity:0.85`}></i>
                <div class="pi-body"><div class="pi-title">{c.title}</div><div class="pi-meta">{c.meta}</div></div>
                <div class="pi-dot" style={`background:${c.bg};color:${c.color}`}>{c.count}</div>
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>
  </div>
</aside>
