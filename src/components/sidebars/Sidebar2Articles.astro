---
// Pass 11 — render actual ARTICLES_LIST entries (live MDX collection),
// not abstract categories. Each item links to its detail page; the
// `syncSb2Active()` script in AppLayout.astro highlights the row whose
// href matches location.pathname.
import { getCollection } from 'astro:content';

const items = (await getCollection('articles'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

function formatDate(iso?: string) {
  // Mockup-canonical format: ISO YYYY-MM-DD.
  if (!iso) return '';
  return iso.slice(0, 10);
}
---

<aside class="sidebar-2" transition:persist="sb2-articles">
  <div class="sb2-pane active" data-pane="articles">
    <div class="sb2-header">
      <div class="sb2-title"><em>Articles</em></div>
    </div>
    <div class="sb2-list">
      <a class="sb2-item" href="/articles/">
        <div class="sb2-row">
          <div class="sb2-name">All Articles</div>
          <div class="sb2-count">{items.length}</div>
        </div>
        <div class="sb2-desc">Every essay + field note</div>
      </a>
      {items.map((a) => {
        const tag = a.data.category || a.data.tags?.[0] || '';
        const date = formatDate(a.data.publishedAt);
        const meta = [tag, date].filter(Boolean).join(' · ');
        return (
          <a class="sb2-item" href={`/articles/${a.slug}/`}>
            <div class="sb2-row">
              <div class="sb2-name">{a.data.title}</div>
            </div>
            {meta && <div class="sb2-desc">{meta}</div>}
          </a>
        );
      })}
    </div>
  </div>
</aside>
