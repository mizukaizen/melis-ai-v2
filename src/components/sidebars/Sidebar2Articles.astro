---
// All articles in sb2 — live + coming-soon — sorted publishedAt desc.
// Mockup-canonical styling:
//   - Uppercase violet category eyebrow above each title (Field Notes /
//     Essays / Tutorials / Tear-downs)
//   - Date format DD/MM short in sb2 ONLY (cards keep ISO)
//   - One-row metadata layout
//   - Coming-soon items render as <div> (non-clickable) with a "Coming soon"
//     badge — same treatment as the index cards.
import { getCollection } from 'astro:content';

const items = (await getCollection('articles'))
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

function formatDateShort(iso?: string) {
  // sb2 format: DD/MM (mockup-canonical for sidebar)
  if (!iso) return '';
  const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!m) return iso;
  return `${m[3]}/${m[2]}`;
}
---

<aside class="sidebar-2" transition:persist="sb2-articles">
  <div class="sb2-pane active" data-pane="articles">
    <div class="sb2-header">
      <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 18 Q 12 13 19 18"/><path d="M5 7 Q 12 12 19 7"/></svg>
      <div class="sb2-title"><em>Articles</em></div>
    </div>
    <div class="sb2-list">
      <a class="sb2-item" href="/articles/">
        <div class="sb2-row">
          <div class="sb2-name">All Articles</div>
          <div class="sb2-count">{items.length}</div>
        </div>
        <div class="sb2-desc">Every essay + field note</div>
      </a>
      {items.map((a) => {
        const cat = a.data.category || a.data.tags?.[0] || '';
        const date = formatDateShort(a.data.publishedAt);
        const isComingSoon = a.data.status === 'coming-soon';
        const inner = (
          <>
            {cat && <div class="sb2-eyebrow">{cat}</div>}
            <div class="sb2-row">
              <div class="sb2-name">{a.data.title}</div>
              {date && <div class="sb2-date">{date}</div>}
            </div>
            {isComingSoon && <div class="sb2-badge">Coming soon</div>}
          </>
        );
        return isComingSoon ? (
          <div class="sb2-item sb2-item-coming-soon">{inner}</div>
        ) : (
          <a class="sb2-item" href={`/articles/${a.slug}/`}>{inner}</a>
        );
      })}
    </div>
  </div>
</aside>

