---
// Mockup-canonical sb2 entries (lines 5311-5351 of melis-ai-spa-v6-astro-content.html).
// Note: mockup labels (Strategy Session / Build Sprint / Fractional Operator /
// Speaking / Advisory) don't 1:1 map to live service slugs — they're the
// mockup's IA. Each entry links to /services/ landing; specific detail pages
// are only available for the three live services.

const ENTRIES: { name: string; count: string; desc: string }[] = [
  { name: 'Strategy Session',    count: '1:1', desc: '90-minute deep dive' },
  { name: 'Build Sprint',        count: '1:1', desc: '2-week intensive shipping' },
  { name: 'Fractional Operator', count: '1:1', desc: 'Embedded for 3+ months' },
  { name: 'Speaking',            count: '—',   desc: 'Keynotes and workshops' },
  { name: 'Advisory',            count: '—',   desc: 'Ongoing strategic counsel' },
];
---

<aside class="sidebar-2" transition:persist="sb2-services">
  <div class="sb2-pane active" data-pane="services">
    <div class="sb2-header">
      <div class="sb2-title"><em>Services</em></div>
    </div>
    <div class="sb2-list">
      <a class="sb2-item" href="/services/">
        <div class="sb2-row">
          <div class="sb2-name">All Services</div>
          <div class="sb2-count">5</div>
        </div>
        <div class="sb2-desc">How to work with me</div>
      </a>
      {ENTRIES.map((e) => (
        <a class="sb2-item" href="/services/">
          <div class="sb2-row">
            <div class="sb2-name">{e.name}</div>
            <div class="sb2-count">{e.count}</div>
          </div>
          <div class="sb2-desc">{e.desc}</div>
        </a>
      ))}
    </div>
  </div>
</aside>
