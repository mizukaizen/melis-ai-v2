---
// Services sb2 — the single Confessional offer. The five old service
// tiers are archived in /content (draft) and removed from nav for now;
// may return in future.
const ENTRIES: { name: string; count: string; desc: string; href: string; icon: string }[] = [
  { name: 'The Report',       count: '$11',  desc: 'AI-built roadmap, in your inbox',    href: '/services/#confess', icon: 'ph-file-text' },
  { name: 'The Presentation', count: '$111', desc: 'I build & present the playbook',      href: '/services/#confess', icon: 'ph-projector-screen' },
];
---

<aside class="sidebar-2" transition:persist="sb2-services">
  <div class="sb2-pane active" data-pane="services">
    <div class="sb2-header">
      <div class="sb2-title"><em>The Confessional</em></div>
    </div>
    <div class="sb2-list">
      <a class="sb2-item" href="/services/">
        <i class="ph ph-microphone sb2-icon"></i>
        <div class="sb2-row">
          <div class="sb2-name">The Confessional</div>
          <div class="sb2-count">1:1</div>
        </div>
        <div class="sb2-desc">How to work with me</div>
      </a>
      {ENTRIES.map((e) => (
        <a class="sb2-item" href={e.href}>
          <i class={`ph ${e.icon} sb2-icon`}></i>
          <div class="sb2-row">
            <div class="sb2-name">{e.name}</div>
            <div class="sb2-count">{e.count}</div>
          </div>
          <div class="sb2-desc">{e.desc}</div>
        </a>
      ))}
    </div>
  </div>
</aside>
