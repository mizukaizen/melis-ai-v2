---
// Sidebar2About — sb2 for /about/sean (the biography route).
// /about/melis-ai now uses Sidebar2MelisAI (brand-book TOC).
// /about/legals  now uses Sidebar2Legals.
// All three are routed independently by Sidebar2.astro. Cross-section
// navigation between the three ABOUT pages is handled by sb1 — this
// sb2 shows only the items relevant to /about/sean.

// Chapter TOC for /about/sean/ — anchor IDs match the chapter divs in
// src/_html/pane-about.html (ch01-ch09 + timeline + drives).
const SEAN_CHAPTERS: { id: string; label: string; num?: string }[] = [
  { id: 'top',      label: 'Opening' },
  { id: 'ch01',     label: 'The Blueprint',          num: '01' },
  { id: 'ch02',     label: 'Sharp End of the Spear', num: '02' },
  { id: 'ch03',     label: 'The Machine Starts',     num: '03' },
  { id: 'ch04',     label: 'The Great Unraveling',   num: '04' },
  { id: 'ch05',     label: 'Zero to Agency',         num: '05' },
  { id: 'ch06',     label: 'The Pivot',              num: '06' },
  { id: 'ch07',     label: 'Back in the Room',       num: '07' },
  { id: 'ch08',     label: 'The Edge',               num: '08' },
  { id: 'ch09',     label: 'The Long Bet',           num: '09' },
  { id: 'timeline', label: 'Career Timeline' },
  { id: 'drives',   label: 'What Drives Me' },
];
---

<aside class="sidebar-2" transition:persist="sb2-about">
  <div class="sb2-pane active" data-pane="about">
    <div class="sb2-header">
      <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="9" r="3"/><path d="M5 20a7 7 0 0 1 14 0"/></svg>
      <div class="sb2-title"><em>Sean</em></div>
    </div>

    <nav class="about-toc" data-about-toc>
      <div class="about-toc-label">Chapters</div>
      {SEAN_CHAPTERS.map((c) => (
        <a class="about-toc-item" href={`#${c.id}`} data-toc-target={c.id}>
          {c.num && <span class="toc-num">{c.num}</span>}
          <span class="toc-label">{c.label}</span>
        </a>
      ))}
    </nav>
  </div>
</aside>

<script>
  // Scroll-spy: highlight the about-toc item whose target section is
  // currently in view. Smooth-scroll on click. Runs on every page load
  // and after Astro view-transitions.
  function wireAboutScrollSpy() {
    const toc = document.querySelector<HTMLElement>('[data-about-toc]');
    if (!toc) return;
    if (toc.dataset.wired === '1') return;
    toc.dataset.wired = '1';

    const items = toc.querySelectorAll<HTMLAnchorElement>('.about-toc-item');
    const sectionById = new Map<string, Element>();
    items.forEach((item) => {
      const id = item.dataset.tocTarget;
      if (!id) return;
      const el = document.getElementById(id);
      if (el) sectionById.set(id, el);
    });

    if (sectionById.size === 0) return;

    const setActive = (id: string | null) => {
      items.forEach((it) => {
        it.classList.toggle('is-current', it.dataset.tocTarget === id);
      });
    };

    // Smooth scroll on click.
    items.forEach((item) => {
      item.addEventListener('click', (e) => {
        const id = item.dataset.tocTarget;
        if (!id) return;
        const el = sectionById.get(id);
        if (!el) return;
        e.preventDefault();
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setActive(id);
        history.replaceState(null, '', `#${id}`);
      });
    });

    // IntersectionObserver — fires when ≥30% of a section is in the
    // upper-half of the viewport. Picks the topmost intersecting section.
    const visible = new Set<string>();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = (entry.target as HTMLElement).id;
          if (!id) return;
          if (entry.isIntersecting) visible.add(id);
          else visible.delete(id);
        });
        // Pick the first section in document order that's visible.
        const orderedIds = Array.from(items)
          .map((it) => it.dataset.tocTarget!)
          .filter((id) => visible.has(id));
        setActive(orderedIds[0] || null);
      },
      {
        rootMargin: '-15% 0px -55% 0px',
        threshold: [0, 0.3, 0.6],
      },
    );
    sectionById.forEach((el) => observer.observe(el));

    // Initial state — light up the first section by default.
    const first = items[0]?.dataset.tocTarget;
    if (first) setActive(first);
  }
  document.addEventListener('DOMContentLoaded', wireAboutScrollSpy);
  document.addEventListener('astro:after-swap', wireAboutScrollSpy);
  if (document.readyState !== 'loading') wireAboutScrollSpy();
</script>
