---
// Sidebar2About — sb2 for /about/sean (the biography route).
// /about/melis-ai uses Sidebar2MelisAI (brand-book TOC).
// All routes are dispatched independently by Sidebar2.astro.
//
// Pattern mirrors Sidebar2Dossiers/Articles/Newsletter — canonical
// .sb2-header + .panel-list + .panel-item with icon + body + count.

const CHAPTERS: { id: string; title: string; subtitle?: string; num?: string; icon: string }[] = [
  { id: 'top',      title: 'Opening',                       subtitle: undefined,                                                                       icon: 'ph-book-open' },
  { id: 'ch01',     title: 'The Blueprint',                 num: '01', subtitle: 'Brisbane, early 2000s — architects for parents, AI in high school',  icon: 'ph-compass' },
  { id: 'ch02',     title: 'Sharp End of the Spear',        num: '02', subtitle: 'QUT 2011–2015 — international competitions, Uber early hire, Shanghai', icon: 'ph-target' },
  { id: 'ch03',     title: 'The Machine Starts',            num: '03', subtitle: "Deloitte 2016–2017 — RPA pioneer, Singapore and China, Brisbane's first AI research deck", icon: 'ph-gear' },
  { id: 'ch04',     title: 'The Great Unraveling',          num: '04', subtitle: '2017 — the failures, the floor, the reset',                          icon: 'ph-arrows-out' },
  { id: 'ch05',     title: 'Zero to Agency',                num: '05', subtitle: "bot•hello 2017–2023 — Australia's first conversational AI agency, digital humans, Intercom APAC", icon: 'ph-rocket-launch' },
  { id: 'ch06',     title: 'The Pivot',                     num: '06', subtitle: '2023 — walking away from a profitable business, teaching at scale',  icon: 'ph-arrow-bend-up-right' },
  { id: 'ch07',     title: 'Back in the Room',              num: '07', subtitle: 'PA Consulting 2025 — enterprise AI, Tier 1 banks, agentic transformation', icon: 'ph-door-open' },
  { id: 'ch08',     title: 'The Edge',                      num: '08', subtitle: 'melis.ai 2026 — London, multi-agent systems, building in the open',   icon: 'ph-mountains' },
  { id: 'ch09',     title: 'The Long Bet',                  num: '09', subtitle: "2026 and beyond — what's being built, and where it's all heading",    icon: 'ph-infinity' },
  { id: 'timeline', title: 'Career Timeline',               subtitle: undefined,                                                                       icon: 'ph-clock-counter-clockwise' },
  { id: 'drives',   title: 'What Drives Me',                subtitle: undefined,                                                                       icon: 'ph-flame' },
];
---

<aside class="sidebar-2" transition:persist="sb2-about">
  <div class="sb2-pane active" data-pane="about">
    <div class="sb2-header">
      <div class="sb2-title"><em>My story</em></div>
    </div>

    <div class="panel-list" data-about-toc>
      {CHAPTERS.map((c) => (
        <a class="panel-item" href={`#${c.id}`} data-toc-target={c.id}>
          <i class={`ph ${c.icon} pi-icon`} style="color:var(--accent);opacity:0.85"></i>
          <div class="pi-body">
            <div class="pi-title">{c.title}</div>
            {c.subtitle && <div class="pi-meta">{c.subtitle}</div>}
          </div>
          {c.num && <div class="pi-dot">{c.num}</div>}
        </a>
      ))}
    </div>
  </div>
</aside>

<script>
  // Scroll-spy + smooth-scroll on TOC click. Idempotent across page
  // loads + Astro view-transitions.
  function wireSeanScrollSpy() {
    const toc = document.querySelector<HTMLElement>('aside.sidebar-2 [data-about-toc]');
    if (!toc) return;
    if (toc.dataset.wired === '1') return;
    toc.dataset.wired = '1';

    const items = toc.querySelectorAll<HTMLAnchorElement>('.panel-item');
    const sectionById = new Map<string, Element>();
    items.forEach((item) => {
      const id = item.dataset.tocTarget;
      if (!id) return;
      const el = document.getElementById(id);
      if (el) sectionById.set(id, el);
    });
    if (sectionById.size === 0) return;

    const setActive = (id: string | null) => {
      items.forEach((it) => {
        it.classList.toggle('active', it.dataset.tocTarget === id);
      });
    };

    items.forEach((item) => {
      item.addEventListener('click', (e) => {
        const id = item.dataset.tocTarget;
        if (!id) return;
        const el = sectionById.get(id);
        if (!el) return;
        e.preventDefault();
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        // Don't setActive here — the IntersectionObserver settles the
        // highlight when the smooth scroll lands. Calling setActive on
        // click caused a "flash" of the destination, then a bounce as
        // the IO picked up intermediate sections passing through the
        // viewport, then a re-settle on the destination. Mirrors the
        // melis-ai sidebar behaviour.
        history.replaceState(null, '', `#${id}`);
      });
    });

    const visible = new Set<string>();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = (entry.target as HTMLElement).id;
          if (!id) return;
          if (entry.isIntersecting) visible.add(id);
          else visible.delete(id);
        });
        // 'top' is the entire .section-body wrapper that CONTAINS every
        // chapter — so the IO reports it as intersecting whenever any
        // chapter is on screen. That meant clicking ch03/ch05 etc. left
        // the active highlight stuck on Opening. Filter 'top' out of
        // the contention whenever any other section is also visible —
        // 'top' only wins when nothing else is on screen (= true top
        // of the page).
        const otherVisible = Array.from(items)
          .map((it) => it.dataset.tocTarget!)
          .filter((id) => id !== 'top' && visible.has(id));
        if (otherVisible.length > 0) {
          setActive(otherVisible[0]);
          return;
        }
        if (visible.has('top')) {
          setActive('top');
          return;
        }
        // No section currently visible (between sections) — keep last active.
      },
      { rootMargin: '-15% 0px -55% 0px', threshold: [0, 0.3, 0.6] },
    );
    sectionById.forEach((el) => observer.observe(el));

    const first = items[0]?.dataset.tocTarget;
    if (first) setActive(first);
  }
  document.addEventListener('DOMContentLoaded', wireSeanScrollSpy);
  document.addEventListener('astro:after-swap', wireSeanScrollSpy);
  if (document.readyState !== 'loading') wireSeanScrollSpy();
</script>
