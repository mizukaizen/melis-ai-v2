---
import { getCollection } from 'astro:content';
import { DOSSIER_CATEGORIES } from '../../data/dossier-categories';

const all = (await getCollection('dossiers')).filter((d) => !d.data.draft);
const byCategory = new Map<string, typeof all>();
for (const d of all) {
  const c = d.data.category;
  if (!byCategory.has(c)) byCategory.set(c, [] as never);
  byCategory.get(c)!.push(d);
}

// Find current category from URL: /dossiers/<category>/ or /dossiers/<category>/<slug>/
const pathParts = Astro.url.pathname.replace(/^\/+|\/+$/g, '').split('/');
const currentCategory = pathParts[0] === 'dossiers' ? pathParts[1] : undefined;
const currentSlug = pathParts[0] === 'dossiers' ? pathParts[2] : undefined;

const ORDER = [
  'books', 'essays', 'mental-models', 'thought-experiments',
  'remarkable-people', 'letters', 'speeches', 'poems',
  'manifestos', 'scientific-papers', 'ai-concepts', 'vocabulary',
] as const;

type CatSlug = keyof typeof DOSSIER_CATEGORIES;
const categories = ORDER.map((slug) => ({
  slug,
  cat: DOSSIER_CATEGORIES[slug as CatSlug],
  items: byCategory.get(slug) ?? [],
})).filter((c) => c.cat);
---

<aside class="sidebar-2" transition:persist="sb2-dossiers">
  <div class="sb2-pane active" data-pane="library">
    <div class="sb2-header">
      <div class="sb2-title"><em>Dossiers</em></div>
    </div>
    <div class="panel-list">
      <a class="panel-item" class:list={[{ active: !currentCategory }]} href="/dossiers/">
        <i class="ph ph-book-open-text pi-icon" style="color:#a78bfa;opacity:0.9"></i>
        <div class="pi-body">
          <div class="pi-title">All Dossiers</div>
          <div class="pi-meta">{all.length} fleshed · 242 catalogued</div>
        </div>
        <div class="pi-dot" style="background:rgba(168,85,247,0.18);color:#a78bfa">{all.length}</div>
      </a>
      {categories.map(({ slug, cat, items }) => {
        const isOpen = currentCategory === slug;
        return (
          <div class:list={['panel-group', { open: isOpen }]}>
            <div class="panel-group-header">
              <span class="pgh-label">{cat.title}</span>
              <svg class="pgh-chevron" viewBox="0 0 10 6" fill="none">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="panel-group-items">
              <a class="panel-item" class:list={[{ active: currentCategory === slug && !currentSlug }]} href={`/dossiers/${slug}/`}>
                <div class="pi-body">
                  <div class="pi-title" style="font-style:italic;">View all {cat.title.toLowerCase()}</div>
                  <div class="pi-meta">{cat.count}</div>
                </div>
              </a>
              {items.map((d) => (
                <a class="panel-item" class:list={[{ active: d.slug === currentSlug }]} href={`/dossiers/${slug}/${d.slug}/`}>
                  <div class="pi-body">
                    <div class="pi-title">{d.data.title.replace(/<[^>]+>/g, '')}</div>
                    {d.data.byline && <div class="pi-meta">{d.data.byline.split('·')[0].trim()}</div>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</aside>
