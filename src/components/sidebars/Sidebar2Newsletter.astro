---
// All newsletter issues in sb2 — live + coming-soon — sorted publishedAt desc.
// Mockup-canonical styling:
//   - Uppercase violet channel eyebrow above each title (Soul of the Machine /
//     Operator's Brief / Hive Doctrine / Dispatch)
//   - Date format DD/MM short in sb2 ONLY (cards keep ISO)
//   - One-row metadata layout
//   - Coming-soon items render as <div> (non-clickable) with badge.
import { getCollection } from 'astro:content';

const items = (await getCollection('newsletter'))
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

function formatDateShort(iso?: string) {
  if (!iso) return '';
  const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!m) return iso;
  return `${m[3]}/${m[2]}`;
}

function channelFor(data: { byline?: string; eyebrow?: string }) {
  // Mockup byline format: "Sean · Channel · Issue 12"
  // Mockup eyebrow format: "Channel · 2026-04-28" OR "Newsletter · Channel · Issue 047"
  if (data.byline) {
    const parts = data.byline.split('·').map((s) => s.trim());
    if (parts[1]) return parts[1];
  }
  if (data.eyebrow) {
    const parts = data.eyebrow.split('·').map((s) => s.trim());
    // "Newsletter · Soul of the Machine · Issue 047" → 2nd
    // "Soul of the Machine · 2026-04-28" → 1st (skip if it looks like a date)
    const dateLike = /^\d{4}-\d{2}-\d{2}$/;
    for (const p of parts) {
      if (p && !dateLike.test(p) && p.toLowerCase() !== 'newsletter' && !/^issue/i.test(p)) {
        return p;
      }
    }
  }
  return '';
}
---

<aside class="sidebar-2" transition:persist="sb2-newsletter">
  <div class="sb2-pane active" data-pane="newsletter">
    <div class="sb2-header">
      <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="6" width="16" height="12" rx="1"/><path d="M4 9h16"/></svg>
      <div class="sb2-title"><em>Newsletter</em></div>
    </div>
    <div class="sb2-list">
      <a class="sb2-item" href="/newsletter/">
        <div class="sb2-row">
          <div class="sb2-name">All Issues</div>
          <div class="sb2-count">{items.length}</div>
        </div>
        <div class="sb2-desc">Every dispatch</div>
      </a>
      {items.map((n) => {
        const channel = channelFor(n.data);
        const date = formatDateShort(n.data.publishedAt);
        const isComingSoon = n.data.status === 'coming-soon';
        const inner = (
          <>
            {channel && <div class="sb2-eyebrow">{channel}</div>}
            <div class="sb2-row">
              <div class="sb2-name">{n.data.title}</div>
              {date && <div class="sb2-date">{date}</div>}
            </div>
            {isComingSoon && <div class="sb2-badge">Coming soon</div>}
          </>
        );
        return isComingSoon ? (
          <div class="sb2-item sb2-item-coming-soon">{inner}</div>
        ) : (
          <a class="sb2-item" href={`/newsletter/${n.slug}/`}>{inner}</a>
        );
      })}
    </div>
  </div>
</aside>

<style>
  .sb2-eyebrow {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c4b5fd;
    margin-bottom: 4px;
  }
  .sb2-date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-3);
    letter-spacing: 0.04em;
    margin-left: 8px;
    flex-shrink: 0;
  }
  .sb2-row { display: flex; align-items: baseline; justify-content: space-between; gap: 8px; }
  .sb2-item-coming-soon { cursor: default; opacity: 0.72; }
  .sb2-item-coming-soon:hover { background: transparent; }
  .sb2-badge {
    display: inline-block;
    margin-top: 4px;
    background: rgba(168, 85, 247, 0.18);
    color: #c4b5fd;
    border: 1px solid rgba(168, 85, 247, 0.35);
    padding: 2px 7px;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
