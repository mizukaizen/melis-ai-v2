---
import { getCollection } from 'astro:content';

const items = (await getCollection('newsletter'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));
const currentSlug = Astro.url.pathname.match(/\/newsletter\/([^/]+)/)?.[1];
---

<aside class="sidebar-2" transition:persist="sb2-newsletter">
  <div class="sb2-pane active" data-pane="newsletter">
    <div class="sb2-header">
      <div class="sb2-title"><em>Newsletter</em></div>
    </div>
    <div class="sb2-list">
      <a class="sb2-item" class:list={[{ active: !currentSlug }]} href="/newsletter/">
        <div class="sb2-row">
          <div class="sb2-name">Subscribe</div>
          <div class="sb2-count badge-live">DAILY</div>
        </div>
        <div class="sb2-desc">Soul of the Machine · daily dispatch</div>
      </a>
      {items.map((n) => (
        <a class="sb2-item" class:list={[{ active: n.slug === currentSlug }]} href={`/newsletter/${n.slug}/`}>
          <div class="sb2-row">
            <div class="sb2-name">{n.data.title}</div>
            {n.data.publishedAt && <div class="sb2-count">{n.data.publishedAt.slice(5)}</div>}
          </div>
          {n.data.byline && <div class="sb2-desc">{n.data.byline}</div>}
        </a>
      ))}
    </div>
  </div>
</aside>
