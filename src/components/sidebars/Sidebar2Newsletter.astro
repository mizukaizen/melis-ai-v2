---
// Pass 11 — render actual NEWSLETTER_LIST entries from the live MDX
// collection. Each issue links to its detail page; AppLayout's
// `syncSb2Active()` highlights the row whose href matches the URL.
import { getCollection } from 'astro:content';

const items = (await getCollection('newsletter'))
  .filter((n) => !n.data.draft)
  .sort((a, b) => (b.data.publishedAt || '').localeCompare(a.data.publishedAt || ''));

function formatDate(iso?: string) {
  if (!iso) return '';
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: '2-digit' });
}

function tagFor(byline?: string) {
  if (!byline) return '';
  const parts = byline.split('·').map((s) => s.trim());
  return parts[1] || parts[0] || '';
}
---

<aside class="sidebar-2" transition:persist="sb2-newsletter">
  <div class="sb2-pane active" data-pane="newsletter">
    <div class="sb2-header">
      <div class="sb2-title"><em>Newsletter</em></div>
    </div>
    <div class="sb2-list">
      <a class="sb2-item" href="/newsletter/">
        <div class="sb2-row">
          <div class="sb2-name">All Issues</div>
          <div class="sb2-count">{items.length}</div>
        </div>
        <div class="sb2-desc">Every dispatch</div>
      </a>
      {items.map((n) => {
        const tag = tagFor(n.data.byline);
        const date = formatDate(n.data.publishedAt);
        const meta = [tag, date].filter(Boolean).join(' · ');
        return (
          <a class="sb2-item" href={`/newsletter/${n.slug}/`}>
            <div class="sb2-row">
              <div class="sb2-name">{n.data.title}</div>
            </div>
            {meta && <div class="sb2-desc">{meta}</div>}
          </a>
        );
      })}
    </div>
  </div>
</aside>
