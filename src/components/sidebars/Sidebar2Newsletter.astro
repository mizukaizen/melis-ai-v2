---
// Mockup-canonical sb2 entries (lines 5197-5244 of melis-ai-spa-v6-astro-content.html).
import { getCollection } from 'astro:content';

const items = (await getCollection('newsletter')).filter((n) => !n.data.draft);
const total = items.length;

const ENTRIES: { name: string; count: string; desc: string }[] = [
  { name: 'Latest dispatch',     count: '01', desc: 'Sent this week' },
  { name: 'Soul of the Machine', count: '47', desc: 'The flagship Sunday email' },
  { name: "Operator's Brief",    count: '23', desc: 'Tuesday tactical newsletter' },
  { name: 'Hive Doctrine',       count: '12', desc: 'Cinematic essays on intelligence' },
  { name: 'Subscribe',           count: '—',  desc: 'Join 6,400+ operators' },
  { name: 'Archive',             count: '82', desc: 'Browse every issue' },
];
---

<aside class="sidebar-2" transition:persist="sb2-newsletter">
  <div class="sb2-pane active" data-pane="newsletter">
    <div class="sb2-header">
      <div class="sb2-title"><em>Newsletter</em></div>
    </div>
    <div class="sb2-list">
      <a class="sb2-item" href="/newsletter/">
        <div class="sb2-row">
          <div class="sb2-name">All Issues</div>
          <div class="sb2-count">{total}×</div>
        </div>
        <div class="sb2-desc">Every dispatch</div>
      </a>
      {ENTRIES.map((e) => (
        <a class="sb2-item" href="/newsletter/">
          <div class="sb2-row">
            <div class="sb2-name">{e.name}</div>
            <div class="sb2-count">{e.count}</div>
          </div>
          <div class="sb2-desc">{e.desc}</div>
        </a>
      ))}
    </div>
  </div>
</aside>
