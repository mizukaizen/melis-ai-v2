---
// Section 17.5 · Channel · The Cowork Course. Verbatim embed of the
// brand-guidelines.html section body, scoped under .bg-port. Gated
// behind the same locked-section password as the other detail
// sections. Anchor id = `cowork-course` to match the brand-guidelines
// source.

import LockedSection from './LockedSection.astro';
import fs from 'node:fs';
import path from 'node:path';

const coworkHtml = fs.readFileSync(
  path.resolve(process.cwd(), 'src/components/about/brand/_bg-cowork-body.html'),
  'utf8',
);
---

<section id="cowork-course" data-brand-section class="melis-section">
  <div class="melis-section-eyebrow-row">
    <span class="num">17.5</span>
    <span class="name">Where the brand lives · The Cowork Course</span>
    <span class="line"></span>
  </div>
  <h2 class="melis-section-title">A course that teaches what we actually run.</h2>

  <div class="melis-prose">
    <p>The flagship channel where the operating system gets unbundled — methods, prompts, agent configs, the full working stack. Detail block is locked alongside the rest of the brand-system reference.</p>
  </div>

  <LockedSection slug="cowork-course-full" title="Cowork course · positioning, pillars, surface treatment">
    <div class="bg-port bg-port-locked" set:html={coworkHtml} />
  </LockedSection>
</section>
