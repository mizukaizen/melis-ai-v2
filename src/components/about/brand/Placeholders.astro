const LOCKED_TITLE: Record<Props['slug'], string> = {
  spacing:       'Detailed spacing tokens · reading widths',
  motion:        'Easings, durations, motion demos · live indicator · skeleton · progress',
  dataviz:       'KPI cards · line chart · bar chart · sparkline · brand table',
  accessibility: 'Contrast matrix · focus-state demo · WCAG 2.2 AA audit',
};

const LOCKED_HTML: Record<Props['slug'], string> = {
  spacing:       SPACING_HTML,
  motion:        MOTION_HTML,
  dataviz:       DATAVIZ_HTML,
  accessibility: ACCESSIBILITY_HTML,
};
---

<section id={slug} data-brand-section class="melis-section melis-section-wide">
  <div class="melis-section-eyebrow-row">
    <span class="num">{s.num}</span>
    <span class="name">{s.group} · {s.name}</span>
    <span class="line"></span>
  </div>
  <h2 class="melis-section-title">{s.title}</h2>

  <div class="melis-prose">
    <p set:html={s.body} />
  </div>

  <LockedSection slug={`${slug}-full`} title={LOCKED_TITLE[slug]}>
    <div class="bg-port bg-port-locked" set:html={LOCKED_HTML[slug]} />
  </LockedSection>
</section>

<style is:global>
  /* Constrain ported chunks to the LockedSection width so the
     brand-guidelines container helpers don't break out of the
     surrounding prose column. */
  .bg-port-locked .container,
  .bg-port-locked .container-narrow {
    max-width: 100%;
    padding: 0;
  }
  .bg-port-locked {
    margin-top: 8px;
  }
  @media (max-width: 900px) {
    .bg-port-locked [style*="grid-template-columns: repeat(4, 1fr)"],
    .bg-port-locked [style*="grid-template-columns: 1fr 1fr 1fr"],
    .bg-port-locked [style*="grid-template-columns: 1fr 1fr"],
    .bg-port-locked [style*="grid-template-columns: 1.4fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
