---
// Principle stubs for Spacing & layout · Motion · Data viz ·
// Accessibility. Each renders with the canonical section chrome
// (eyebrow row + Cormorant title + 2–3 sentence prose body). Voice
// lifted from Manifesto/Promise — short, declarative, principle-first.
//
// Below the principle, sections marked as having locked content reveal
// the FULL brand-guidelines.html content for that section, gated by
// the page-level unlock. The embedded HTML is the verbatim markup
// from brand-guidelines.html scoped under .bg-port so its CSS doesn't
// leak into the rest of the site (see src/styles/brand-port.css).

import LockedSection from './LockedSection.astro';

interface Props {
  slug: 'spacing' | 'motion' | 'dataviz' | 'accessibility';
}

const { slug } = Astro.props;

type Stub = {
  num: string;
  group: string;
  name: string;
  title: string;
  body: string;
};

const STUBS: Record<Props['slug'], Stub> = {
  spacing: {
    num: '08', group: 'How we appear', name: 'Spacing & layout',
    title: 'Generous, considered, never tight.',
    body: 'Whitespace earns its place. The page breathes because every block has room to be what it is — body copy at a comfortable reading column, sections separated by air, chrome that frames without crowding. <em>Density is not depth.</em> When a layout feels crowded, the answer is almost never another column.',
  },
  motion: {
    num: '11', group: 'How we appear', name: 'Motion',
    title: 'Restrained, purposeful, never decorative.',
    body: 'Things move when meaning requires it — a state change, a transition between rooms, a focus shift that draws the eye to where the work is now. We don\'t animate to signal effort. A still page that holds attention is worth more than a page that performs liveliness. <em>Honest before impressive.</em>',
  },
  dataviz: {
    num: '12', group: 'How we appear', name: 'Data viz',
    title: 'Honest before impressive.',
    body: 'Charts that tell the truth even when the truth is messy. One chart, one primary colour. Maximise data, minimise chrome. If a chart needs decoration to be interesting, the underlying data isn\'t the point — and we should be writing prose instead.',
  },
  accessibility: {
    num: '13', group: 'How we appear', name: 'Accessibility',
    title: 'WCAG AA is the floor, not the goal.',
    body: 'Contrast targets hit. Focus states visible. Motion-reduction honoured. Keyboard-first interaction across every surface. Accessibility is a brand decision, not a compliance afterthought — <em>the surface tells you what we think of the audience.</em>',
  },
};

const s = STUBS[slug];

// Verbatim HTML from brand-guidelines.html (lines 5116-5141 / 6318-6376
// / 6390-6635), with the outer <section id="…"> stripped to avoid
// duplicate IDs. All class names are intact — the .bg-port wrapper
// scopes them via brand-port.css.
const SPACING_HTML = `
<div class="container">
  <div class="spacing-grid">
    <div class="spacing-card">
      <h4>Spacing scale · 8px base</h4>
      <div class="spacing-bars">
        <div class="spacing-bar-row"><span class="label">xs</span><span class="bar" style="width: 4px;"></span><span class="px">4 px</span></div>
        <div class="spacing-bar-row"><span class="label">sm</span><span class="bar" style="width: 8px;"></span><span class="px">8 px</span></div>
        <div class="spacing-bar-row"><span class="label">md</span><span class="bar" style="width: 16px;"></span><span class="px">16 px</span></div>
        <div class="spacing-bar-row"><span class="label">lg</span><span class="bar" style="width: 24px;"></span><span class="px">24 px</span></div>
        <div class="spacing-bar-row"><span class="label">xl</span><span class="bar" style="width: 44px;"></span><span class="px">44 px · section gap</span></div>
        <div class="spacing-bar-row"><span class="label">2xl</span><span class="bar" style="width: 64px;"></span><span class="px">64 px</span></div>
        <div class="spacing-bar-row"><span class="label">3xl</span><span class="bar" style="width: 96px;"></span><span class="px">96 px</span></div>
      </div>
    </div>
    <div class="spacing-card">
      <h4>Layout columns · reading widths</h4>
      <div class="layout-viz">
        <div class="col" style="width: 35%;">720 px<br>standard</div>
        <div class="col" style="width: 50%;">1100 px<br>wide</div>
        <div class="col" style="width: 15%;">232 px<br>sidebar</div>
      </div>
      <p style="font-family: var(--font-body); font-size: 12px; color: var(--text-2); line-height: 1.6; margin-top: 20px;">720 px is the standard reading pane — wider than this, comfort drops. 1100 px is the wide pane for grids and dashboards. The sidebar is a fixed 232 px on desktop.</p>
    </div>
  </div>
</div>
`;

const MOTION_HTML = `
<div class="container">
  <div class="demo-card" style="margin-bottom: 24px;">
    <div class="demo-meta"><span class="lhs">Easings</span><span class="rhs">three curves</span></div>
    <div class="demo-canvas" style="padding: 28px 36px; align-items: stretch;">
      <div class="motion-row">
        <div class="label">--ease-out</div>
        <div class="motion-track"><span class="motion-dot ease-out"></span></div>
        <div class="spec">cubic-bezier(0.16, 1, 0.3, 1)</div>
      </div>
      <div class="motion-row">
        <div class="label">--ease-in-out</div>
        <div class="motion-track"><span class="motion-dot ease-in-out"></span></div>
        <div class="spec">cubic-bezier(0.4, 0, 0.2, 1)</div>
      </div>
      <div class="motion-row">
        <div class="label">--ease-linear</div>
        <div class="motion-track"><span class="motion-dot ease-linear"></span></div>
        <div class="spec">linear · loaders only</div>
      </div>
    </div>
    <div class="demo-caption"><strong style="color: var(--text); font-weight: 500;">Default is <span class="a-code">--ease-out</span></strong> — quick start, slow settle. <span class="a-code">--ease-in-out</span> for two-way (drawer open/close). <span class="a-code">--ease-linear</span> only for continuous motion (loaders, progress bars).</div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px;">
    <div class="demo-card">
      <div class="demo-meta"><span class="lhs">Live indicator</span><span class="rhs">pulse 2s</span></div>
      <div class="demo-canvas">
        <div style="display: flex; align-items: center; gap: 12px;">
          <span class="live-dot-demo"></span>
          <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-2); letter-spacing: 0.08em; text-transform: uppercase;">Live · syncing</span>
        </div>
      </div>
      <div class="demo-caption">Box-shadow pulse 0 → 12px, opacity fade. Used on real-time data and live agent status.</div>
    </div>
    <div class="demo-card">
      <div class="demo-meta"><span class="lhs">Skeleton loader</span><span class="rhs">1500ms ease</span></div>
      <div class="demo-canvas" style="padding: 24px; align-items: stretch; gap: 8px;">
        <div class="skeleton-line w-third" style="width: 30%;"></div>
        <div class="skeleton-line"></div>
        <div class="skeleton-line w-half"></div>
      </div>
      <div class="demo-caption">Opacity pulse 0.4 → 0.8 → 0.4. Restrained — no shimmer-sweep effect.</div>
    </div>
    <div class="demo-card">
      <div class="demo-meta"><span class="lhs">Progress · indeterminate</span><span class="rhs">1.6s loop</span></div>
      <div class="demo-canvas" style="padding: 32px 28px; align-items: stretch;">
        <div class="progress-shell"><div class="indeterminate"></div></div>
      </div>
      <div class="demo-caption">Linear, no spinner. Spinners signal "stuck" — bars signal "working".</div>
    </div>
  </div>
</div>
`;

