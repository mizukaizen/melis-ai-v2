---
// Principle stubs for Spacing & layout · Motion · Data viz ·
// Accessibility. Each renders with the canonical section chrome
// (eyebrow row + Cormorant title + 2–3 sentence prose body) — no
// dashed-border placeholder treatment, no "available to collaborators"
// framing. Voice lifted from Manifesto/Promise: short, declarative,
// principle-first.

interface Props {
  slug: 'spacing' | 'motion' | 'dataviz' | 'accessibility';
}

const { slug } = Astro.props;

type Stub = {
  num: string;
  group: string;
  name: string;
  title: string;
  body: string;
};

const STUBS: Record<Props['slug'], Stub> = {
  spacing: {
    num: '08', group: 'How we appear', name: 'Spacing & layout',
    title: 'Generous, considered, never tight.',
    body: 'Whitespace earns its place. The page breathes because every block has room to be what it is — body copy at a comfortable reading column, sections separated by air, chrome that frames without crowding. <em>Density is not depth.</em> When a layout feels crowded, the answer is almost never another column.',
  },
  motion: {
    num: '11', group: 'How we appear', name: 'Motion',
    title: 'Restrained, purposeful, never decorative.',
    body: 'Things move when meaning requires it — a state change, a transition between rooms, a focus shift that draws the eye to where the work is now. We don\'t animate to signal effort. A still page that holds attention is worth more than a page that performs liveliness. <em>Honest before impressive.</em>',
  },
  dataviz: {
    num: '12', group: 'How we appear', name: 'Data viz',
    title: 'Honest before impressive.',
    body: 'Charts that tell the truth even when the truth is messy. One chart, one primary colour. Maximise data, minimise chrome. If a chart needs decoration to be interesting, the underlying data isn\'t the point — and we should be writing prose instead.',
  },
  accessibility: {
    num: '13', group: 'How we appear', name: 'Accessibility',
    title: 'WCAG AA is the floor, not the goal.',
    body: 'Contrast targets hit. Focus states visible. Motion-reduction honoured. Keyboard-first interaction across every surface. Accessibility is a brand decision, not a compliance afterthought — <em>the surface tells you what we think of the audience.</em>',
  },
};

const s = STUBS[slug];
---

<section id={slug} data-brand-section class="melis-section">
  <div class="melis-section-eyebrow-row">
    <span class="num">{s.num}</span>
    <span class="name">{s.group} · {s.name}</span>
    <span class="line"></span>
  </div>
  <h2 class="melis-section-title">{s.title}</h2>

  <div class="melis-prose">
    <p set:html={s.body} />
  </div>
</section>
