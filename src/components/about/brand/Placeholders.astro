---
// Placeholder sections — Spacing & layout · Motion · Data viz ·
// Accessibility. Per Sean's plan: detailed specs are internal,
// available to collaborators. Renders one stub at a time so callers
// can interleave with neighbouring fully-ported sections in source
// order (Spacing sits between Typography and Voice; Motion / DataViz /
// Accessibility sit between Imagery and Influences).

interface Props {
  slug: 'spacing' | 'motion' | 'dataviz' | 'accessibility';
}

const { slug } = Astro.props;

const STUBS = {
  spacing: {
    num: '08', group: 'How we appear', name: 'Spacing & layout',
    lede: 'Detailed spacing tokens (4 / 8 / 16 / 24 / 44 / 64 / 96 px) and the 720 px / 1100 px reading-column widths are part of the internal layout grid. <em>Available to collaborators on request.</em>',
  },
  motion: {
    num: '11', group: 'How we appear', name: 'Motion',
    lede: 'Restrained, intentional, reverent of attention. Easing curves, durations, motion-reduction defaults — all internal. <em>Available to collaborators on request.</em>',
  },
  dataviz: {
    num: '12', group: 'How we appear', name: 'Data viz',
    lede: 'One chart, one primary colour. Maximise data-ink, minimise chart-junk. Token-tied palettes for sequential / diverging / categorical scales. <em>Internal — available to collaborators on request.</em>',
  },
  accessibility: {
    num: '13', group: 'How we appear', name: 'Accessibility',
    lede: 'Accessibility is a brand decision, not a compliance afterthought. WCAG AA contrast targets, keyboard-first interaction, motion-reduction honoured, prose-clarity standards. <em>Internal accessibility spec available to collaborators on request.</em>',
  },
} as const;

const s = STUBS[slug];
---

<section id={slug} data-brand-section class="melis-section">
  <div class="melis-section-eyebrow-row">
    <span class="num">{s.num}</span>
    <span class="name">{s.group} · {s.name}</span>
    <span class="line"></span>
  </div>
  <h2 class="melis-section-title">{s.name}</h2>
  <p class="brand-stub-lede" set:html={s.lede} />
</section>

<style is:global>
  .brand-stub-lede {
    max-width: 720px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-2);
    margin: 0;
  }
  .brand-stub-lede em {
    font-style: italic;
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
  }
</style>
