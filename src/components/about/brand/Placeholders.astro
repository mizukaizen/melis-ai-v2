          <div class="verdict pass">AA</div>
        </div>
        <div class="a11y-pair">
          <div class="swatch" style="background: #0F0F0F; color: #5EEAD4;">Aa</div>
          <div class="label">--signal on --bg</div>
          <div class="ratio">11.3 : 1</div>
          <div class="verdict pass">AAA</div>
        </div>
        <div class="a11y-pair">
          <div class="swatch" style="background: #0F0F0F; color: #F5B342;">Aa</div>
          <div class="label">--amber on --bg</div>
          <div class="ratio">9.7 : 1</div>
          <div class="verdict pass">AAA</div>
        </div>
        <div class="a11y-pair">
          <div class="swatch" style="background: #1A1A1A; color: #6B7280;">Aa</div>
