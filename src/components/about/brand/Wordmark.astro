---
// Section 05 · Wordmark · the logo system. Incorporates 05a Hive
// etymology (Meli · Melissa · Melissae) as a sub-section. Source:
// brand-guidelines.html lines 4820-4934.

import UpsellCard from './UpsellCard.astro';

const ETYMOLOGY = [
  {
    term: 'μέλι',
    translit: 'meli',
    gloss: 'Honey. The sweet substance. The droplet — the essence held in form. The root of <em>Melissa, Melissae, melis</em>.',
    sigil: '<path d="M 12 4 Q 7 11 7 14 A 5 5 0 0 0 17 14 Q 17 11 12 4 Z"/><circle cx="12" cy="13" r="1.25" fill="currentColor" stroke="none"/>',
  },
  {
    term: 'μέλισσα',
    translit: 'melissa',
    gloss: 'Bee. The worker, the connector, the maker of honey. The body abstracted — striped, ovoid, in flight.',
    sigil: '<path d="M 8 11 H 16 A 3 3 0 0 1 16 17 H 8 A 3 3 0 0 1 8 11 Z"/><path d="M 11 11 V 17"/><path d="M 14 11 V 17"/>',
  },
  {
    term: 'Μέλισσαι',
    translit: 'melissae',
    gloss: 'The bee priestesses. The original pattern-recognisers. The oracles of Delphi. The keepers of the hive.',
    sigil: '<circle cx="12" cy="7" r="1.5" fill="currentColor" stroke="none"/><circle cx="7" cy="16" r="1.5" fill="currentColor" stroke="none"/><circle cx="17" cy="16" r="1.5" fill="currentColor" stroke="none"/>',
  },
];
---

<section id="wordmark" data-brand-section class="melis-section">
  <div class="melis-section-eyebrow-row">
    <span class="num">05</span>
    <span class="name">Wordmark · the logo system</span>
    <span class="line"></span>
  </div>
  <h2 class="melis-section-title">A wordmark, not a logo. The word does the work.</h2>

  <div class="melis-prose">
    <p>No mark, no monogram, no glyph. Just the word — set in Cormorant Garamond, lowercase, light weight. The dot is part of the name. <em>Italic emphasis renders the dot in accent purple.</em></p>
  </div>

  <div class="wordmark-row">
    <div class="wordmark-cell">
      <div class="wordmark-meta"><span>Default</span><span>on dark</span></div>
      <div class="wordmark-canvas"><span class="wordmark-display">melis.ai</span></div>
      <div class="wordmark-caption">Cormorant Garamond 300, lowercase, letter-spacing −0.03em. The default everywhere.</div>
    </div>
    <div class="wordmark-cell">
      <div class="wordmark-meta"><span>Italic emphasis</span><span>accent dot</span></div>
      <div class="wordmark-canvas"><span class="wordmark-display wordmark-italic">melis<em>.</em>ai</span></div>
      <div class="wordmark-caption">Italic 400, dot rendered in accent purple. Reserved for display contexts — never default.</div>
    </div>
    <div class="wordmark-cell">
      <div class="wordmark-meta"><span>On light</span><span>inverted</span></div>
      <div class="wordmark-canvas wordmark-canvas-light"><span class="wordmark-display wordmark-light">melis.ai</span></div>
      <div class="wordmark-caption">For light surfaces (light-mode email, third-party slides). Dot stays the same colour as the rest.</div>
    </div>
  </div>

  <h3 class="wordmark-subhead">Three roots beneath the wordmark. <em>Meli. Melissa. Melissae.</em></h3>
  <p class="melis-prose"><span>The brand's name traces back through three Greek words: honey, bee, bee-priestess. The wordmark is downstream of these. Each gets its own glyph — private to melis.ai, used in the brand's deepest registers (the Hive Doctrine, signed dispatches, ritual surfaces).</span></p>

  <div class="lex-grid wordmark-etymology-grid">
    {ETYMOLOGY.map((e) => (
      <article class="lex-card">
        <span class="lex-glyph">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={e.sigil} />
        </span>
        <div class="lex-num">Etymology</div>
        <h4 class="lex-word">{e.term} <span class="translit">{e.translit}</span></h4>
        <p class="lex-gloss" set:html={e.gloss} />
      </article>
    ))}
  </div>

  <UpsellCard
    eyebrow="Studio · Services"
    body="Want a wordmark designed this way? Identity work for AI-first studios — the same system, applied to yours."
    cta="See services"
    href="/services"
  />
</section>

<style is:global>
  .wordmark-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 40px;
  }
  .wordmark-cell {
    display: flex; flex-direction: column;
    border: 1px solid var(--border-2, rgba(232,227,216,0.08));
    background: rgba(255,255,255,0.015);
  }
  .wordmark-meta {
    display: flex; justify-content: space-between;
    padding: 12px 14px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
    border-bottom: 1px solid var(--border-2, rgba(232,227,216,0.06));
  }
  .wordmark-canvas {
    flex: 1;
    min-height: 160px;
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
  }
  .wordmark-canvas-light { background: #fff; color: #0f0f0f; }
  .wordmark-display {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 44px;
    letter-spacing: -0.03em;
    color: var(--text-1, var(--text));
  }
  .wordmark-italic em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }
  .wordmark-light { color: #0f0f0f; }
  .wordmark-caption {
    padding: 12px 14px;
    border-top: 1px solid var(--border-2, rgba(232,227,216,0.06));
    font-size: 12px;
    line-height: 1.55;
    color: var(--text-2);
  }
  .wordmark-subhead {
    margin: 64px 0 14px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    letter-spacing: -0.01em;
    color: var(--text-1, var(--text));
  }
  .wordmark-subhead em { font-style: italic; color: var(--accent); }
  .wordmark-etymology-grid {
    grid-template-columns: repeat(3, 1fr) !important;
    margin-top: 32px;
  }
  @media (max-width: 1100px) {
    .wordmark-row { grid-template-columns: 1fr; }
    .wordmark-etymology-grid { grid-template-columns: 1fr !important; }
  }
</style>
