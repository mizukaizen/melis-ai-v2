---
// Sections 15-17 · Where the brand lives — The website / Soul of
// the Machine / YouTube. Source: brand-guidelines.html lines
// 6724-6830. Each channel renders as eyebrow + glyph + h2 + lede +
// 5-6 spec rows (Purpose / Cadence / Format / etc).

type Row = { label: string; body: string };
type Channel = {
  id: string;
  num: string;
  name: string;
  glyph: string;
  title: string;
  lede: string;
  rows: Row[];
};

const CHANNELS: Channel[] = [
  {
    id: 'website',
    num: '15',
    name: 'Channel · The website',
    glyph: '<path d="M 6 19 V 11 A 6 6 0 0 1 18 11 V 19"/>',
    title: 'The home base. <em>Everything points back here.</em>',
    lede: 'melis.ai is the canonical surface. The newsletter, the YouTube channel, the courses, the products — all of them route back to the website. The website is where the brand can be experienced unmediated by an algorithm. It carries The Dispatch (the personal blog), the courses, the lab, the products, and the brand book itself.',
    rows: [
      { label: 'Purpose',  body: 'The owned surface — outside any platform\'s algorithm. Place to read deeply, browse the work, find the products, and discover the broader system. The newsletter and YouTube are where people hear about us; the website is where they decide.' },
      { label: 'Sections', body: 'The Dispatch (personal blog, written by Sean with AI assistance) · The Cowork Course · The Library (resources) · The Lab (experiments in flight) · Products · About · Brand book.' },
      { label: 'Voice on the site', body: 'Operator-confident on course landings. Reflective and personal on The Dispatch. Functional and precise on product pages. Always Australian, always plain-spoken, always at the level of a peer.' },
      { label: 'What lives on the site only', body: 'Long-form Dispatch essays (not the daily newsletter — different thing). Course content. Product pages. Resource library. The brand book. Anything that\'s owned, evergreen, and not algorithm-dependent.' },
      { label: 'What never lives here', body: 'Pop-ups, exit-intent modals, "subscribe before you read" gates, social proof bars, sticky chat widgets. Anything that performs urgency or extracts attention from the work.' },
    ],
  },
  {
    id: 'soul',
    num: '16',
    name: 'Channel · Soul of the Machine',
    glyph: '<path d="M 5 5 H 19 V 19 H 5 Z"/><circle cx="12" cy="12" r="4"/>',
    title: 'Soul of the Machine. <em>A daily field note from inside the operation.</em>',
    lede: 'Soul of the Machine is the brand\'s daily newsletter — written entirely by the persona agents in the OpenClaw operation, sent through Beehiiv, every morning. It\'s not a curated digest. It\'s not a roundup. It\'s a window into a real AI operation thinking out loud — what the agents noticed yesterday, what they\'re working on today, what\'s shifting in the field. The personas write; Sean reads it like everyone else.',
    rows: [
      { label: 'Purpose',  body: 'Show the operation at work, daily. Build a habit of receiving operator-grade signal in the inbox, generated by the system the brand teaches. Convert curious readers into students, customers, and community members.' },
      { label: 'Cadence',  body: 'Daily. Sent in the morning. Short — a single note from one persona, never a wall of text. If a day genuinely has nothing to say, the system holds — but in practice the personas always have something.' },
      { label: 'Author',   body: 'Authored by the L2 personas in rotation — Marcus, Lila, Priya, Elijah, Ethan, Lara, Liam, Mateo, Sophia. Each persona owns one day\'s note per cycle. Voice slants per persona, but all share the brand\'s underlying tone.' },
      { label: 'Platform', body: 'Beehiiv. Plain editorial template — no marketing chrome, no "view in browser" header, no subscriber-count flexing. Reads like an editorial dispatch, not a SaaS announcement.' },
      { label: 'What never goes in', body: 'Affiliate stacks. AI news roundups. "Top 10 prompts." Recap of yesterday\'s tweet. Anything that sounds like content rather than communication.' },
    ],
  },
  {
    id: 'youtube',
    num: '17',
    name: 'Channel · YouTube',
    glyph: '<path d="M 4 8 H 20 V 16 H 4 Z"/><path d="M 10 10 L 14 12 L 10 14 Z"/>',
    title: 'Essay-grade video. <em>Not how-to slop.</em>',
    lede: 'YouTube is the most-abused platform in AI education. 95% of it is thumbnail bait, AI-Tools-2026 shouting, and recycled prompts dressed as wisdom. The melis.ai channel does the opposite: long-form essays, build-in-public moments, demos at length. Closer to a Vox documentary than a "5 prompts" video. <em>YouTube is where most of our energy goes.</em> It\'s the front door for new audiences who haven\'t found us yet.',
    rows: [
      { label: 'Purpose',  body: 'Reach audiences we don\'t already have. Convert curious viewers into Soul of the Machine subscribers, Dispatch readers, and course students. Establish "operator at the frontier" as the brand\'s centre of gravity. The comments section is the only place we engage with audiences publicly — by design.' },
      { label: 'Cadence',  body: 'High effort, irregular. The aim is one or two essay-grade videos per month — but quality is the gate, not the calendar. Each video earns 10–25 minutes of attention, or it doesn\'t ship.' },
      { label: 'Format',   body: 'Editorial essay. Talking-head plus B-roll of real screens, real systems, real artefacts. Tilt-shift papercraft imagery for thumbnails and intros. No jump cuts every 2 seconds. Trusted-friend pace, not Mr Beast pace.' },
      { label: 'What goes here', body: 'Long-form essays on the craft of operating with AI. Build-along sessions for the Cowork Course. Stories from running the operation, including the failures. Field notes adapted from The Dispatch. Public retrospectives.' },
      { label: 'What never goes here', body: 'Shorts. AI tool comparisons as content. "Top 10" videos. Reaction content. Thumbnails with shocked-face screencaps and red arrows. Listicles. Anything optimised for the algorithm at the expense of the work.' },
      { label: 'Comments policy', body: 'Read. Respond when there\'s something useful to add. Treat YouTube comments as a working channel for new conversations — not a metric. Don\'t reply to bait, don\'t reward outrage, don\'t optimise for engagement. The good ones become community members.' },
    ],
  },
];
---

{CHANNELS.map((c) => (
  <section id={c.id} data-brand-section class="melis-section">
    <div class="melis-section-eyebrow-row">
      <span class="num">{c.num}</span>
      <span class="name">{c.name}</span>
      <span class="line"></span>
    </div>
    <span class="channel-mark">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={c.glyph} />
    </span>
    <h2 class="melis-section-title" set:html={c.title} />
    <div class="melis-prose">
      <p>{c.lede}</p>
    </div>
    <dl class="channel-rows">
      {c.rows.map((r) => (
        <>
          <dt>{r.label}</dt>
          <dd>{r.body}</dd>
        </>
      ))}
    </dl>
  </section>
))}

<style is:global>
  .channel-mark {
    display: inline-flex;
    width: 36px; height: 36px;
    color: var(--text-2);
    margin: 6px 0 16px;
  }
  .channel-mark svg { width: 100%; height: 100%; }
  .channel-rows {
    margin-top: 40px;
    display: grid;
    grid-template-columns: 200px 1fr;
    column-gap: 24px;
    row-gap: 0;
  }
  .channel-rows dt {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
    padding: 16px 0;
    border-top: 1px solid var(--border-2, rgba(232,227,216,0.08));
  }
  .channel-rows dd {
    margin: 0;
    padding: 16px 0;
    border-top: 1px solid var(--border-2, rgba(232,227,216,0.08));
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-2);
  }
  @media (max-width: 1100px) {
    .channel-rows { grid-template-columns: 1fr; row-gap: 0; }
    .channel-rows dd { padding-top: 4px; border-top: none; }
  }
</style>
