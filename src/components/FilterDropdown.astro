---
// Brand-styled custom select. Emits a 'filter:change' CustomEvent
// with the selected option as detail.
interface Props {
  id: string;
  options: string[];
  label?: string;
}

const { id, options, label = 'Filter' } = Astro.props;
---

<div class="filter-dropdown" id={id} data-value={options[0]}>
  <div class="filter-label">{label}</div>
  <button class="filter-trigger" type="button" aria-expanded="false" aria-haspopup="listbox">
    <span class="filter-current">{options[0]}</span>
    <svg class="chevron" viewBox="0 0 10 6" fill="none">
      <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <div class="filter-menu" data-open="false" role="listbox">
    {options.map((opt) => (
      <button class="filter-option" type="button" data-value={opt} role="option">
        <span class="tick">●</span>
        <span>{opt}</span>
      </button>
    ))}
  </div>
</div>

<script>
  function wire() {
    document.querySelectorAll<HTMLElement>('.filter-dropdown').forEach((root) => {
      if (root.dataset.wired === '1') return;
      root.dataset.wired = '1';

      const trigger = root.querySelector<HTMLButtonElement>('.filter-trigger');
      const menu = root.querySelector<HTMLElement>('.filter-menu');
      const current = root.querySelector<HTMLElement>('.filter-current');
      if (!trigger || !menu || !current) return;

      // Initial active mark
      const initVal = root.dataset.value;
      root.querySelectorAll<HTMLElement>('.filter-option').forEach((opt) => {
        if (opt.dataset.value === initVal) opt.classList.add('is-active');
      });

      trigger.addEventListener('click', () => {
        const open = menu.getAttribute('data-open') === 'true';
        menu.setAttribute('data-open', open ? 'false' : 'true');
        trigger.setAttribute('aria-expanded', open ? 'false' : 'true');
      });

      root.querySelectorAll<HTMLElement>('.filter-option').forEach((opt) => {
        opt.addEventListener('click', () => {
          const val = opt.dataset.value || '';
          root.querySelectorAll<HTMLElement>('.filter-option').forEach((o) => o.classList.remove('is-active'));
          opt.classList.add('is-active');
          current.textContent = val;
          root.dataset.value = val;
          menu.setAttribute('data-open', 'false');
          trigger.setAttribute('aria-expanded', 'false');
          root.dispatchEvent(new CustomEvent('filter:change', { detail: val, bubbles: true }));
        });
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) {
          menu.setAttribute('data-open', 'false');
          trigger.setAttribute('aria-expanded', 'false');
        }
      });
    });
  }
  document.addEventListener('astro:page-load', wire);
  wire();
</script>
