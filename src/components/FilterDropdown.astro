---
// Brand-styled custom select. Emits a 'filter:change' CustomEvent
// with the selected option as detail.
interface Props {
  id: string;
  options: string[];
  label?: string;
}

const { id, options, label = 'Filter' } = Astro.props;
---

<div class="filter-dropdown" id={id} data-value={options[0]}>
  <div class="filter-label">{label}</div>
  <button class="filter-trigger" type="button" aria-expanded="false" aria-haspopup="listbox">
    <span class="filter-current">{options[0]}</span>
    <svg class="chevron" viewBox="0 0 10 6" fill="none">
      <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <div class="filter-menu" data-open="false" role="listbox">
    {options.map((opt) => (
      <button class="filter-option" type="button" data-value={opt} role="option">
        <span class="tick">●</span>
        <span>{opt}</span>
      </button>
    ))}
  </div>
</div>

<style>
  .filter-dropdown {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .filter-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .filter-trigger {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    background: rgba(20, 20, 24, 0.45);
    border: 1px solid var(--border-2);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-1);
    cursor: pointer;
    transition: border-color 0.15s var(--ease), background 0.15s var(--ease);
  }
  .filter-trigger:hover {
    border-color: rgba(168, 85, 247, 0.35);
    background: rgba(20, 20, 24, 0.65);
  }
  .filter-trigger[aria-expanded="true"] {
    border-color: var(--accent);
  }
  .filter-trigger .chevron {
    width: 8px;
    height: 6px;
    color: var(--text-3);
    transition: transform 0.2s var(--ease);
  }
  .filter-trigger[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  .filter-menu {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 180px;
    padding: 6px;
    background: rgba(15, 15, 18, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(168, 85, 247, 0.25);
    border-radius: 8px;
    z-index: 10;
  }
  .filter-menu[data-open="true"] { display: block; }
  .filter-option {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 10px;
    background: transparent;
    border: none;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-1);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s var(--ease);
  }
  .filter-option:hover { background: rgba(168, 85, 247, 0.10); }
  .filter-option .tick {
    color: var(--accent);
    font-size: 9px;
    opacity: 0;
  }
  .filter-option.is-active .tick { opacity: 1; }
  .filter-option.is-active { color: var(--accent); }
</style>

<script>
  function wire() {
    document.querySelectorAll<HTMLElement>('.filter-dropdown').forEach((root) => {
      if (root.dataset.wired === '1') return;
      root.dataset.wired = '1';

      const trigger = root.querySelector<HTMLButtonElement>('.filter-trigger');
      const menu = root.querySelector<HTMLElement>('.filter-menu');
      const current = root.querySelector<HTMLElement>('.filter-current');
      if (!trigger || !menu || !current) return;

      // Initial active mark
      const initVal = root.dataset.value;
      root.querySelectorAll<HTMLElement>('.filter-option').forEach((opt) => {
        if (opt.dataset.value === initVal) opt.classList.add('is-active');
      });

      trigger.addEventListener('click', () => {
        const open = menu.getAttribute('data-open') === 'true';
        menu.setAttribute('data-open', open ? 'false' : 'true');
        trigger.setAttribute('aria-expanded', open ? 'false' : 'true');
      });

      root.querySelectorAll<HTMLElement>('.filter-option').forEach((opt) => {
        opt.addEventListener('click', () => {
          const val = opt.dataset.value || '';
          root.querySelectorAll<HTMLElement>('.filter-option').forEach((o) => o.classList.remove('is-active'));
          opt.classList.add('is-active');
          current.textContent = val;
          root.dataset.value = val;
          menu.setAttribute('data-open', 'false');
          trigger.setAttribute('aria-expanded', 'false');
          root.dispatchEvent(new CustomEvent('filter:change', { detail: val, bubbles: true }));
        });
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) {
          menu.setAttribute('data-open', 'false');
          trigger.setAttribute('aria-expanded', 'false');
        }
      });
    });
  }
  document.addEventListener('astro:page-load', wire);
  wire();
</script>
